{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Parseltongue",
  "scopeName": "source.pltg",
  "fileTypes": ["pltg"],
  "patterns": [
    { "include": "#comment" },
    { "include": "#string" },
    { "include": "#variable" },
    { "include": "#keyword-arg" },
    { "include": "#boolean" },
    { "include": "#number" },
    { "include": "#directive-with-name" },
    { "include": "#directive-bare" },
    { "include": "#special-form" },
    { "include": "#effect" },
    { "include": "#operator-logic" },
    { "include": "#operator-comparison" },
    { "include": "#operator-arithmetic" },
    { "include": "#parens" }
  ],
  "repository": {
    "comment": {
      "match": ";.*$",
      "name": "comment.line.number-sign.pltg"
    },
    "string": {
      "begin": "\"",
      "end": "\"",
      "name": "string.quoted.double.pltg",
      "patterns": [
        {
          "match": "\\\\.",
          "name": "constant.character.escape.pltg"
        }
      ]
    },
    "variable": {
      "match": "(?<=[\\s(])\\?[a-zA-Z_][a-zA-Z0-9_-]*",
      "name": "variable.parameter.pltg"
    },
    "keyword-arg": {
      "match": ":[a-zA-Z][a-zA-Z0-9_-]*",
      "name": "constant.pltg"
    },
    "boolean": {
      "match": "(?<=[\\s(])(?:true|false)(?=[\\s)]|$)",
      "name": "constant.numeric.dec.pltg"
    },
    "number": {
      "match": "(?<=[\\s(])-?[0-9]+(\\.[0-9]+)?(?=[\\s)]|$)",
      "name": "constant.numeric.dec.pltg"
    },
    "directive-with-name": {
      "match": "(?<=\\()(fact|axiom|defterm|derive|diff|evidence)\\s+([a-zA-Z_][a-zA-Z0-9_./-]*)",
      "captures": {
        "1": { "name": "keyword.control.flow.pltg" },
        "2": { "name": "entity.name.function.pltg" }
      }
    },
    "directive-bare": {
      "match": "(?<=\\()(?:fact|axiom|defterm|derive|diff|evidence)(?=[\\s)])",
      "name": "keyword.control.flow.pltg"
    },
    "special-form": {
      "match": "(?<=\\()(?:if|let|quote|strict)(?=[\\s)])",
      "name": "keyword.control.flow.pltg"
    },
    "effect": {
      "match": "(?<=\\()(?:consistency|context|dangerously-eval|import|load-document|print|run-on-entry|verify-manual)(?=[\\s)])",
      "name": "constant.character.escape.pltg"
    },
    "operator-logic": {
      "match": "(?<=\\()(?:and|or|not|implies)(?=[\\s)])",
      "name": "keyword.control.flow.pltg"
    },
    "operator-comparison": {
      "match": "(?<=\\()(?:>=|<=|!=|>|<|=)(?=[\\s)])",
      "name": "keyword.operator.comparison.pltg"
    },
    "operator-arithmetic": {
      "match": "(?<=\\()(?:[+\\-*/]|mod)(?=[\\s)])",
      "name": "keyword.operator.arithmetic.pltg"
    },
    "parens": {
      "begin": "\\(",
      "end": "\\)",
      "name": "meta.parens.pltg",
      "patterns": [
        { "include": "$self" }
      ]
    }
  }
}
