    :using (count-exists counting.count-exists-base counting.count-exists-step
            code-check-topic code-check-catches-fabrication))

(defterm code-check-features-impl-count 2
    :evidence (evidence "code_check"
        :quotes ("Code Implementation Checks" "fabricated claims about behavior that")
        :explanation "2 code check demo features in source"))

