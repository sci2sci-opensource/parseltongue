(derive demo-total-count
    (count-exists apples-count apples-pltg-count apples-splats-pltg-count biomarkers-count code-check-count deferred-pltg-count doc-validation-count entry-mocks-count extensibility-count revenue-count self-healing-count spec-validation-count)
    :using (count-exists apples-count apples-pltg-count apples-splats-pltg-count biomarkers-count code-check-count deferred-pltg-count doc-validation-count entry-mocks-count extensibility-count revenue-count self-healing-count spec-validation-count))

; =====================================================================
; Spec validation — intentional demo divergences expressed as implies
; The demo exists to show diff detection; mismatches are expected
; =====================================================================

; --- Spec validation: docstring documents 3 divergence types ---

; Layer 1: DOC — docstring claims these divergences exist
(fact spec-doc-claims-expiry-divergence true
    :evidence (evidence "spec_validation"
        :quotes ("tokens expire in 30 minutes" "1-hour expiry")
        :explanation "Docstring claims expiry mismatch between spec and impl"))

(fact spec-doc-claims-session-divergence true
    :evidence (evidence "spec_validation"
        :quotes ("max 3 sessions" "5 sessions")
        :explanation "Docstring claims session limit mismatch"))

(fact spec-doc-claims-md5-divergence true
    :evidence (evidence "spec_validation"
        :quotes ("MD5 must not be used" "uses MD5 for session IDs")
        :explanation "Docstring claims MD5 used despite being prohibited"))

; Layer 2: IMPL — demo code actually has these divergences
(fact spec-impl-has-expiry-divergence true
    :evidence (evidence "spec_validation"
        :quotes ("(fact spec-token-expiry 1800" "(fact impl-token-expiry 3600")
        :explanation "Spec says 1800s, impl says 3600s — divergence present in demo code"))

(fact spec-impl-has-session-divergence true
    :evidence (evidence "spec_validation"
        :quotes ("(fact spec-max-sessions 3" "(fact impl-max-sessions 5")
        :explanation "Spec says 3, impl says 5 — divergence present in demo code"))

(fact spec-impl-has-md5-divergence true
    :evidence (evidence "spec_validation"
        :quotes ("(fact spec-md5-forbidden true" "(fact impl-session-hash \"md5\"")
        :explanation "Spec forbids MD5, impl uses it — divergence present in demo code"))

; Cross-layer diffs: docstring claim vs actual presence
(diff spec-expiry-doc-vs-impl :replace spec-doc-claims-expiry-divergence :with spec-impl-has-expiry-divergence)
(diff spec-session-doc-vs-impl :replace spec-doc-claims-session-divergence :with spec-impl-has-session-divergence)
(diff spec-md5-doc-vs-impl :replace spec-doc-claims-md5-divergence :with spec-impl-has-md5-divergence)

; Divergence counts
(derive spec-divergence-doc-count
    (count-exists spec-doc-claims-expiry-divergence spec-doc-claims-session-divergence spec-doc-claims-md5-divergence)
    :using (count-exists spec-doc-claims-expiry-divergence spec-doc-claims-session-divergence spec-doc-claims-md5-divergence))

(derive spec-divergence-impl-count
    (count-exists spec-impl-has-expiry-divergence spec-impl-has-session-divergence spec-impl-has-md5-divergence)
    :using (count-exists spec-impl-has-expiry-divergence spec-impl-has-session-divergence spec-impl-has-md5-divergence))

(diff spec-divergence-doc-vs-impl :replace spec-divergence-doc-count :with spec-divergence-impl-count)

; Paired: each divergence type documented AND present
(derive spec-divergence-paired-count
    (count-exists (and spec-doc-claims-expiry-divergence spec-impl-has-expiry-divergence)
                  (and spec-doc-claims-session-divergence spec-impl-has-session-divergence)
                  (and spec-doc-claims-md5-divergence spec-impl-has-md5-divergence))
    :using (count-exists
            spec-doc-claims-expiry-divergence spec-impl-has-expiry-divergence
            spec-doc-claims-session-divergence spec-impl-has-session-divergence
            spec-doc-claims-md5-divergence spec-impl-has-md5-divergence))

(diff spec-divergence-paired-vs-doc :replace spec-divergence-paired-count :with spec-divergence-doc-count)

; --- Intentional mismatches: Items × Layers + implies ---

; Layer 1: DOC — docstring documents each intentional mismatch
(fact spec-expiry-doc-intentional true
    :evidence (evidence "spec_validation"
        :quotes ("Token expiry: spec says 1800s (30 min), impl uses 3600s (60 min)")
        :explanation "Docstring documents expiry mismatch as intentional"))

(fact spec-sessions-doc-intentional true
    :evidence (evidence "spec_validation"
        :quotes ("Session limit: spec says max 3, impl allows 5")
        :explanation "Docstring documents session mismatch as intentional"))

(fact spec-md5-doc-intentional true
    :evidence (evidence "spec_validation"
        :quotes ("MD5 usage: spec prohibits MD5, impl uses it for session IDs")
        :explanation "Docstring documents MD5 mismatch as intentional"))

; Axiom: documented intentional mismatch implies the values will differ
(axiom intentional-mismatch-implies-divergence
    (implies ?doc-intentional (not (= ?spec-val ?impl-val)))
    :evidence (evidence "spec_validation"
        :quotes ("Intentional mismatches (the point of the demo):")
        :explanation "Documented intentional mismatches imply spec/impl values differ"))

; Bind the axiom for each mismatch
(derive expiry-divergence-expected
    intentional-mismatch-implies-divergence
    :bind ((?doc-intentional spec-expiry-doc-intentional)
           (?spec-val spec-validation-token-expiry-spec)
           (?impl-val spec-validation-token-expiry-impl))
    :using (intentional-mismatch-implies-divergence spec-expiry-doc-intentional
            spec-validation-token-expiry-spec spec-validation-token-expiry-impl))

(derive sessions-divergence-expected
    intentional-mismatch-implies-divergence
    :bind ((?doc-intentional spec-sessions-doc-intentional)
           (?spec-val spec-validation-sessions-spec)
           (?impl-val spec-validation-sessions-impl))
    :using (intentional-mismatch-implies-divergence spec-sessions-doc-intentional
            spec-validation-sessions-spec spec-validation-sessions-impl))

; MD5 is a contradiction (both true), not a value mismatch
(axiom intentional-contradiction-implies-coexistence
    (implies ?doc-intentional (and ?prohibited ?used))
    :evidence (evidence "spec_validation"
        :quotes ("MD5 usage: spec prohibits MD5, impl uses it for session IDs")
        :explanation "Documented intentional contradiction implies both prohibited and used coexist"))

(derive md5-divergence-expected
    intentional-contradiction-implies-coexistence
    :bind ((?doc-intentional spec-md5-doc-intentional)
           (?prohibited spec-validation-md5-prohibited)
           (?used spec-validation-md5-used))
    :using (intentional-contradiction-implies-coexistence spec-md5-doc-intentional
            spec-validation-md5-prohibited spec-validation-md5-used))

; Paired: each doc-intentional paired with its impl-divergence
(derive intentional-paired-count
    (count-exists (and spec-expiry-doc-intentional expiry-divergence-expected)
                  (and spec-sessions-doc-intentional sessions-divergence-expected)
                  (and spec-md5-doc-intentional md5-divergence-expected))
    :using (count-exists
            spec-expiry-doc-intentional expiry-divergence-expected
            spec-sessions-doc-intentional sessions-divergence-expected
            spec-md5-doc-intentional md5-divergence-expected))

(derive intentional-doc-count
    (count-exists spec-expiry-doc-intentional spec-sessions-doc-intentional spec-md5-doc-intentional)
    :using (count-exists spec-expiry-doc-intentional spec-sessions-doc-intentional spec-md5-doc-intentional))

(diff intentional-paired-vs-doc :replace intentional-paired-count :with intentional-doc-count)

; spec validation has MD5 both prohibited and used — contradiction grounded in docs
(derive spec-md5-contradiction
    (and spec-validation-md5-prohibited spec-validation-md5-used)
    :using (spec-validation-md5-prohibited spec-validation-md5-used))

; Derives that connect catches-divergence to the mismatch proofs
(derive spec-token-expiry-mismatch
    (implies (not (= spec-validation-token-expiry-spec spec-validation-token-expiry-impl)) spec-validation-catches-divergence)
    :using (spec-validation-token-expiry-spec spec-validation-token-expiry-impl spec-validation-catches-divergence))

(derive spec-session-limit-mismatch
    (implies (not (= spec-validation-sessions-spec spec-validation-sessions-impl)) spec-validation-catches-divergence)
    :using (spec-validation-sessions-spec spec-validation-sessions-impl spec-validation-catches-divergence))

; Mismatch count — demo claims to catch "every divergence", prove there are 3
(derive spec-mismatch-count
    (count-exists spec-token-expiry-mismatch spec-session-limit-mismatch spec-md5-contradiction)
    :using (count-exists spec-token-expiry-mismatch spec-session-limit-mismatch spec-md5-contradiction))

(diff spec-mismatch-vs-divergence-doc :replace spec-mismatch-count :with spec-divergence-doc-count)

; =====================================================================
; Derivations
; =====================================================================

; apples_pltg proves loader bootstraps from empty env (code, not doc)
(fact apples-pltg-uses-empty-env true
    :evidence (evidence "apples_pltg"
        :quotes ("initial_env={},")
        :explanation "apples_pltg passes empty dict as initial_env to load_main"))

; The pltg demo's existence implies the loader bootstrapped everything
(axiom pltg-demo-proves-loader-bootstrap
    (implies (and ?pltg-topic ?empty-env) (and ?successor ?starts-empty))
    :evidence (evidence "apples_pltg"
        :quotes ("Demo: Peano Arithmetic via .pltg — Empty-Env Module Loading.\n\nScenario: Same orchard arithmetic as the apples demo, but executed\nentirely through .pltg file loading with an empty initial environment.\nProves that the Loader of modules works correctly to load DSL for\nbootstrapping Peano successor notation, axioms, imports, and derives\nfrom scratch — no Python-side setup.")
        :explanation "If the pltg demo exists and starts empty, then loader bootstrapped successor notation and empty-start invariant"))

(derive pltg-loader-bootstrap-confirmed
    pltg-demo-proves-loader-bootstrap
    :bind ((?pltg-topic apples-pltg-topic) (?empty-env apples-pltg-uses-empty-env)
           (?successor apples-uses-successor-notation) (?starts-empty apples-starts-empty))
    :using (pltg-demo-proves-loader-bootstrap apples-pltg-topic apples-pltg-uses-empty-env
            apples-uses-successor-notation apples-starts-empty))

; splats topic implies splats usage in the demo
(axiom splats-topic-implies-usage
    (implies ?splats-topic ?splats-usage)
    :evidence (evidence "apples_splats_pltg"
        :quotes ("Demo: Apple Arithmetic with Variadic Splats (?...).\n\nSame orchard, same ground truth — but axioms now use ?... splat\npatterns for variadic operations: sum-all, count-gt, all-gt.")
        :explanation "The splats demo topic entails ?... splat pattern usage"))

(derive splats-topic-confirms-usage
    splats-topic-implies-usage
    :bind ((?splats-topic apples-splats-pltg-topic) (?splats-usage apples-splats-uses-splat-patterns))
    :using (splats-topic-implies-usage apples-splats-pltg-topic apples-splats-uses-splat-patterns))

; --- Self-healing: docstring documents 6 effects, code registers them ---

; Layer 1: DOC — docstring lists effects
(fact self-healing-doc-has-load-data true
    :evidence (evidence "self_healing"
        :quotes ("(load-data name path)")
        :explanation "Docstring lists load-data effect"))

(fact self-healing-doc-has-check-diff true
    :evidence (evidence "self_healing"
        :quotes ("(check-diff name)")
        :explanation "Docstring lists check-diff effect"))

(fact self-healing-doc-has-check-consistency true
    :evidence (evidence "self_healing"
        :quotes ("(check-consistency)")
        :explanation "Docstring lists check-consistency effect"))

(fact self-healing-doc-has-snapshot true
    :evidence (evidence "self_healing"
        :quotes ("(snapshot name)")
        :explanation "Docstring lists snapshot effect"))

(fact self-healing-doc-has-patch-fact true
    :evidence (evidence "self_healing"
        :quotes ("(patch-fact name value)")
        :explanation "Docstring lists patch-fact effect"))

(fact self-healing-doc-has-rollback true
    :evidence (evidence "self_healing"
        :quotes ("(rollback name)")
        :explanation "Docstring lists rollback effect"))

; Layer 2: IMPL — effects registered in System constructor
(fact self-healing-impl-has-load-data true
    :evidence (evidence "self_healing"
        :quotes ("\"load-data\": load_data,")
        :explanation "load-data effect registered"))

(fact self-healing-impl-has-check-diff true
    :evidence (evidence "self_healing"
        :quotes ("\"check-diff\": check_diff,")
        :explanation "check-diff effect registered"))

(fact self-healing-impl-has-check-consistency true
    :evidence (evidence "self_healing"
        :quotes ("\"check-consistency\": check_consistency,")
        :explanation "check-consistency effect registered"))

(fact self-healing-impl-has-snapshot true
    :evidence (evidence "self_healing"
        :quotes ("\"snapshot\": snapshot,")
        :explanation "snapshot effect registered"))

(fact self-healing-impl-has-patch-fact true
    :evidence (evidence "self_healing"
        :quotes ("\"patch-fact\": patch_fact,")
        :explanation "patch-fact effect registered"))

(fact self-healing-impl-has-rollback true
    :evidence (evidence "self_healing"
        :quotes ("\"rollback\": rollback,")
        :explanation "rollback effect registered"))

; Per-layer counts
(derive self-healing-doc-count
    (count-exists self-healing-doc-has-load-data self-healing-doc-has-check-diff
                  self-healing-doc-has-check-consistency self-healing-doc-has-snapshot
                  self-healing-doc-has-patch-fact self-healing-doc-has-rollback)
    :using (count-exists self-healing-doc-has-load-data self-healing-doc-has-check-diff
                         self-healing-doc-has-check-consistency self-healing-doc-has-snapshot
                         self-healing-doc-has-patch-fact self-healing-doc-has-rollback))

(derive self-healing-impl-count
    (count-exists self-healing-impl-has-load-data self-healing-impl-has-check-diff
                  self-healing-impl-has-check-consistency self-healing-impl-has-snapshot
                  self-healing-impl-has-patch-fact self-healing-impl-has-rollback)
    :using (count-exists self-healing-impl-has-load-data self-healing-impl-has-check-diff
                         self-healing-impl-has-check-consistency self-healing-impl-has-snapshot
                         self-healing-impl-has-patch-fact self-healing-impl-has-rollback))

(diff self-healing-doc-vs-impl :replace self-healing-doc-count :with self-healing-impl-count)

; Paired: each effect documented AND registered
(derive self-healing-paired-count
    (count-exists (and self-healing-doc-has-load-data self-healing-impl-has-load-data)
                  (and self-healing-doc-has-check-diff self-healing-impl-has-check-diff)
                  (and self-healing-doc-has-check-consistency self-healing-impl-has-check-consistency)
                  (and self-healing-doc-has-snapshot self-healing-impl-has-snapshot)
                  (and self-healing-doc-has-patch-fact self-healing-impl-has-patch-fact)
                  (and self-healing-doc-has-rollback self-healing-impl-has-rollback))
    :using (count-exists
            self-healing-doc-has-load-data self-healing-impl-has-load-data
            self-healing-doc-has-check-diff self-healing-impl-has-check-diff
            self-healing-doc-has-check-consistency self-healing-impl-has-check-consistency
            self-healing-doc-has-snapshot self-healing-impl-has-snapshot
            self-healing-doc-has-patch-fact self-healing-impl-has-patch-fact
            self-healing-doc-has-rollback self-healing-impl-has-rollback))

(diff self-healing-paired-vs-doc :replace self-healing-paired-count :with self-healing-doc-count)

; self-healing demo can recover: it has snapshot, patch, and rollback
; These 3 are the recovery subset — connect old dangling facts
(derive self-healing-can-recover
    (and self-healing-has-snapshot self-healing-has-patch self-healing-has-rollback)
    :using (self-healing-has-snapshot self-healing-has-patch self-healing-has-rollback))

(derive self-healing-recovery-count
    (count-exists self-healing-has-snapshot self-healing-has-patch self-healing-has-rollback)
    :using (count-exists self-healing-has-snapshot self-healing-has-patch self-healing-has-rollback
            self-healing-can-recover))

(defterm self-healing-recovery-expected 3
    :evidence (evidence "self_healing"
        :quotes ("(snapshot name)" "(rollback name)" "(patch-fact name value)")
        :explanation "3 recovery effects in self-healing demo"))

(diff self-healing-recovery-coverage
    :replace self-healing-recovery-count
    :with self-healing-recovery-expected)

; =====================================================================
; MODULE SYSTEM AXIOMS — universal rules proved by .pltg demos
; =====================================================================

; ---------------------------------------------------------------------
; Axiom 1: Local aliasing rule
; For any module ?m and symbol ?s, (defterm ?alias ?m.?s) makes
; ?alias resolve to the namespaced value. Proved by apples_pltg.
; ---------------------------------------------------------------------

(axiom alias-resolves (= ?alias ?m-symbol)
    :evidence (evidence "apples_demo_pltg"
        :quotes ("(defterm local-zero src.primitives.zero :origin \"import\")"
                 "(defterm local-succ src.primitives.succ :origin \"import\")")
        :explanation "Local alias defterm makes ?alias equal to the namespaced ?m-symbol"))

; Concrete instantiation: local-zero = src.primitives.zero
(fact alias-local-zero-exists true
    :evidence (evidence "apples_demo_pltg"
        :quotes ("(defterm local-zero src.primitives.zero :origin \"import\")")
        :explanation "demo.pltg aliases zero"))

(fact alias-local-zero-used-in-bind true
    :evidence (evidence "apples_demo_pltg"
        :quotes (":bind ((?n (local-succ (local-succ (local-succ local-zero)))))")
        :explanation "Local alias used in :bind — proves resolution works"))

(derive alias-used-in-practice
    (and alias-local-zero-exists alias-local-zero-used-in-bind)
    :using (alias-local-zero-exists alias-local-zero-used-in-bind))

; ---------------------------------------------------------------------
; Axiom 2: Lazy vs eager aliasing
; (defterm ?alias (quote ?m.?s)) delays resolution (lazy).
; (defterm ?alias ?m.?s) resolves immediately (eager).
; Both patterns coexist in axioms.pltg.
; ---------------------------------------------------------------------

(axiom defterm-alias-is-lazy (= ?alias ?target)
    :evidence (evidence "apples_axioms_pltg"
        :quotes ("(defterm - src.primitives.- :origin \"import\")"
                 "(defterm > src.primitives.> :origin \"import\")")
        :explanation "defterm aliasing is inherently lazy — resolution is deferred regardless of quote"))

; The quote wrapper is redundant: both patterns produce the same result
(fact no-explicit-lazy-label true
    :evidence (evidence "apples_axioms_pltg"
        :quotes ("(defterm = src.primitives.= :origin \"import\")"
                 "(defterm + src.primitives.+ :origin \"import\")"
                 "(defterm - src.primitives.- :origin \"import\")")
        :explanation "No alias carries an explicit 'lazy' label — all use plain 'import'"))

; --- Proof chain: quote is redundant in defterm aliasing ---

; Step 1: let rebinds a bare (non-quoted) defterm alias
(fact let-rebinds-bare-alias true
    :evidence (evidence "entry_mocks_math_pltg"
        :quotes ("(defterm zero primitives.zero :origin \"import\")"
                 "(let ((primitives.zero 0)" "(primitives.plus +)" "(primitives.equals =))")
        :explanation "math.pltg aliases primitives.zero without quote, then let rebinds it to 0"))

; Step 2: if let can rebind a bare alias, the symbol was NOT eagerly resolved
;         (if it had been eagerly resolved, rebinding the original wouldn't propagate)
(axiom let-rebind-proves-lazy (implies ?let-can-rebind-bare (not ?eagerly-resolved))
    :evidence (evidence "entry_mocks_math_pltg"
        :quotes ("(assert-true \"add-identity: 5 + 0 = 5\""
                 "(primitives.equals (primitives.plus 5 primitives.zero) 5))")
        :explanation "Assert passes after let rebind — bare alias was not eagerly resolved"))

; Step 3: defterm uses the same resolution mechanism for all aliases
(fact defterm-same-mechanism true
    :evidence (evidence "apples_axioms_pltg"
        :quotes ("(defterm zero src.primitives.zero :origin \"import\")"
                 "(defterm = src.primitives.= :origin \"import\")")
        :explanation "All aliases go through the same defterm path — no quote distinction"))

; Step 4: therefore every defterm is lazy — quote adds nothing
(derive every-defterm-is-lazy
    (and let-rebinds-bare-alias defterm-same-mechanism)
    :using (let-rebinds-bare-alias defterm-same-mechanism))

; Step 5: labels say 2, reality says 7
; Nothing is explicitly lazy, but everything IS lazy (proven by let-rebind chain)
; → laziness is the default behavior of defterm
(derive laziness-is-default
    (and no-explicit-lazy-label every-defterm-is-lazy)
    :using (no-explicit-lazy-label every-defterm-is-lazy))

(defterm lazy-alias-zero (if every-defterm-is-lazy 1 0)
    :evidence (evidence "apples_axioms_pltg"
        :quotes ("(defterm zero src.primitives.zero :origin \"import\")")
        :explanation "bare alias — lazy by axiom chain"))

(defterm lazy-alias-succ (if every-defterm-is-lazy 1 0)
    :evidence (evidence "apples_axioms_pltg"
        :quotes ("(defterm succ src.primitives.succ :origin \"import\")")
        :explanation "bare alias — lazy by axiom chain"))

(defterm lazy-alias-eq (if every-defterm-is-lazy 1 0)
    :evidence (evidence "apples_axioms_pltg"
        :quotes ("(defterm = src.primitives.= :origin \"import\")")
        :explanation "alias — lazy by axiom chain"))

(defterm lazy-alias-plus (if every-defterm-is-lazy 1 0)
    :evidence (evidence "apples_axioms_pltg"
        :quotes ("(defterm + src.primitives.+ :origin \"import\")")
        :explanation "alias — lazy by axiom chain"))

(defterm lazy-alias-minus (if every-defterm-is-lazy 1 0)
    :evidence (evidence "apples_axioms_pltg"
        :quotes ("(defterm - src.primitives.- :origin \"import\")")
        :explanation "bare alias — lazy by axiom chain"))

(defterm lazy-alias-gt (if every-defterm-is-lazy 1 0)
    :evidence (evidence "apples_axioms_pltg"
        :quotes ("(defterm > src.primitives.> :origin \"import\")")
        :explanation "bare alias — lazy by axiom chain"))

(defterm lazy-alias-mul (if every-defterm-is-lazy 1 0)
    :evidence (evidence "apples_axioms_pltg"
        :quotes ("(defterm * src.primitives.* :origin \"import\")")
        :explanation "bare alias — lazy by axiom chain"))

(derive actual-lazy-count
    (count-exists lazy-alias-zero lazy-alias-succ lazy-alias-eq lazy-alias-plus lazy-alias-minus lazy-alias-gt lazy-alias-mul)
    :using (count-exists lazy-alias-zero lazy-alias-succ lazy-alias-eq lazy-alias-plus lazy-alias-minus lazy-alias-gt lazy-alias-mul))

; Since laziness is default, labeled count = actual count
(derive labeled-lazy-count
    (if laziness-is-default actual-lazy-count 0)
    :using (laziness-is-default actual-lazy-count))

; Step 6: diff — labeled matches actual after fix
(diff lazy-label-vs-reality
    :replace labeled-lazy-count
    :with actual-lazy-count)

; ---------------------------------------------------------------------
; Axiom 3: Forward-declared primitives
; For any term ?t with no body (:origin "primitive"), using ?t in an
; expression produces a formal (symbolic) expression — no import needed.
; ---------------------------------------------------------------------

(axiom forward-decl-produces-formal (implies (= ?t ?t) (= (?t ?x) (?t ?x)))
    :evidence (evidence "apples_afternoon_pltg"
        :quotes ("succ/zero are used here without explicit imports"
                 "evaluation returns them as bare"
                 "Symbols, producing formal expressions like (succ (succ zero))")
        :explanation "Forward-declared term with no body produces formal expression"))

(fact primitives-are-forward-declared true
    :evidence (evidence "apples_primitives_pltg"
        :quotes ("(defterm zero" "(defterm succ")
        :explanation "zero and succ declared with evidence but no computed body"))

(fact afternoon-uses-without-import true
    :evidence (evidence "apples_afternoon_pltg"
        :quotes ("(defterm serpent-afternoon (succ (succ (succ (succ zero))))")
        :explanation "afternoon.pltg uses succ/zero without importing primitives"))

(derive forward-decl-proven-by-afternoon
    (and primitives-are-forward-declared afternoon-uses-without-import)
    :using (primitives-are-forward-declared afternoon-uses-without-import))

; Also proved by entry_mocks
(fact entry-mocks-primitives-forward-declared true
    :evidence (evidence "entry_mocks_primitives_pltg"
        :quotes ("(defterm zero :origin \"primitive\")"
                 "(defterm succ :origin \"primitive\")")
        :explanation "entry_mocks primitives are pure forward declarations with :origin"))

; ---------------------------------------------------------------------
; Axiom 4: run-on-entry gating
; For any module ?m, if ?m is not main, (run-on-entry ...) is skipped.
; If ?m is main, it fires. Proved by deferred_pltg.
; ---------------------------------------------------------------------

(axiom run-on-entry-gate (implies (not ?is-main) (= ?run-on-entry false))
    :evidence (evidence "deferred_demo_pltg"
        :quotes ("lib's run-on-entry: SKIPPED (not main)"
                 "app's run-on-entry: SKIPPED (not main)"
                 "Only demo.pltg is main, so only its run-on-entry fires.")
        :explanation "run-on-entry is gated on is_main — skipped for all imported modules"))

(fact lib-has-run-on-entry true
    :evidence (evidence "deferred_lib_pltg"
        :quotes ("(run-on-entry"
                 "(quote (fact standalone-mode true :origin \"deferred — only when main\"))")
        :explanation "lib.pltg defines run-on-entry facts"))

(fact app-has-run-on-entry true
    :evidence (evidence "deferred_app_pltg"
        :quotes ("(run-on-entry"
                 "(quote (fact app-initialized true :origin \"deferred — app is main\"))")
        :explanation "app.pltg defines run-on-entry facts"))

(fact demo-run-on-entry-fires true
    :evidence (evidence "deferred_demo_pltg"
        :quotes ("(run-on-entry"
                 "(quote (fact demo-ready true :origin \"deferred — demo is main\")))")
        :explanation "demo.pltg's run-on-entry fires because it IS main"))

(derive run-on-entry-gating-proven
    (and lib-has-run-on-entry app-has-run-on-entry demo-run-on-entry-fires deferred-skips-on-import)
    :using (lib-has-run-on-entry app-has-run-on-entry demo-run-on-entry-fires deferred-skips-on-import))

; ---------------------------------------------------------------------
; Axiom 5: let-mock rebinding
; For any forward-declared ?term, (let ((?term ?val)) ?expr) rebinds
; ?term to ?val, making formal expressions computable. This is the
; unit-testing pattern: formal theorems become executable assertions.
; ---------------------------------------------------------------------

(axiom let-rebinds-forward-decl (implies (and ?is-forward-declared ?has-mock-value) ?is-computable)
    :evidence (evidence "entry_mocks_math_pltg"
        :quotes ("run-on-entry block rebinds the non-existent primitives"
                 "to concrete mock values via let, turning the formal theorem"
                 "into a computable self-test")
        :explanation "let rebinds forward-declared primitives to concrete values, making formal expressions computable"))

(fact let-mock-rebinds-zero true
    :evidence (evidence "entry_mocks_math_pltg"
        :quotes ("(let ((primitives.zero 0)" "(primitives.plus +)" "(primitives.equals =))")
        :explanation "let rebinds zero→0, plus→+, equals→= inside run-on-entry"))

(fact let-mock-asserts true
    :evidence (evidence "entry_mocks_math_pltg"
        :quotes ("(assert-true \"add-identity: 5 + 0 = 5\""
                 "(primitives.equals (primitives.plus 5 primitives.zero) 5))")
        :explanation "Rebound primitives used in assert-true — formal becomes computable"))

(fact let-mock-in-run-on-entry true
    :evidence (evidence "entry_mocks_math_pltg"
        :quotes ("(run-on-entry" "(quote (assert-true \"add-identity: 5 + 0 = 5\"")
        :explanation "Mock rebinding happens inside run-on-entry for test isolation"))

(derive let-mock-unit-test-proven
    (and let-mock-rebinds-zero let-mock-asserts let-mock-in-run-on-entry entry-mocks-uses-let)
    :using (let-mock-rebinds-zero let-mock-asserts let-mock-in-run-on-entry entry-mocks-uses-let))

; ---------------------------------------------------------------------
; Axiom 6: Import chain transitivity
; If ?a imports ?b and ?b imports ?c, then ?a has access to ?c's
; namespaced definitions. Proved by deferred_pltg's 3-level chain.
; ---------------------------------------------------------------------

(axiom import-transitive (implies (and ?a-imports-b ?b-imports-c) ?a-has-c)
    :evidence (evidence "deferred_demo_pltg"
        :quotes ("Importing app (which imports lib)")
        :explanation "demo imports app, app imports lib — demo sees lib's facts"))

(fact chain-demo-imports-app true
    :evidence (evidence "deferred_demo_pltg"
        :quotes ("(import (quote app))")
        :explanation "demo.pltg imports app"))

(fact chain-app-imports-lib true
    :evidence (evidence "deferred_app_pltg"
        :quotes ("(import (quote lib))")
        :explanation "app.pltg imports lib"))

(fact chain-lib-has-facts true
    :evidence (evidence "deferred_lib_pltg"
        :quotes ("(fact api-version 3 :origin \"library constant\")"
                 "(fact max-retries 5 :origin \"library constant\")")
        :explanation "lib.pltg defines regular facts that load on import"))

(derive import-chain-proven
    (and chain-demo-imports-app chain-app-imports-lib chain-lib-has-facts)
    :using (chain-demo-imports-app chain-app-imports-lib chain-lib-has-facts))

; ---------------------------------------------------------------------
; Axiom 7: Cross-module :bind
; For any axiom ?ax in module ?m, (derive ?thm ?m.?ax :bind ...)
; instantiates the axiom with concrete terms from the current module.
; ---------------------------------------------------------------------

(axiom cross-module-bind (implies (and ?axiom-in-module ?bindings-from-local) ?theorem-instantiated)
    :evidence (evidence "apples_demo_pltg"
        :quotes ("(derive three-plus-zero src.axioms.add-identity"
                 ":bind ((?n (local-succ (local-succ (local-succ local-zero)))))"
                 ":using (src.axioms.add-identity local-succ local-zero))")
        :explanation "Axiom from one module can be instantiated with terms from another via :bind"))

(fact cross-bind-mixes-namespaces true
    :evidence (evidence "apples_demo_pltg"
        :quotes (":using (src.axioms.add-identity local-succ local-zero)")
        :explanation ":using mixes namespaced axiom ref with local alias terms"))

(fact cross-bind-multiple-axioms true
    :evidence (evidence "apples_demo_pltg"
        :quotes ("(derive commute-3-2 src.axioms.add-commutative"
                 "(derive add-step-3-1 src.axioms.add-succ")
        :explanation "Multiple axioms from same module instantiated in demo"))

(derive cross-module-bind-proven
    (and cross-bind-mixes-namespaces cross-bind-multiple-axioms)
    :using (cross-bind-mixes-namespaces cross-bind-multiple-axioms))

; ---------------------------------------------------------------------
; Axiom 8: Dot-separated import path resolution
; (import (quote ?a.?b)) resolves to ?a/?b.pltg relative to current dir.
; Proved by src.primitives, src.axioms, src.morning, src.afternoon.
; ---------------------------------------------------------------------

(axiom dot-import-resolves (implies ?dot-separated-name ?maps-to-path)
    :evidence (evidence "apples_demo_pltg"
        :quotes ("(import (quote src.primitives))"
                 "(import (quote src.axioms))"
                 "(import (quote src.morning))"
                 "(import (quote src.afternoon))")
        :explanation "Dot-separated module name maps to directory path — src.primitives → src/primitives.pltg"))

(fact flat-import-also-works true
    :evidence (evidence "entry_mocks_math_pltg"
        :quotes ("(import (quote primitives))"
                 "(import (quote axioms))")
        :explanation "Single-segment imports resolve to sibling files without dots"))

; =====================================================================
; Code vs Docs — two-branch-then-diff
; =====================================================================

; --- 1. Apples demo features ---

(derive apples-features-doc-count
    (count-exists apples-starts-empty apples-uses-successor-notation)
    :using (count-exists counting.count-exists-base counting.count-exists-step
            apples-starts-empty apples-uses-successor-notation
            pltg-loader-bootstrap-confirmed))

(defterm apples-features-impl-count 2
    :evidence (evidence "apples"
        :quotes ("Starts with a completely empty system" "all in successor notation")
        :explanation "2 apples demo features in source"))

(diff apples-features-coverage
    :replace apples-features-doc-count
    :with apples-features-impl-count)

; --- 2. Apples splats demo features ---

(fact apples-splats-uses-splat-patterns-impl true
    :evidence (evidence "splats_axioms_pltg"
        :quotes ("; --- Variadic axioms via ?... splats ---
; These enable working with arbitrary numbers of piles at once,
; instead of nesting binary operations by hand."
                 "(axiom sum-all-step (= (sum-all ?x ?y ?...rest) (+ ?x (sum-all ?y ?...rest)))"
                 "(axiom count-gt-step
    (= (count-gt ?t ?x ?y ?...rest)
       (+ (if (> ?x ?t) 1 0) (count-gt ?t ?y ?...rest))))"
                 "(axiom all-gt-step
    (= (all-gt ?t ?x ?y ?...rest)
       (and (> ?x ?t) (all-gt ?t ?y ?...rest))))")
        :explanation "axioms.pltg defines sum-all, count-gt, all-gt using ?...rest splat patterns"))

(fact apples-splats-replaces-nested-ops-impl true
    :evidence (evidence "splats_demo_pltg"
        :quotes ("; OLD way: (+ (+ eve-morning adam-morning) (+ serpent-afternoon eve-afternoon))
; NEW way: just list them all"
                 "(defterm daily-total
    (sum-all src.morning.eve-morning src.morning.adam-morning
             src.afternoon.serpent-afternoon src.afternoon.eve-afternoon)")
        :explanation "demo.pltg replaces nested (+ (+ ...)) with flat (sum-all ...) call"))

; --- Apples splats: docstring claims 3 variadic ops, axioms.pltg implements them ---

; Layer 1: DOC — docstring claims these variadic operations
(fact apples-splats-doc-sum-all true
    :evidence (evidence "apples_splats_pltg"
        :quotes ("sum-all")
        :explanation "Docstring lists sum-all as a variadic operation"))

(fact apples-splats-doc-count-gt true
    :evidence (evidence "apples_splats_pltg"
        :quotes ("count-gt")
        :explanation "Docstring lists count-gt as a variadic operation"))

(fact apples-splats-doc-all-gt true
    :evidence (evidence "apples_splats_pltg"
        :quotes ("all-gt")
        :explanation "Docstring lists all-gt as a variadic operation"))

; Layer 2: IMPL — axioms.pltg defines splat axioms for each
(fact apples-splats-impl-sum-all true
    :evidence (evidence "splats_axioms_pltg"
        :quotes ("(axiom sum-all-base (= (sum-all ?x) ?x)"
                 "(axiom sum-all-step (= (sum-all ?x ?y ?...rest) (+ ?x (sum-all ?y ?...rest)))")
        :explanation "sum-all has base and step axioms using ?...rest"))

(fact apples-splats-impl-count-gt true
    :evidence (evidence "splats_axioms_pltg"
        :quotes ("(axiom count-gt-base (= (count-gt ?t ?x) (+ (if (> ?x ?t) 1 0) 0))"
                 "(axiom count-gt-step"
                 "(= (count-gt ?t ?x ?y ?...rest)")
        :explanation "count-gt has base and step axioms using ?...rest"))

(fact apples-splats-impl-all-gt true
    :evidence (evidence "splats_axioms_pltg"
        :quotes ("(axiom all-gt-base (= (all-gt ?t ?x) (> ?x ?t))"
                 "(axiom all-gt-step"
                 "(= (all-gt ?t ?x ?y ?...rest)")
        :explanation "all-gt has base and step axioms using ?...rest"))

; Cross-layer diffs
(diff apples-splats-sum-all-doc-vs-impl :replace apples-splats-doc-sum-all :with apples-splats-impl-sum-all)
(diff apples-splats-count-gt-doc-vs-impl :replace apples-splats-doc-count-gt :with apples-splats-impl-count-gt)
(diff apples-splats-all-gt-doc-vs-impl :replace apples-splats-doc-all-gt :with apples-splats-impl-all-gt)

; Per-layer counts
(derive apples-splats-doc-count
    (count-exists apples-splats-doc-sum-all apples-splats-doc-count-gt apples-splats-doc-all-gt)
    :using (count-exists apples-splats-doc-sum-all apples-splats-doc-count-gt apples-splats-doc-all-gt))

(derive apples-splats-impl-count
    (count-exists apples-splats-impl-sum-all apples-splats-impl-count-gt apples-splats-impl-all-gt)
    :using (count-exists apples-splats-impl-sum-all apples-splats-impl-count-gt apples-splats-impl-all-gt))

(diff apples-splats-doc-vs-impl :replace apples-splats-doc-count :with apples-splats-impl-count)

; Paired: each variadic op documented AND implemented
(derive apples-splats-paired-count
    (count-exists (and apples-splats-doc-sum-all apples-splats-impl-sum-all)
                  (and apples-splats-doc-count-gt apples-splats-impl-count-gt)
                  (and apples-splats-doc-all-gt apples-splats-impl-all-gt))
    :using (count-exists
            apples-splats-doc-sum-all apples-splats-impl-sum-all
            apples-splats-doc-count-gt apples-splats-impl-count-gt
            apples-splats-doc-all-gt apples-splats-impl-all-gt))

(diff apples-splats-paired-vs-doc :replace apples-splats-paired-count :with apples-splats-doc-count)

; Original feature-level diffs — splat patterns and nested ops replacement
(diff apples-splats-splat-pair
    :replace apples-splats-uses-splat-patterns
    :with apples-splats-uses-splat-patterns-impl)

(diff apples-splats-nested-ops-pair
    :replace apples-splats-replaces-nested-ops
    :with apples-splats-replaces-nested-ops-impl)

; --- 3. Biomarkers demo features ---

(derive biomarkers-features-doc-count
    (count-exists biomarkers-topic biomarkers-uses-two-papers biomarkers-flags-conflict)
    :using (count-exists counting.count-exists-base counting.count-exists-step
            biomarkers-topic biomarkers-uses-two-papers biomarkers-flags-conflict))

(defterm biomarkers-features-impl-count 3
    :evidence (evidence "biomarkers"
        :quotes ("Biomarker Evidence Conflict" "Two papers report on fecal calprotectin" "flags the conflict")
        :explanation "3 biomarkers demo features in source"))

