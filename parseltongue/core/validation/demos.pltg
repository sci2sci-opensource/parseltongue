    (count-exists flat-import-also-works)
    :using (count-exists counting.count-exists-base
            flat-import-also-works))

(defterm import-patterns-impl-count 1
    :evidence (evidence "entry_mocks_math_pltg"
        :quotes ("(import (quote primitives))")
        :explanation "1 flat import pattern in source"))

(diff import-patterns-coverage
    :replace import-patterns-doc-count
    :with import-patterns-impl-count)

