; demos.pltg — Ground truth from demo files
;
; Two layers:
;   1. Demo identity/existence — grounded in demo.py docstrings
;   2. Module system axioms — universal rules proved by .pltg demos

(load-document "apples" "../demos/apples/demo.py")
(load-document "apples_pltg" "../demos/apples_pltg/demo.py")
(load-document "apples_splats_pltg" "../demos/apples_splats_pltg/demo.py")
(load-document "biomarkers" "../demos/biomarkers/demo.py")
(load-document "code_check" "../demos/code_check/demo.py")
(load-document "deferred_pltg" "../demos/deferred_pltg/demo.py")
(load-document "doc_validation" "../demos/doc_validation/demo.py")
(load-document "entry_mocks_pltg" "../demos/entry_mocks_pltg/demo.py")
(load-document "extensibility" "../demos/extensibility/demo.py")
(load-document "revenue_reports" "../demos/revenue_reports/demo.py")
(load-document "self_healing" "../demos/self_healing/demo.py")
(load-document "spec_validation" "../demos/spec_validation/demo.py")
(import (quote counting))
(defterm count-exists counting.count-exists :origin "import")

; .pltg source files — module system patterns
(load-document "splats_demo_pltg" "../demos/apples_splats_pltg/demo.pltg")
(load-document "splats_axioms_pltg" "../demos/apples_splats_pltg/src/axioms.pltg")
(load-document "apples_demo_pltg" "../demos/apples_pltg/demo.pltg")
(load-document "apples_primitives_pltg" "../demos/apples_pltg/src/primitives.pltg")
(load-document "apples_axioms_pltg" "../demos/apples_pltg/src/axioms.pltg")
(load-document "apples_afternoon_pltg" "../demos/apples_pltg/src/afternoon.pltg")
(load-document "deferred_demo_pltg" "../demos/deferred_pltg/demo.pltg")
(load-document "deferred_app_pltg" "../demos/deferred_pltg/app.pltg")
(load-document "deferred_lib_pltg" "../demos/deferred_pltg/lib.pltg")
(load-document "entry_mocks_math_pltg" "../demos/entry_mocks_pltg/src/math.pltg")
(load-document "entry_mocks_primitives_pltg" "../demos/entry_mocks_pltg/src/primitives.pltg")

