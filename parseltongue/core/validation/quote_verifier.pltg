; quote_verifier.pltg — Ground truth from quote_verifier/

(load-document "verifier.py" "../quote_verifier/verifier.py")
(load-document "normalizer.py" "../quote_verifier/normalizer.py")
(load-document "config.py" "../quote_verifier/config.py")
(import (quote counting))
(defterm count-exists counting.count-exists :origin "import")

; =====================================================================
; Normalizer pipeline — 6 steps
; =====================================================================

(fact normalizer-step-count 6
    :evidence (evidence "normalizer.py"
        :quotes ("Six-step normalization: case, lists, hyphenation, punctuation, stopwords, whitespace.")
        :explanation "Docstring documents 6 steps"))

(fact normalizer-step-1 "case"
    :evidence (evidence "normalizer.py"
        :quotes ("_normalize_case")
        :explanation "Step 1: case"))

(fact normalizer-step-2 "lists"
    :evidence (evidence "normalizer.py"
        :quotes ("_normalize_lists")
        :explanation "Step 2: lists"))

(fact normalizer-step-3 "hyphenation"
    :evidence (evidence "normalizer.py"
        :quotes ("_normalize_hyphenation")
        :explanation "Step 3: hyphenation"))

(fact normalizer-step-4 "punctuation"
    :evidence (evidence "normalizer.py"
        :quotes ("_normalize_punctuation")
        :explanation "Step 4: punctuation"))

(fact normalizer-step-5 "stopwords"
    :evidence (evidence "normalizer.py"
        :quotes ("_normalize_stopwords")
        :explanation "Step 5: stopwords"))

(fact normalizer-step-6 "whitespace"
    :evidence (evidence "normalizer.py"
        :quotes ("_normalize_whitespace")
        :explanation "Step 6: whitespace"))

(fact normalizer-stateless true
    :evidence (evidence "normalizer.py"
        :quotes ("All functions are stateless")
        :explanation "Normalizer functions are pure"))

; =====================================================================
; Verifier API
; =====================================================================

(fact verifier-docstring "Verify if quotes appear in source documents using an inverted index."
    :evidence (evidence "verifier.py"
        :quotes ("Verify if quotes appear in source documents using an inverted index.")
        :explanation "QuoteVerifier class docstring"))

(fact verifier-default-threshold 0.7
    :evidence (evidence "verifier.py"
        :quotes ("confidence_threshold: float = 0.7")
        :explanation "Default confidence threshold"))

(fact verifier-default-case-sensitive false
    :evidence (evidence "verifier.py"
        :quotes ("case_sensitive: bool = False")
        :explanation "Case insensitive by default"))

(fact verifier-default-ignore-punctuation true
    :evidence (evidence "verifier.py"
        :quotes ("ignore_punctuation: bool = True")
        :explanation "Ignores punctuation by default"))

(fact verifier-default-remove-stopwords false
    :evidence (evidence "verifier.py"
        :quotes ("remove_stopwords: bool = False")
        :explanation "Stopword removal off by default"))

(fact verifier-confidence-return-shape "dict"
    :evidence (evidence "verifier.py"
        :quotes ("result[\"confidence\"] = {")
        :explanation "Confidence returned as nested dict"))

(fact verifier-confidence-has-score true
    :evidence (evidence "verifier.py"
        :quotes ("\"score\": confidence_info[\"score\"]")
        :explanation "Confidence dict has score"))

(fact verifier-confidence-has-level true
    :evidence (evidence "verifier.py"
        :quotes ("\"level\": confidence_info[\"level\"]")
        :explanation "Confidence dict has level"))

(fact verifier-position-key "original_position"
    :evidence (evidence "verifier.py"
        :quotes ("\"original_position\": original_position")
        :explanation "Key is original_position, not position"))

; =====================================================================
; Config — Thresholds
; =====================================================================

(fact high-confidence-threshold 0.9
    :evidence (evidence "config.py"
        :quotes ("high_confidence_threshold: float = 0.9")
        :explanation "High confidence >= 0.9"))

(fact medium-confidence-threshold 0.7
    :evidence (evidence "config.py"
        :quotes ("medium_confidence_threshold: float = 0.7")
        :explanation "Medium confidence >= 0.7"))

; =====================================================================
; Config — Match strategies
; =====================================================================

(fact match-strategy-exact "exact"
    :evidence (evidence "config.py"
        :quotes ("EXACT = \"exact\"")
        :explanation "Exact match via inverted index"))

(fact match-strategy-collapsed "collapsed"
    :evidence (evidence "config.py"
        :quotes ("COLLAPSED = \"collapsed\"")
        :explanation "Collapsed space match for PDF artifacts"))

; =====================================================================
; Config — Dangerous stopwords (sample)
; =====================================================================

(fact dangerous-includes-not true
    :evidence (evidence "config.py"
        :quotes ("\"not\"")
        :explanation "not is a dangerous stopword"))

(fact dangerous-includes-never true
    :evidence (evidence "config.py"
        :quotes ("\"never\"")
        :explanation "never is a dangerous stopword"))

(fact dangerous-includes-without true
    :evidence (evidence "config.py"
        :quotes ("\"without\"")
        :explanation "without is a dangerous stopword"))

; =====================================================================
; Axioms — invariants extracted from quote_verifier code
; =====================================================================

; 1. Penalty ordering: heavier semantic impact = heavier penalty
(axiom penalty-ordering (> ?heavy ?light)
    :evidence (evidence "config.py"
        :quotes ("\"dangerous_stopword_removal\": 0.31"
                 "\"stopword_removal\": 0.125"
                 "\"punctuation_removal\": 0.02"
                 "\"case_normalization\": 0.01"
                 "\"whitespace_normalization\": 0.001")
        :explanation "Penalties are ordered by semantic impact"))

; 2. Confidence level determination: score thresholds map to levels
(axiom confidence-level-rule (implies (> ?score ?threshold) (= ?level ?expected-level))
    :evidence (evidence "verifier.py"
        :quotes ("if score > self.config.high_confidence_threshold:"
                 "level = ConfidenceLevel.HIGH"
                 "elif score > self.config.medium_confidence_threshold:"
                 "level = ConfidenceLevel.MEDIUM"
                 "level = ConfidenceLevel.LOW")
        :explanation "Score > high → HIGH, > medium → MEDIUM, else LOW"))

; 3. Score starts at 1.0, penalties subtract
(axiom score-starts-at-one (= ?score (- 1.0 ?total-penalty))
    :evidence (evidence "verifier.py"
        :quotes ("score = 1.0"
                 "score -= t.penalty"
                 "score = max(0.0, min(1.0, score))")
        :explanation "Confidence score starts at 1.0, penalties subtract, clamped to [0,1]"))

; 4. Dangerous stopwords get full penalty, not diluted by word count
(axiom dangerous-not-diluted (implies ?is-dangerous (= ?penalty (* ?base-penalty ?count)))
    :evidence (evidence "verifier.py"
        :quotes ("# Dangerous stopwords — full penalty, not diluted by word count"
                 "penalty=self.config.get_penalty(\"dangerous_stopword_removal\") * len(dangerous_quote),")
        :explanation "Dangerous stopword penalty is base * count, not divided by word count"))

; 5. Regular stopwords ARE diluted by word count
(axiom regular-stopwords-diluted (implies (not ?is-dangerous) (= ?penalty (/ (* ?base-penalty ?count) ?word-count)))
    :evidence (evidence "verifier.py"
        :quotes ("self.config.get_penalty(\"stopword_removal\") * len(quote_only) / max(1, len(quote.split()))")
        :explanation "Regular stopword penalty is diluted by total word count"))

; 6. Empty quote → not verified
(axiom empty-quote-rejected (implies (not ?has-content) (= ?verified false))
    :evidence (evidence "verifier.py"
        :quotes ("if not quote.strip():"
                 "\"verified\": False,"
                 "\"reason\": \"Empty quote\",")
        :explanation "Pre-validation rejects empty quotes"))

; 7. All-stopwords safety: keep at least one word
(axiom all-stopwords-keep-one (implies ?all-are-stopwords (= ?kept 1))
    :evidence (evidence "normalizer.py"
        :quotes ("# All words are stopwords — keep at least one"
                 "words_to_keep = [words[0]]")
        :explanation "If all words are stopwords, first word is kept"))

; 8. Pipeline ordering is fixed: case → lists → hyphenation → punctuation → stopwords → whitespace
(axiom pipeline-order-fixed (= ?pipeline (?case ?lists ?hyphenation ?punctuation ?stopwords ?whitespace))
    :evidence (evidence "normalizer.py"
        :quotes ("processed, pos_map, trans = _normalize_case(text, config)"
                 "processed, pos_map, trans = _normalize_lists(processed, pos_map, config)"
                 "processed, pos_map, trans = _normalize_hyphenation(processed, pos_map, config)"
                 "processed, pos_map, trans = _normalize_punctuation(processed, pos_map, config)"
                 "processed, pos_map, trans = _normalize_stopwords(processed, pos_map, config)"
                 "processed, pos_map, trans = _normalize_whitespace(processed, pos_map, config)")
        :explanation "Pipeline runs 6 steps in fixed order"))

; 9. Collapsed match is fallback for exact
(axiom collapsed-is-fallback (implies (= ?exact-match false) ?try-collapsed)
    :evidence (evidence "verifier.py"
        :quotes ("# Use the inverted index (with space-collapsed fallback)")
        :explanation "Exact index match first, collapsed space match as fallback"))

; =====================================================================
; Layer 1: CONFIG — penalty values declared in config.py
; =====================================================================

(fact penalty-whitespace-config true
    :evidence (evidence "config.py"
        :quotes ("\"whitespace_normalization\": 0.001")
        :explanation "Whitespace penalty 0.001"))

(fact penalty-whitespace-trim-config true
    :evidence (evidence "config.py"
        :quotes ("\"whitespace_trimming\": 0.001")
        :explanation "Whitespace trimming penalty 0.001"))

(fact penalty-hyphenation-config true
    :evidence (evidence "config.py"
        :quotes ("\"hyphenation_normalization\": 0.005")
        :explanation "Hyphenation penalty 0.005"))

(fact penalty-case-config true
    :evidence (evidence "config.py"
        :quotes ("\"case_normalization\": 0.01")
        :explanation "Case penalty 0.01"))

(fact penalty-list-config true
    :evidence (evidence "config.py"
        :quotes ("\"list_normalization\": 0.01")
        :explanation "List penalty 0.01"))

(fact penalty-punctuation-config true
    :evidence (evidence "config.py"
        :quotes ("\"punctuation_removal\": 0.02")
        :explanation "Punctuation penalty 0.02"))

(fact penalty-collapsed-config true
    :evidence (evidence "config.py"
        :quotes ("\"collapsed_space_match\": 0.03")
        :explanation "Collapsed space penalty 0.03"))

(fact penalty-stopword-config true
    :evidence (evidence "config.py"
        :quotes ("\"stopword_removal\": 0.125")
        :explanation "Stopword penalty 0.125"))

(fact penalty-dangerous-config true
    :evidence (evidence "config.py"
        :quotes ("\"dangerous_stopword_removal\": 0.31")
        :explanation "Dangerous stopword penalty 0.31"))

; =====================================================================
; Layer 2: USAGE — penalty types used in normalizer/verifier code
; =====================================================================

(fact penalty-whitespace-usage true
    :evidence (evidence "normalizer.py"
        :quotes ("type=\"whitespace_normalization\",")
        :explanation "whitespace_normalization used in _normalize_whitespace"))

(fact penalty-whitespace-trim-usage true
    :evidence (evidence "normalizer.py"
        :quotes ("type=\"whitespace_trimming\",")
        :explanation "whitespace_trimming used in _normalize_whitespace"))

(fact penalty-hyphenation-usage true
    :evidence (evidence "normalizer.py"
        :quotes ("type=\"hyphenation_normalization\",")
        :explanation "hyphenation_normalization used in _normalize_hyphenation"))

(fact penalty-case-usage true
    :evidence (evidence "normalizer.py"
        :quotes ("type=\"case_normalization\",")
        :explanation "case_normalization used in _normalize_case"))

(fact penalty-list-usage true
    :evidence (evidence "normalizer.py"
        :quotes ("type=\"list_normalization\",")
        :explanation "list_normalization used in _normalize_lists"))

(fact penalty-punctuation-usage true
    :evidence (evidence "normalizer.py"
        :quotes ("type=\"punctuation_removal\",")
        :explanation "punctuation_removal used in _normalize_punctuation"))

(fact penalty-collapsed-usage true
    :evidence (evidence "verifier.py"
        :quotes ("type=\"collapsed_space_match\",")
        :explanation "collapsed_space_match used in verifier _find_quote_position"))

(fact penalty-stopword-usage true
    :evidence (evidence "normalizer.py"
        :quotes ("type=\"stopword_removal\",")
        :explanation "stopword_removal used in _normalize_stopwords"))

(fact penalty-dangerous-usage true
    :evidence (evidence "normalizer.py"
        :quotes ("type=\"dangerous_stopword_removal\",")
        :explanation "dangerous_stopword_removal used in _normalize_stopwords"))

; =====================================================================
; Per-layer penalty counts
; =====================================================================

(derive penalty-config-count
    (count-exists penalty-whitespace-config penalty-whitespace-trim-config
                  penalty-hyphenation-config penalty-case-config penalty-list-config
                  penalty-punctuation-config penalty-collapsed-config
                  penalty-stopword-config penalty-dangerous-config)
    :using (count-exists penalty-whitespace-config penalty-whitespace-trim-config
                         penalty-hyphenation-config penalty-case-config penalty-list-config
                         penalty-punctuation-config penalty-collapsed-config
                         penalty-stopword-config penalty-dangerous-config))

(derive penalty-usage-count
    (count-exists penalty-whitespace-usage penalty-whitespace-trim-usage
                  penalty-hyphenation-usage penalty-case-usage penalty-list-usage
                  penalty-punctuation-usage penalty-collapsed-usage
                  penalty-stopword-usage penalty-dangerous-usage)
    :using (count-exists penalty-whitespace-usage penalty-whitespace-trim-usage
                         penalty-hyphenation-usage penalty-case-usage penalty-list-usage
                         penalty-punctuation-usage penalty-collapsed-usage
                         penalty-stopword-usage penalty-dangerous-usage))

(diff penalty-config-vs-usage :replace penalty-config-count :with penalty-usage-count)

; =====================================================================
; Paired penalty count — types with BOTH config AND usage confirmed
; =====================================================================

(derive penalty-paired-count
    (count-exists (and penalty-whitespace-config penalty-whitespace-usage)
                  (and penalty-whitespace-trim-config penalty-whitespace-trim-usage)
                  (and penalty-hyphenation-config penalty-hyphenation-usage)
                  (and penalty-case-config penalty-case-usage)
                  (and penalty-list-config penalty-list-usage)
                  (and penalty-punctuation-config penalty-punctuation-usage)
                  (and penalty-collapsed-config penalty-collapsed-usage)
                  (and penalty-stopword-config penalty-stopword-usage)
                  (and penalty-dangerous-config penalty-dangerous-usage))
    :using (count-exists
            penalty-whitespace-config penalty-whitespace-usage
            penalty-whitespace-trim-config penalty-whitespace-trim-usage
            penalty-hyphenation-config penalty-hyphenation-usage
            penalty-case-config penalty-case-usage
            penalty-list-config penalty-list-usage
            penalty-punctuation-config penalty-punctuation-usage
            penalty-collapsed-config penalty-collapsed-usage
            penalty-stopword-config penalty-stopword-usage
            penalty-dangerous-config penalty-dangerous-usage))

(diff paired-vs-config :replace penalty-paired-count :with penalty-config-count)
(diff paired-vs-usage :replace penalty-paired-count :with penalty-usage-count)

; =====================================================================
; Penalty ordering — derives + diffs
; =====================================================================

; Ordering derives using actual config values
(fact penalty-whitespace-value 0.001
    :evidence (evidence "config.py"
        :quotes ("\"whitespace_normalization\": 0.001")
        :explanation "Whitespace penalty value"))

(fact penalty-case-value 0.01
    :evidence (evidence "config.py"
        :quotes ("\"case_normalization\": 0.01")
        :explanation "Case penalty value"))

(fact penalty-punctuation-value 0.02
    :evidence (evidence "config.py"
        :quotes ("\"punctuation_removal\": 0.02")
        :explanation "Punctuation penalty value"))

(fact penalty-stopword-value 0.125
    :evidence (evidence "config.py"
        :quotes ("\"stopword_removal\": 0.125")
        :explanation "Stopword penalty value"))

(fact penalty-dangerous-value 0.31
    :evidence (evidence "config.py"
        :quotes ("\"dangerous_stopword_removal\": 0.31")
        :explanation "Dangerous stopword penalty value"))

; Ordering derives — each proves one step via penalty-ordering axiom with :bind
(derive whitespace-lt-case penalty-ordering
    :bind ((?heavy penalty-case-value) (?light penalty-whitespace-value))
    :using (penalty-ordering penalty-case-value penalty-whitespace-value))

(derive case-lt-punctuation penalty-ordering
    :bind ((?heavy penalty-punctuation-value) (?light penalty-case-value))
    :using (penalty-ordering penalty-punctuation-value penalty-case-value))

(derive punctuation-lt-stopword penalty-ordering
    :bind ((?heavy penalty-stopword-value) (?light penalty-punctuation-value))
    :using (penalty-ordering penalty-stopword-value penalty-punctuation-value))

(derive stopword-lt-dangerous penalty-ordering
    :bind ((?heavy penalty-dangerous-value) (?light penalty-stopword-value))
    :using (penalty-ordering penalty-dangerous-value penalty-stopword-value))

; Count of ordering invariants that hold — should be 4
(derive ordering-invariants-count
    (count-exists whitespace-lt-case case-lt-punctuation
                  punctuation-lt-stopword stopword-lt-dangerous)
    :using (count-exists whitespace-lt-case case-lt-punctuation
                         punctuation-lt-stopword stopword-lt-dangerous))

; 5 penalty values used in ordering, 4 ordering steps between them
(derive ordering-values-count
    (count-exists penalty-whitespace-value penalty-case-value
                  penalty-punctuation-value penalty-stopword-value penalty-dangerous-value)
    :using (count-exists penalty-whitespace-value penalty-case-value
                         penalty-punctuation-value penalty-stopword-value penalty-dangerous-value))

(diff ordering-invariants-vs-values :replace ordering-invariants-count :with ordering-values-count)

; =====================================================================
; Normalizer pipeline counts + diffs
; =====================================================================

; pipeline-order-fixed axiom claims fixed order; steps prove each exists
(derive normalizer-steps-doc-count
    (count-exists normalizer-step-1 normalizer-step-2 normalizer-step-3
                  normalizer-step-4 normalizer-step-5 normalizer-step-6)
    :using (count-exists normalizer-step-1 normalizer-step-2 normalizer-step-3
                         normalizer-step-4 normalizer-step-5 normalizer-step-6))

; Bind pipeline-order-fixed: the 6 steps prove the pipeline has the claimed order
(derive bound-pipeline-order pipeline-order-fixed
    :bind ((?pipeline normalizer-step-count)
           (?case normalizer-step-1) (?lists normalizer-step-2)
           (?hyphenation normalizer-step-3) (?punctuation normalizer-step-4)
           (?stopwords normalizer-step-5) (?whitespace normalizer-step-6))
    :using (pipeline-order-fixed normalizer-step-count
            normalizer-step-1 normalizer-step-2 normalizer-step-3
            normalizer-step-4 normalizer-step-5 normalizer-step-6))

(diff normalizer-pipeline-coverage
    :replace normalizer-steps-doc-count
    :with normalizer-step-count)

; Stateless + steps = complete normalizer characterization
(derive normalizer-features-count
    (count-exists normalizer-stateless normalizer-step-count
                  normalizer-step-1 normalizer-step-2 normalizer-step-3
                  normalizer-step-4 normalizer-step-5 normalizer-step-6)
    :using (count-exists normalizer-stateless normalizer-step-count
                         normalizer-step-1 normalizer-step-2 normalizer-step-3
                         normalizer-step-4 normalizer-step-5 normalizer-step-6))

(diff normalizer-features-vs-steps :replace normalizer-features-count :with normalizer-steps-doc-count)

; =====================================================================
; Threshold consistency
; =====================================================================

; medium_confidence_threshold == confidence_threshold (both 0.7)
(derive medium-equals-verification-threshold
    (= medium-confidence-threshold verifier-default-threshold)
    :using (medium-confidence-threshold verifier-default-threshold))

; Bind confidence-level-rule: medium threshold determines MEDIUM level
(derive bound-confidence-level confidence-level-rule
    :bind ((?score verifier-default-threshold) (?threshold medium-confidence-threshold)
           (?level verifier-confidence-has-level) (?expected-level medium-confidence-threshold))
    :using (confidence-level-rule verifier-default-threshold medium-confidence-threshold
            verifier-confidence-has-level))

(derive threshold-count
    (count-exists high-confidence-threshold medium-confidence-threshold verifier-default-threshold)
    :using (count-exists high-confidence-threshold medium-confidence-threshold verifier-default-threshold))

(diff medium-vs-default-threshold :replace medium-confidence-threshold :with verifier-default-threshold)

; =====================================================================
; Verifier API — counts + diffs
; =====================================================================

(derive verifier-defaults-count
    (count-exists verifier-default-case-sensitive verifier-default-ignore-punctuation
                  verifier-default-remove-stopwords verifier-default-threshold)
    :using (count-exists verifier-default-case-sensitive verifier-default-ignore-punctuation
                         verifier-default-remove-stopwords verifier-default-threshold))

; Confidence computation features
(derive verifier-confidence-count
    (count-exists verifier-confidence-return-shape verifier-confidence-has-score
                  verifier-confidence-has-level verifier-position-key)
    :using (count-exists verifier-confidence-return-shape verifier-confidence-has-score
                         verifier-confidence-has-level verifier-position-key))

(diff verifier-defaults-vs-confidence :replace verifier-defaults-count :with verifier-confidence-count)

; =====================================================================
; Match strategies + dangerous stopwords — counts + diffs
; =====================================================================

; Match strategy count
(derive match-strategies-count
    (count-exists match-strategy-exact match-strategy-collapsed)
    :using (count-exists match-strategy-exact match-strategy-collapsed))

; Bind collapsed-is-fallback: exact match first, collapsed as fallback
(derive bound-collapsed-fallback collapsed-is-fallback
    :bind ((?exact-match match-strategy-exact) (?try-collapsed match-strategy-collapsed))
    :using (collapsed-is-fallback match-strategy-exact match-strategy-collapsed))

(derive dangerous-stopwords-count
    (count-exists dangerous-includes-not dangerous-includes-never dangerous-includes-without)
    :using (count-exists dangerous-includes-not dangerous-includes-never dangerous-includes-without))

(diff strategies-vs-dangerous :replace match-strategies-count :with dangerous-stopwords-count)
(diff threshold-vs-strategies :replace threshold-count :with match-strategies-count)

; =====================================================================
; Axiom impl backing — proving axiom claims hold in code
; =====================================================================

(fact score-init-impl true
    :evidence (evidence "verifier.py"
        :quotes ("score = 1.0
        for t in relevant:
            score -= t.penalty
        score = max(0.0, min(1.0, score))")
        :explanation "Score starts at 1.0, each penalty subtracts, clamped to [0,1]"))

(fact dangerous-full-penalty-impl true
    :evidence (evidence "verifier.py"
        :quotes ("# Dangerous stopwords — full penalty, not diluted by word count
        dangerous_quote = {w for w in quote_only if w.lower() in self.config.dangerous_stopwords}
        dangerous_matched = {w for w in matched_only if w.lower() in self.config.dangerous_stopwords}

        if dangerous_quote:
            relevant.append(
                NormalizationTransformation(
                    type=\"dangerous_stopword_removal_difference\",
                    description=f\"Dangerous words removed from quote but not source: {', '.join(dangerous_quote)}\",
                    penalty=self.config.get_penalty(\"dangerous_stopword_removal\") * len(dangerous_quote),
                )
            )")
        :explanation "Dangerous stopword penalty is base * count with no word-count division"))

(fact regular-diluted-penalty-impl true
    :evidence (evidence "verifier.py"
        :quotes ("penalty=(
                        self.config.get_penalty(\"stopword_removal\") * len(quote_only) / max(1, len(quote.split()))
                    ),")
        :explanation "Regular stopword penalty is diluted by total word count"))

(fact empty-rejected-impl true
    :evidence (evidence "verifier.py"
        :quotes ("if not quote.strip():
            return {
                \"quote\": quote,
                \"verified\": False,
                \"original_position\": -1,
                \"normalized_position\": -1,
                \"reason\": \"Empty quote\",
                \"length\": 0,
            }, False")
        :explanation "Empty quotes return verified=False immediately"))

(fact keep-one-stopword-impl true
    :evidence (evidence "normalizer.py"
        :quotes ("all_stopwords = all(w.lower() in config.stopwords for w in words)
    if all_stopwords:
        words_to_keep = [words[0]]
        words_to_remove = words[1:]")
        :explanation "When all words are stopwords, keeps first word, removes rest"))

; Bind axioms to their implementation proofs
(derive bound-score-starts score-starts-at-one
    :bind ((?score verifier-confidence-has-score) (?total-penalty score-init-impl))
    :using (score-starts-at-one verifier-confidence-has-score score-init-impl))

(derive bound-dangerous-not-diluted dangerous-not-diluted
    :bind ((?is-dangerous dangerous-includes-not) (?penalty dangerous-full-penalty-impl)
           (?base-penalty penalty-dangerous-config) (?count dangerous-full-penalty-impl))
    :using (dangerous-not-diluted dangerous-includes-not dangerous-full-penalty-impl penalty-dangerous-config))

(derive bound-regular-diluted regular-stopwords-diluted
    :bind ((?is-dangerous penalty-stopword-config) (?penalty regular-diluted-penalty-impl)
           (?base-penalty penalty-stopword-config) (?count regular-diluted-penalty-impl) (?word-count regular-diluted-penalty-impl))
    :using (regular-stopwords-diluted penalty-stopword-config regular-diluted-penalty-impl))

(derive bound-empty-rejected empty-quote-rejected
    :bind ((?has-content empty-rejected-impl) (?verified empty-rejected-impl))
    :using (empty-quote-rejected empty-rejected-impl))

(derive bound-all-stopwords-keep all-stopwords-keep-one
    :bind ((?all-are-stopwords keep-one-stopword-impl) (?kept keep-one-stopword-impl))
    :using (all-stopwords-keep-one keep-one-stopword-impl))

; Count impl facts that back axiom claims
(derive axiom-impl-count
    (count-exists score-init-impl dangerous-full-penalty-impl
                  regular-diluted-penalty-impl empty-rejected-impl
                  keep-one-stopword-impl)
    :using (count-exists
            bound-score-starts bound-dangerous-not-diluted bound-regular-diluted
            bound-empty-rejected bound-all-stopwords-keep
            score-init-impl dangerous-full-penalty-impl
            regular-diluted-penalty-impl empty-rejected-impl
            keep-one-stopword-impl))

(diff axiom-impl-vs-penalty-config :replace axiom-impl-count :with penalty-config-count)

; =====================================================================
; Cross-check: verifier API features vs penalty config
; =====================================================================

(derive verifier-all-features-count
    (count-exists verifier-docstring verifier-default-threshold
                  verifier-default-case-sensitive verifier-default-ignore-punctuation
                  verifier-default-remove-stopwords verifier-confidence-return-shape
                  verifier-confidence-has-score verifier-confidence-has-level
                  verifier-position-key)
    :using (count-exists verifier-docstring verifier-default-threshold
                         verifier-default-case-sensitive verifier-default-ignore-punctuation
                         verifier-default-remove-stopwords verifier-confidence-return-shape
                         verifier-confidence-has-score verifier-confidence-has-level
                         verifier-position-key))

(diff verifier-features-vs-penalty-config :replace verifier-all-features-count :with penalty-config-count)

; medium-equals-verification-threshold proves thresholds match;
; diff it against the boolean true to surface if it ever breaks
(diff threshold-equality-holds :replace medium-equals-verification-threshold :with verifier-default-ignore-punctuation)
