        :quotes ("\"level\": confidence_info[\"level\"]")
        :explanation "Confidence sub-dict includes level"))

(fact result-impl-position-key true
    :evidence (evidence "verifier.py"
        :quotes ("\"original_position\": original_position,")
        :explanation "Result uses original_position key"))

; Per-layer counts
(derive result-api-count
    (count-exists verifier-confidence-return-shape verifier-confidence-has-score
                  verifier-confidence-has-level verifier-position-key)
    :using (count-exists verifier-confidence-return-shape verifier-confidence-has-score
                         verifier-confidence-has-level verifier-position-key))

(derive result-impl-count
    (count-exists result-impl-confidence-dict result-impl-has-score
                  result-impl-has-level result-impl-position-key)
    :using (count-exists result-impl-confidence-dict result-impl-has-score
                         result-impl-has-level result-impl-position-key))

(derive doc-result-count
