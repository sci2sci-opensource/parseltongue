    :evidence (evidence "config.py"
        :quotes ("NONE — no match found, score is 0.0")
        :explanation "ConfidenceLevel docstring documents NONE level"))

; Layer 1: ENUM — confidence levels declared in config.py
(fact level-enum-high true
