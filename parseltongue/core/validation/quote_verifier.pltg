        :quotes ("HIGH = \"high\"")
        :explanation "ConfidenceLevel.HIGH enum value"))

(fact level-enum-medium true
    :evidence (evidence "config.py"
        :quotes ("MEDIUM = \"medium\"")
        :explanation "ConfidenceLevel.MEDIUM enum value"))

(fact level-enum-low true
    :evidence (evidence "config.py"
        :quotes ("LOW = \"low\"")
        :explanation "ConfidenceLevel.LOW enum value"))

(fact level-enum-none true
    :evidence (evidence "config.py"
        :quotes ("NONE = \"none\"")
        :explanation "ConfidenceLevel.NONE enum value"))

; Layer 2: USAGE — where each level is assigned in verifier code
(fact level-usage-high true
    :evidence (evidence "verifier.py"
        :quotes ("if score > self.config.high_confidence_threshold:\n            level = ConfidenceLevel.HIGH")
        :explanation "HIGH assigned when score exceeds high threshold"))

(fact level-usage-medium true
    :evidence (evidence "verifier.py"
        :quotes ("elif score > self.config.medium_confidence_threshold:\n            level = ConfidenceLevel.MEDIUM")
        :explanation "MEDIUM assigned when score exceeds medium threshold"))

(fact level-usage-low true
    :evidence (evidence "verifier.py"
        :quotes ("else:\n            level = ConfidenceLevel.LOW")
        :explanation "LOW assigned as default when below both thresholds"))

(fact level-usage-none true
    :evidence (evidence "verifier.py"
        :quotes ("confidence_info = {\n            \"score\": 0.0,\n            \"level\": ConfidenceLevel.NONE,\n            \"transformations\": [],\n        }")
        :explanation "NONE used as initial value before any match is found"))

; Per-layer counts
(derive level-enum-count
    (count-exists level-enum-high level-enum-medium level-enum-low level-enum-none)
    :using (count-exists level-enum-high level-enum-medium level-enum-low level-enum-none))

(derive level-usage-count
    (count-exists level-usage-high level-usage-medium level-usage-low level-usage-none)
    :using (count-exists level-usage-high level-usage-medium level-usage-low level-usage-none))

(derive doc-level-count
    (count-exists doc-level-high doc-level-medium doc-level-low doc-level-none)
    :using (count-exists doc-level-high doc-level-medium doc-level-low doc-level-none))

(derive level-paired-count
    (count-exists (and doc-level-high level-enum-high level-usage-high)
                  (and doc-level-medium level-enum-medium level-usage-medium)
                  (and doc-level-low level-enum-low level-usage-low)
                  (and doc-level-none level-enum-none level-usage-none))
    :using (count-exists
            doc-level-high level-enum-high level-usage-high
            doc-level-medium level-enum-medium level-usage-medium
            doc-level-low level-enum-low level-usage-low
            doc-level-none level-enum-none level-usage-none))

(diff level-paired-vs-doc :replace level-paired-count :with doc-level-count)
(diff level-paired-vs-enum :replace level-paired-count :with level-enum-count)
(diff level-paired-vs-usage :replace level-paired-count :with level-usage-count)

