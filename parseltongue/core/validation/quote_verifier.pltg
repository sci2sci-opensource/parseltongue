        :explanation "Docstring documents confidence as nested dict"))
(fact doc-result-has-score true
    :evidence (evidence "verifier.py"
        :quotes ("confidence — nested dict with score (float) and level (ConfidenceLevel)")
        :explanation "Docstring documents score in confidence dict"))
(fact doc-result-has-level true
    :evidence (evidence "verifier.py"
        :quotes ("confidence — nested dict with score (float) and level (ConfidenceLevel)")
        :explanation "Docstring documents level in confidence dict"))
(fact doc-result-position-key true
    :evidence (evidence "verifier.py"
        :quotes ("original_position — character offset in original document, or -1")
        :explanation "Docstring documents original_position key"))

; Layer 1: API — already defined above:
;   verifier-confidence-return-shape, verifier-confidence-has-score,
;   verifier-confidence-has-level, verifier-position-key

; Layer 2: IMPL — code that constructs the result dict
(fact result-impl-confidence-dict true
    :evidence (evidence "verifier.py"
        :quotes ("result[\"confidence\"] = {\n            \"score\": confidence_info[\"score\"],\n            \"level\": confidence_info[\"level\"],\n        }")
        :explanation "Result dict constructs confidence sub-dict"))

(fact result-impl-has-score true
    :evidence (evidence "verifier.py"
        :quotes ("\"score\": confidence_info[\"score\"]")
        :explanation "Confidence sub-dict includes score"))

(fact result-impl-has-level true
