                  doc-result-has-level doc-result-position-key)
    :using (count-exists doc-result-confidence-dict doc-result-has-score
                         doc-result-has-level doc-result-position-key))

(derive result-paired-count
    (count-exists (and doc-result-confidence-dict verifier-confidence-return-shape result-impl-confidence-dict)
                  (and doc-result-has-score verifier-confidence-has-score result-impl-has-score)
                  (and doc-result-has-level verifier-confidence-has-level result-impl-has-level)
                  (and doc-result-position-key verifier-position-key result-impl-position-key))
    :using (count-exists
            doc-result-confidence-dict verifier-confidence-return-shape result-impl-confidence-dict
            doc-result-has-score verifier-confidence-has-score result-impl-has-score
            doc-result-has-level verifier-confidence-has-level result-impl-has-level
            doc-result-position-key verifier-position-key result-impl-position-key))

(diff result-paired-vs-doc :replace result-paired-count :with doc-result-count)
(diff result-paired-vs-api :replace result-paired-count :with result-api-count)
