; self_test.pltg — The system tests itself, then proves it cannot prove its own consistency.
;
; Uses dangerously-eval to run the pytest suite (excluding the consistency test)
; from within the formal system. Then cites Gödel and Turing from our own README
; to axiomatically assert that self-consistency is unprovable.

(import (quote counting))
(defterm count-exists counting.count-exists :origin "import")

(load-document "README" "../README.md")

; =====================================================================
; Phase 1: Execute the test suite from within the system
; =====================================================================

(print "")
(print "========================================")
(print "  Self-Test Execution Verification")
(print "========================================")

; Run all tests except the consistency meta-test
; Uses _ctx (loader context) to resolve paths relative to this file
(dangerously-eval "import subprocess, os; test_dir = os.path.normpath(os.path.join(_ctx.current_dir, '..', 'tests')); ignore = os.path.join(test_dir, 'test_parseltongue_core_consistency.py'); root = os.path.normpath(os.path.join(_ctx.current_dir, '..', '..', '..')); r = subprocess.run(['python', '-m', 'pytest', test_dir, '-q', '--ignore=' + ignore, '--tb=no'], capture_output=True, text=True, timeout=120, cwd=root); system.engine.set_fact('test-suite-result', r.returncode == 0, 'pytest suite execution via dangerously-eval')")

(print "  Test suite passed:" test-suite-result)

; =====================================================================
; Phase 2: The incompleteness axiom
; =====================================================================

; Gödel: a sufficiently powerful system's consistency is unprovable from within
(axiom goedel-incompleteness
    (implies ?sufficiently-powerful ?consistency-unprovable)
    :evidence (evidence "README"
        :quotes ("This is not a proof of consistency — Godel tells us that's impossible for sufficiently strong systems — but a practical detection mechanism that catches real-world contradictions between documents, data sources, and reported figures.")
        :explanation "README acknowledges Gödel's incompleteness: consistency for sufficiently strong system is unprovable"))

; Turing: each extension unlocks new derivations but cannot escape the limitation
(axiom turing-ordinal-extension
    (implies ?extends-by-ordinals ?transcends-single-system)
    :evidence (evidence "README"
        :quotes ("This is the core idea from Turing's *Systems of Logic Based on Ordinals* (1939): a sequence of logics, each extending the previous one by adding new axioms, can transcend the limitations of any single formal system.")
        :explanation "README cites Turing's ordinal logics — extensions transcend but each system remains limited"))

; The system is sufficiently powerful (it runs its own tests and they pass)
(defterm system-is-powerful test-suite-result
    :origin "system executes its own test suite — sufficiently powerful")

; Therefore: the system cannot prove its own consistency
(derive system-cannot-prove-own-consistency goedel-incompleteness
    :bind ((?sufficiently-powerful system-is-powerful) (?consistency-unprovable system-is-powerful))
    :using (goedel-incompleteness system-is-powerful))

; =====================================================================
; Phase 3: Ordinal extension — reconstructed from loader.pltg AST
; =====================================================================

(load-document "loader.pltg" "loader.pltg")

; --- Ordinal 1: axiom circular-import-detection and its chain ---

(fact axiom-1-exists true
    :evidence (evidence "loader.pltg"
        :quotes ("(axiom circular-import-detection")
        :explanation "Ordinal 1: axiom circular-import-detection exists"))

(fact axiom-1-produces-theorem true
    :evidence (evidence "loader.pltg"
        :quotes ("(derive bound-circular-import circular-import-detection")
        :explanation "Axiom 1 enables theorem bound-circular-import via :bind"))

(fact axiom-1-chain-extends true
    :evidence (evidence "loader.pltg"
        :quotes ("(derive circular-detection-mechanism" "bound-circular-import)")
        :explanation "bound-circular-import in :using enables higher theorem circular-detection-mechanism"))

; --- Ordinal 2: axiom import-deduplication and its chain ---

(fact axiom-2-exists true
    :evidence (evidence "loader.pltg"
        :quotes ("(axiom import-deduplication")
        :explanation "Ordinal 2: axiom import-deduplication exists"))

(fact axiom-2-produces-theorem true
    :evidence (evidence "loader.pltg"
        :quotes ("(derive bound-import-dedup import-deduplication")
        :explanation "Axiom 2 enables theorem bound-import-dedup via :bind"))

(fact axiom-2-chain-extends true
    :evidence (evidence "loader.pltg"
        :quotes ("(derive import-dedup-mechanism" "bound-import-dedup)")
        :explanation "bound-import-dedup in :using enables higher theorem import-dedup-mechanism"))

; --- Upper theorem requires BOTH chains ---

(fact upper-theorem-requires-both true
    :evidence (evidence "loader.pltg"
        :quotes ("(derive safety-mechanism-count" "(count-exists circular-detection-mechanism import-dedup-mechanism run-on-entry-gating-mechanism)")
        :explanation "safety-mechanism-count is unprovable without both axiom chains — remove either and the count drops"))

; --- Turing instantiation ---
; Without at least 2 low-level axioms, the upper theorem is unreachable

(derive ordinals-enable-new-proofs turing-ordinal-extension
    :bind ((?extends-by-ordinals upper-theorem-requires-both)
           (?transcends-single-system upper-theorem-requires-both))
    :using (turing-ordinal-extension
            axiom-1-exists axiom-1-produces-theorem axiom-1-chain-extends
            axiom-2-exists axiom-2-produces-theorem axiom-2-chain-extends
            upper-theorem-requires-both))

(print "")
(print "  Gödel's incompleteness applies:" system-cannot-prove-own-consistency)
(print "  Ordinal extension exemplified:" ordinals-enable-new-proofs)
(print "  The system cannot prove its own consistency.")
(print "")
(print "========================================")

; =====================================================================
; The consistency check is in core.pltg, not here.
; This file proves WHY that's the right design:
; the system can test itself, but it cannot verify
; that its consistency check is itself consistent.
; =====================================================================
