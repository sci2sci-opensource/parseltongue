; --- 7. Demo examples ---

(derive readme-demo-examples-doc-count
    (count-exists readme-demo-apples readme-demo-revenue readme-demo-biomarkers)
    :using (count-exists counting.count-exists-base counting.count-exists-step
            readme-demo-apples readme-demo-revenue readme-demo-biomarkers))

(defterm readme-demo-examples-impl-count 3
    :evidence (evidence "README"
        :quotes ("Apples" "Revenue Reports" "Biomarkers")
        :explanation "3 demo examples in README"))

(diff readme-demo-examples-coverage
    :replace readme-demo-examples-doc-count
    :with readme-demo-examples-impl-count)

; --- 8. Loader effects in README ---

(derive readme-loader-effects-doc-count
    (count-exists readme-loader-import-effect readme-loader-run-on-entry-effect readme-loader-load-document-effect readme-loader-context-effect readme-loader-print-effect readme-loader-load-pltg)
    :using (count-exists counting.count-exists-base counting.count-exists-step
            readme-loader-import-effect readme-loader-run-on-entry-effect readme-loader-load-document-effect readme-loader-context-effect readme-loader-print-effect readme-loader-load-pltg))

(defterm readme-loader-effects-impl-count 6
    :evidence (evidence "README"
        :quotes ("(import (quote module.name))" "(run-on-entry (quote (directive ...)))" "(load-document \"name\" \"relative/path.txt\")" "(context :file)" "(print \"label\" value ...)" "load_pltg")
        :explanation "6 loader effect features in README"))

(diff readme-loader-effects-coverage
    :replace readme-loader-effects-doc-count
    :with readme-loader-effects-impl-count)

; --- 9. Loader architecture ---

(derive readme-loader-arch-doc-count
    (count-exists readme-loader-context-onion readme-documents-consistency-modes)
    :using (count-exists counting.count-exists-base counting.count-exists-step
            readme-loader-context-onion readme-documents-consistency-modes))

(defterm readme-loader-arch-impl-count 2
    :evidence (evidence "README"
        :quotes ("immutable ModuleContext following an onion model" "(consistency :raise)" "(consistency :bool)" "(consistency :report)")
        :explanation "2 loader architecture features in README"))

(diff readme-loader-arch-coverage
    :replace readme-loader-arch-doc-count
    :with readme-loader-arch-impl-count)
