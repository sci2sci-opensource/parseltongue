; =====================================================================
; Axioms — universal rules stated in the README
; =====================================================================

; Axiom 1: Every fact must cite a verbatim quote
(axiom every-fact-cites-quote
    (implies ?is-fact ?must-cite-quote)
    :evidence (evidence "README"
        :quotes ("Every extracted fact must cite a verbatim quote.")
        :explanation "Universal rule: facts require quote citation"))

; Axiom 2: Fabrication taints propagate through derivation chains
(axiom fabrication-propagates
    (implies ?source-unverified ?derivation-tainted)
    :evidence (evidence "README"
        :quotes ("If any source has unverified evidence, the derivation inherits the fabrication taint")
        :explanation "Universal rule: fabrication propagates via derivation"))

; Axiom 4: Axioms must have ?-variables
(axiom axioms-require-variables
    (implies ?is-axiom ?has-question-var)
    :evidence (evidence "README"
        :quotes ("a parametric rule with `?`-variables. Ground statements (no `?`-variables) are rejected; use `fact` for values or `derive` for provable claims.")
        :explanation "Universal rule: axioms require at least one ?-variable"))

; Axiom 5: Diffs detect contradictions via independent paths
(axiom diffs-detect-contradictions
    (implies (and ?path-a ?path-b) ?divergence-detectable)
    :evidence (evidence "README"
        :quotes ("register two independent values for the same quantity, and the engine replays all dependent computations under both assumptions. Where results diverge, something is wrong")
        :explanation "Universal rule: diffs expose contradictions between independent paths"))

; Axiom 6: Evidence grounding inverts classical axiomatics
;
; An axiom's epistemic status is indeterminate until observed.
; Classical: observed as hypothesised → collapses to unknown (trusted, unwitnessed).
; Parseltongue: observed as witnessed → collapses to exemplifiable (grounded in evidence).
; The inversion is a change of observation on the same superposed claim.

(defterm axiom-status (epistemics.superpose epistemics.exemplifiable epistemics.hallucinated epistemics.unknown)
    :origin "any axiom starts in epistemic superposition — its status depends on observation")

(defterm classical-axiom-status (epistemics.collapse (strict axiom-status) epistemics.hypothesised)
    :evidence (evidence "README"
        :quotes ("In a standard formal system (Peano arithmetic, ZFC, etc.), axioms are taken as given. You declare them and reason from there. The system's strength is measured by its proof-theoretic ordinal — how far its induction principles can reach. But the axioms themselves are unjustified within the system; you simply trust them.")
        :explanation "Classical axioms are hypothesised — collapse(superpose, hypothesised) → unknown"))

(defterm parseltongue-axiom-status (epistemics.collapse (strict axiom-status) epistemics.witnessed)
    :evidence (evidence "README"
        :quotes ("Parseltongue inverts this. Every axiom, every fact, every primitive term must cite its justification — a verbatim quote from a source document.")
        :explanation "Parseltongue axioms are witnessed — collapse(superpose, witnessed) → exemplifiable"))

(fact evidence-is-departure true
    :evidence (evidence "README"
        :quotes ("Parseltongue is a formal system in the classical sense — primitives, axioms, inference rules — but with one crucial departure from traditional mathematical logic: **the axiomatic basis is not assumed, it is grounded in evidence.**")
        :explanation "README explicitly calls evidence grounding a crucial departure"))

(axiom evidence-inverts-classical-plan
    (implies (= ?classical epistemics.unknown)
             (= ?parseltongue epistemics.exemplifiable))
    :evidence (evidence "README"
        :quotes ("Parseltongue inverts this. Every axiom, every fact, every primitive term must cite its justification — a verbatim quote from a source document." "the axiomatic basis is not assumed, it is grounded in evidence." "But the axioms themselves are unjustified within the system; you simply trust them.")
        :explanation "Evidence inverts epistemic outcome: unknown (classical) → exemplifiable (parseltongue)"))

(derive evidence-inversion-theorem evidence-inverts-classical-plan
    :bind ((?classical classical-axiom-status) (?parseltongue parseltongue-axiom-status))
    :using (evidence-inverts-classical-plan classical-axiom-status parseltongue-axiom-status))

(derive parseltongue-makes-axioms-exemplifiable
    (and evidence-is-departure (= parseltongue-axiom-status epistemics.exemplifiable))
    :using (evidence-is-departure parseltongue-axiom-status))

; Axiom 7: System extension unlocks new derivations
(axiom extension-unlocks-derivations-plan
    (implies ?new-axiom-added ?new-derivations-reachable)
    :evidence (evidence "README"
        :quotes ("Each new ordinal" "expands what can be proved" "each derivation is a new opportunity for the engine to catch a contradiction")
        :explanation "Adding axioms extends what can be derived and checked"))

