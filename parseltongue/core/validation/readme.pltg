; readme.pltg — Claims extracted from core/README.md

(load-document "README" "../README.md")
(import (quote counting))
(defterm count-exists counting.count-exists :origin "import")

; =====================================================================
; Top-level claims
; =====================================================================

(fact readme-title "Parseltongue Core"
    :evidence (evidence "README"
        :quotes ("# Parseltongue Core")
        :explanation "Module title"))

(fact readme-tagline "The formal language engine. No LLM dependency"
    :evidence (evidence "README"
        :quotes ("The formal language engine. No LLM dependency — pure logic, evidence grounding, consistency checking, and self-introspection.")
        :explanation "Core tagline"))

; =====================================================================
; Rationale section — the "why"
; =====================================================================

(fact readme-rationale-llms-hallucinate true
    :evidence (evidence "README"
        :quotes ("LLMs hallucinate. They produce fluent, confident text that may have no basis in the source material.")
        :explanation "README states the problem Parseltongue solves"))

(fact readme-rationale-encode-as-logic true
    :evidence (evidence "README"
        :quotes ("we ask it to encode each of the documents as a **logic system**")
        :explanation "README describes the approach — encode docs as logic"))

(fact readme-rationale-facts-cite-quotes true
    :evidence (evidence "README"
        :quotes ("Every extracted fact must cite a verbatim quote. Every conclusion must derive from stated premises. And every derivation is checked.")
        :explanation "README states the three invariants of the system"))

(fact readme-rationale-hallucination-detection true
    :evidence (evidence "README"
        :quotes ("Hallucination detection." "Every claim traces back to a quote in a source document. If the LLM fabricates a fact, the quote verification fails")
        :explanation "README claims hallucination detection via quote verification"))

(fact readme-rationale-fabrication-contaminates true
    :evidence (evidence "README"
        :quotes ("that failure propagates automatically to every conclusion that depends on it. You don't just catch the lie; you see everything it contaminates.")
        :explanation "README claims fabrication contamination propagation"))

(fact readme-rationale-cross-doc-consistency true
    :evidence (evidence "README"
        :quotes ("Cross-document consistency checking." "we validate if the ground truth is trustable itself.")
        :explanation "README claims cross-document consistency checking"))

(fact readme-rationale-independent-paths true
    :evidence (evidence "README"
        :quotes ("compute the same value via independent paths" "When these paths disagree, the system flags a divergence")
        :explanation "README describes independent computation paths as the diff mechanism"))

; =====================================================================
; Mathematical Aside — formal foundations
; =====================================================================

(fact readme-math-evidence-grounded true
    :evidence (evidence "README"
        :quotes ("the axiomatic basis is not assumed, it is grounded in evidence")
        :explanation "README states core departure from classical formal systems"))

(fact readme-math-ordinals-via-extension true
    :evidence (evidence "README"
        :quotes ("The system grows by extension." "Each layer of extension builds on everything below it. This is the ordinal hierarchy")
        :explanation "README describes system growth as ordinal hierarchy"))

(fact readme-math-each-ordinal-expands true
    :evidence (evidence "README"
        :quotes ("Each new ordinal" "expands what can be proved" "Each extension unlocks derivations that were previously unreachable")
        :explanation "README claims each extension unlocks new derivations"))

(fact readme-math-diffs-as-consistency true
    :evidence (evidence "README"
        :quotes ("Diffs as axiom consistency checks." "register two independent computation paths for the same quantity, and the system replays all dependent evaluations under both assumptions")
        :explanation "README describes diffs as axiom consistency checks"))

(fact readme-math-godel-limitation true
    :evidence (evidence "README"
        :quotes ("This is not a proof of consistency" "Godel tells us that's impossible for sufficiently strong systems" "but a practical detection mechanism")
        :explanation "README acknowledges Godel limitation and positions diffs as practical detection"))

(fact readme-math-fabrication-propagation-mechanism true
    :evidence (evidence "README"
        :quotes ("When evidence fails verification (a quote not found in its cited document), the taint propagates through the language." "Every theorem derived from a fabricated source inherits the flag")
        :explanation "README describes fabrication propagation mechanism in detail"))

(fact readme-math-turing-reference true
    :evidence (evidence "README"
        :quotes ("This is the core idea from Turing's" "Systems of Logic Based on Ordinals" "a sequence of logics, each extending the previous one by adding new axioms, can transcend the limitations of any single formal system")
        :explanation "README grounds ordinal approach in Turing 1939"))

; =====================================================================
; Axioms — universal rules stated in the README
; =====================================================================

; Axiom 1: Every fact must cite a verbatim quote
(axiom every-fact-cites-quote
    (implies ?is-fact ?must-cite-quote)
    :evidence (evidence "README"
        :quotes ("Every extracted fact must cite a verbatim quote.")
        :explanation "Universal rule: facts require quote citation"))

; Axiom 2: Every conclusion must derive from stated premises
(axiom every-conclusion-derives
    (implies ?is-conclusion ?derives-from-premises)
    :evidence (evidence "README"
        :quotes ("Every conclusion must derive from stated premises.")
        :explanation "Universal rule: conclusions require derivation"))

; Axiom 3: Fabrication taints propagate through derivation chains
(axiom fabrication-propagates
    (implies ?source-unverified ?derivation-tainted)
    :evidence (evidence "README"
        :quotes ("If any source has unverified evidence, the derivation inherits the fabrication taint")
        :explanation "Universal rule: fabrication propagates via derivation"))

; Axiom 4: Axioms must have ?-variables
(axiom axioms-require-variables
    (implies ?is-axiom ?has-question-var)
    :evidence (evidence "README"
        :quotes ("Axioms MUST contain at least one ?-variable" "Ground statements (no ?-variables) are rejected")
        :explanation "Universal rule: axioms require at least one ?-variable"))

; Axiom 5: Diffs detect contradictions via independent paths
(axiom diffs-detect-contradictions
    (implies (and ?path-a ?path-b) ?divergence-detectable)
    :evidence (evidence "README"
        :quotes ("register two independent values for the same quantity, and the engine replays all dependent computations under both assumptions. Where results diverge, something is wrong")
        :explanation "Universal rule: diffs expose contradictions between independent paths"))

; Axiom 6: Evidence grounding inverts classical axiomatics
(axiom evidence-inverts-classical
    (implies ?has-evidence (not ?assumed-without-justification))
    :evidence (evidence "README"
        :quotes ("Parseltongue inverts this. Every axiom, every fact, every primitive term must cite its justification")
        :explanation "Core departure: axioms are justified, not assumed"))

; Axiom 7: System extension unlocks new derivations
(axiom extension-unlocks-derivations
    (implies ?new-axiom-added ?new-derivations-reachable)
    :evidence (evidence "README"
        :quotes ("Each new ordinal" "expands what can be proved" "each derivation is a new opportunity for the engine to catch a contradiction")
        :explanation "Adding axioms extends what can be derived and checked"))

