; readme.pltg — Claims extracted from core/README.md

(load-document "README" "../README.md")
(import (quote ..std.counting))
(import (quote ..std.epistemics))
(import (quote ..std.util))
(defterm count-exists counting.count-exists :origin "import")

; =====================================================================
; Top-level claims
; =====================================================================

(fact readme-title "Parseltongue Core"
    :evidence (evidence "README"
        :quotes ("# Parseltongue Core")
        :explanation "Module title"))

(fact readme-tagline "The formal language engine. No LLM dependency"
    :evidence (evidence "README"
        :quotes ("The formal language engine. No LLM dependency — pure logic, evidence grounding, consistency checking, and self-introspection.")
        :explanation "Core tagline"))

