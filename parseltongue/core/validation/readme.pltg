        :explanation "README describes the approach — encode docs as logic"))

(fact readme-rationale-facts-cite-quotes-plan true
    :evidence (evidence "README"
        :quotes ("Every extracted fact must cite a verbatim quote. Every conclusion must derive from stated premises. And every derivation is checked.")
        :explanation "README states the three invariants of the system"))

(fact readme-rationale-hallucination-detection-plan true
    :evidence (evidence "README"
        :quotes ("Hallucination detection." "Every claim traces back to a quote in a source document. If the LLM fabricates a fact, the quote verification fails")
        :explanation "README claims hallucination detection via quote verification"))

(fact readme-rationale-fabrication-contaminates-plan true
    :evidence (evidence "README"
        :quotes ("that failure propagates automatically to every conclusion that depends on it. You don't just catch the lie; you see everything it contaminates.")
        :explanation "README claims fabrication contamination propagation"))

(fact readme-rationale-cross-doc-consistency-plan true
    :evidence (evidence "README"
        :quotes ("Cross-document consistency checking." "we validate if the ground truth is trustable itself.")
        :explanation "README claims cross-document consistency checking"))

(fact readme-rationale-independent-paths-plan true
    :evidence (evidence "README"
        :quotes ("compute the same value via independent paths" "When these paths disagree, the system flags a divergence")
        :explanation "README describes independent computation paths as the diff mechanism"))

