(fact readme-math-each-ordinal-expands-plan true
    :evidence (evidence "README"
        :quotes ("Each new ordinal" "expands what can be proved" "Each extension unlocks derivations that were previously unreachable")
        :explanation "README claims each extension unlocks new derivations"))

(fact readme-math-diffs-as-consistency-plan true
    :evidence (evidence "README"
