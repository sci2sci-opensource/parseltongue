; Directive count confirmed as boolean
(derive readme-directive-count-confirmed
    (= readme-directive-count 6)
    :using (readme-directive-count))

(derive export-directive-count-confirmed
    (util.export readme-directive-count-confirmed)
    :using (util.export readme-directive-count-confirmed))

; Defterm forms count: forward-decl + computed = 2
(derive readme-defterm-forms-count
    (count-exists readme-defterm-forward-decl readme-defterm-computed)
    :using (count-exists readme-defterm-forward-decl readme-defterm-computed))

(derive export-defterm-forms-count
    (util.export readme-defterm-forms-count)
    :using (util.export readme-defterm-forms-count))
