; =====================================================================
; Axiom claims — what README states as rules
; =====================================================================

; "Axioms MUST contain at least one ?-variable"
(fact readme-axiom-var-requirement true
    :evidence (evidence "README"
        :quotes ("Axioms MUST contain at least one ?-variable")
        :explanation "README states axiom variable requirement"))

; "If any source has unverified evidence, the derivation inherits the fabrication taint"
(fact readme-fabrication-propagation true
    :evidence (evidence "README"
        :quotes ("If any source has unverified evidence, the derivation inherits the fabrication taint")
        :explanation "README documents fabrication propagation"))

; "Evidence is a first-class citizen"
(fact readme-evidence-first-class true
    :evidence (evidence "README"
        :quotes ("Evidence is a first-class citizen")
        :explanation "README claims evidence is first-class"))

; "Statements without evidence can be verified after the fact via system.verify_manual"
(fact readme-verify-manual-described true
    :evidence (evidence "README"
        :quotes ("system.verify_manual")
        :explanation "README documents verify_manual"))

; =====================================================================
; Module system section
; =====================================================================

(fact readme-loader-section true
    :evidence (evidence "README"
        :quotes ("## Module System")
        :explanation "README has a Module System section"))

(fact readme-loader-import-effect true
    :evidence (evidence "README"
        :quotes ("(import (quote module.name))")
        :explanation "README documents import effect"))

(fact readme-loader-run-on-entry-effect true
    :evidence (evidence "README"
        :quotes ("(run-on-entry (quote (directive ...)))")
        :explanation "README documents run-on-entry effect"))

(fact readme-loader-load-document-effect true
    :evidence (evidence "README"
        :quotes ("(load-document \"name\" \"relative/path.txt\")")
        :explanation "README documents load-document effect"))

(fact readme-loader-context-effect true
    :evidence (evidence "README"
        :quotes ("(context :file)")
        :explanation "README documents context effect"))

(fact readme-loader-print-effect true
    :evidence (evidence "README"
        :quotes ("(print \"label\" value ...)")
        :explanation "README documents print effect"))

(fact readme-loader-effect-count 7
    :evidence (evidence "README"
        :quotes ("The loader provides 7 built-in effects")
        :explanation "README claims 7 built-in effects"))

(fact readme-loader-namespacing true
    :evidence (evidence "README"
        :quotes ("automatically namespaced with their module name")
        :explanation "README documents namespacing"))

(fact readme-loader-circular-detection true
    :evidence (evidence "README"
        :quotes ("Circular imports are detected and raise an error")
        :explanation "README documents circular import detection"))

(fact readme-loader-context-onion true
    :evidence (evidence "README"
        :quotes ("immutable ModuleContext following an onion model")
        :explanation "README documents onion context model"))

(fact readme-loader-load-pltg true
    :evidence (evidence "README"
        :quotes ("load_pltg")
        :explanation "README documents load_pltg entry point"))

(fact readme-documents-consistency-modes true
    :evidence (evidence "README"
        :quotes ("(consistency :raise)" "(consistency :bool)" "(consistency :report)")
        :explanation "README documents the three optional consistency modes"))

(fact readme-documents-consistency-default true
    :evidence (evidence "README"
        :quotes ("With no arguments, prints the report and returns True")
        :explanation "README documents default consistency behavior"))

(fact readme-documents-consistency-raise true
    :evidence (evidence "README"
        :quotes ("(consistency :raise) prints and raises on inconsistency")
        :explanation "README documents :raise mode"))

(fact readme-documents-consistency-bool true
    :evidence (evidence "README"
        :quotes ("(consistency :bool) returns boolean without printing")
        :explanation "README documents :bool mode"))

(fact readme-documents-consistency-report true
    :evidence (evidence "README"
        :quotes ("(consistency :report) returns the ConsistencyReport object")
        :explanation "README documents :report mode"))

