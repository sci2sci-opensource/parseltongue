    :evidence (evidence "README"
        :quotes ("Six directive types" "fact, axiom, defterm, derive, diff, and evidence")
        :explanation "README lists 6 directives"))

(fact readme-has-fact-directive true
    :evidence (evidence "README"
        :quotes ("**`fact`** — a named value extracted from a document.")
        :explanation "fact listed as directive"))

(fact readme-has-axiom-directive true
    :evidence (evidence "README"
        :quotes ("**`axiom`** — a parametric rule with `?`-variables.")
        :explanation "axiom listed as directive"))

(fact readme-has-defterm-directive true
    :evidence (evidence "README"
        :quotes ("**`defterm`** (forward declaration) — introduces a primitive symbol with no body")
        :explanation "defterm listed as directive"))

(fact readme-has-derive-directive true
    :evidence (evidence "README"
        :quotes ("**`derive`** — a theorem proved by evaluating a WFF against existing facts, terms, and axioms.")
        :explanation "derive listed as directive"))

(fact readme-has-diff-directive true
    :evidence (evidence "README"
        :quotes ("**`diff`** — a lazy consistency comparison between two symbols.")
        :explanation "diff listed as directive"))

(fact readme-has-evidence-directive true
    :evidence (evidence "README"
        :quotes ("### Evidence" "Evidence is a first-class citizen and is directly used by the engine and grammar" "structured provenance attached to symbolic directives")
        :explanation "evidence has its own section under Directive Types"))

; Directive descriptions — what each directive does
(fact readme-fact-description true
    :evidence (evidence "README"
        :quotes ("a named value extracted from a document. Facts are the atoms of the system")
        :explanation "README describes fact as atomic data point"))

(fact readme-axiom-description true
    :evidence (evidence "README"
        :quotes ("a parametric rule with ?-variables. Ground statements (no ?-variables) are rejected")
        :explanation "README describes axiom as parametric rule"))

(fact readme-defterm-forward-decl true
    :evidence (evidence "README"
        :quotes ("introduces a primitive symbol with no body" "These are the building blocks")
        :explanation "README documents defterm forward declaration in Symbolic Directives"))

(fact readme-defterm-computed true
    :evidence (evidence "README"
        :quotes ("an expression evaluated when referenced" "A **conditional term** uses `if` to branch")
        :explanation "README documents defterm computed and conditional in Computable Directives"))

(fact readme-documents-diffs-section true
    :evidence (evidence "README"
        :quotes ("### Diffs" "Diffs require no evidence because inconsistency between their sides is itself a system-level issue")
        :explanation "README gives diffs their own section"))

(fact readme-derive-restricted-eval true
    :evidence (evidence "README"
        :quotes ("Evaluation is restricted to symbols listed in :using; rewrite axioms fire automatically, non-rewrite axioms require :bind")
        :explanation "README documents :using restriction and bind/auto-bind distinction"))

(fact readme-documents-symbolic-directives true
    :evidence (evidence "README"
        :quotes ("### Symbolic Directives" "Symbols are the core entity of the language")
        :explanation "README names symbolic directives section and introduces symbols as core entity"))

(fact readme-documents-rewrite-vs-bind true
    :evidence (evidence "README"
        :quotes ("**rewrite axioms** (`(= <pattern> <rhs>)`) fire automatically during evaluation — no :bind needed" "**Non-rewrite axioms** (`implies`, `>`, etc.) require explicit :bind")
        :explanation "README documents rewrite auto-bind vs explicit :bind distinction"))

(fact readme-documents-splat-in-axioms true
    :evidence (evidence "README"
        :quotes ("Axioms also support `?...`-prefixed splat variables that collect trailing arguments")
        :explanation "README documents splat variables in axioms"))

(fact readme-documents-computable-directives true
    :evidence (evidence "README"
        :quotes ("### Computable Directives" "Computed terms are evaluated on reference" "Derives are evaluated at definition time")
        :explanation "README names computable directives section with evaluation semantics"))

(fact readme-documents-extensible-directives true
    :evidence (evidence "README"
        :quotes ("the language is extensible with [custom operators](#custom-environments) and [effects](#built-in-effects)")
        :explanation "README mentions extensibility with operators and effects"))

(fact readme-diff-lazy true
    :evidence (evidence "README"
        :quotes ("a lazy consistency comparison between two symbols")
        :explanation "README describes diff as lazy"))

; --- Diff behavior: dependency tracking and contamination ---

(fact readme-diff-scans-five-types true
    :evidence (evidence "README"
        :quotes ("transitively scan all five definition types — facts, terms, axioms, theorems, and diffs")
        :explanation "README claims diff scans 5 definition types"))

(fact readme-diff-scans-facts true
    :evidence (evidence "README"
        :quotes ("facts, terms, axioms, theorems, and diffs")
        :explanation "README lists facts as scanned type"))

(fact readme-diff-scans-terms true
    :evidence (evidence "README"
        :quotes ("facts, terms, axioms, theorems, and diffs")
        :explanation "README lists terms as scanned type"))

(fact readme-diff-scans-axioms true
    :evidence (evidence "README"
        :quotes ("facts, terms, axioms, theorems, and diffs")
        :explanation "README lists axioms as scanned type"))

(fact readme-diff-scans-theorems true
    :evidence (evidence "README"
        :quotes ("facts, terms, axioms, theorems, and diffs")
        :explanation "README lists theorems as scanned type"))

(fact readme-diff-scans-diffs true
    :evidence (evidence "README"
        :quotes ("facts, terms, axioms, theorems, and diffs")
        :explanation "README lists diffs as scanned type"))

(fact readme-diff-transitive true
    :evidence (evidence "README"
        :quotes ("transitively scan all five definition types")
        :explanation "README claims transitive scanning"))

(fact readme-diff-follows-derivation-chains true
    :evidence (evidence "README"
        :quotes ("follows not just direct references but also theorem derivation chains, catching indirect dependencies where a theorem's expression doesn't mention the symbol but its `:using` list does")
        :explanation "README claims derivation chain following"))

(fact readme-diff-excludes-self true
    :evidence (evidence "README"
        :quotes ("A diff excludes itself from its own dependency scan")
        :explanation "README claims self-exclusion"))

(fact readme-diff-contaminates-diffs true
    :evidence (evidence "README"
        :quotes ("Dependent diffs and theorems that reference the replaced symbol are flagged as contaminated rather than re-evaluated")
        :explanation "README claims diff contamination flagging"))

(fact readme-diff-contaminates-theorems true
    :evidence (evidence "README"
        :quotes ("Dependent diffs and theorems that reference the replaced symbol are flagged as contaminated")
        :explanation "README claims theorem contamination flagging"))

; Evidence does not participate in direct computation
(fact readme-evidence-not-direct-computation true
    :evidence (evidence "README"
        :quotes ("evidence does not participate in direct computation — it primarily exists for evaluation by the consistency checker")
        :explanation "README states evidence is not a computable directive"))

(fact readme-diff-not-scans-evidence true
    :evidence (evidence "README"
        :quotes ("transitively scan all five definition types — facts, terms, axioms, theorems, and diffs")
        :explanation "README lists exactly 5 types scanned by diff — evidence is absent"))

; Axiom: evidence implies no direct computation
(axiom evidence-excludes-direct-computation
    (implies ?is-evidence (not ?participates-in-direct-computation))
    :evidence (evidence "README"
        :quotes ("evidence does not participate in direct computation")
        :explanation "Evidence directive is excluded from the computation graph"))

; Prove evidence is excluded via axiom :bind
; evidence-excludes-direct-computation: (implies ?is-evidence (not ?participates))
; ?is-evidence = readme-has-evidence-directive (true)
; ?participates = evidence-computes (false) → (not false) = true → (implies true true) = true ✓
(defterm evidence-computes (not readme-evidence-not-direct-computation)
    :origin "negation: evidence doesn't compute → false")

(derive bound-evidence-excludes-computation evidence-excludes-direct-computation
    :bind ((?is-evidence readme-has-evidence-directive)
           (?participates-in-direct-computation evidence-computes))
    :using (evidence-excludes-direct-computation readme-has-evidence-directive evidence-computes))

; Computable directive count: all 6 directives, evidence counted as false → 5
(derive readme-computable-directive-count
    (count-exists readme-has-fact-directive readme-has-axiom-directive
                  readme-has-defterm-directive readme-has-derive-directive
                  readme-has-diff-directive evidence-computes)
    :using (count-exists counting.count-exists-base counting.count-exists-step
            readme-has-fact-directive readme-has-axiom-directive
            readme-has-defterm-directive readme-has-derive-directive
            readme-has-diff-directive evidence-computes))

; Items × Layers: 6 directives × 2 layers (declared, scanned-by-diff)
; 5 computable directives are scanned; evidence not scanned and not computable
; Evidence row: (or (not not-scans) (not not-computes)) = (or false false) = false
(derive readme-diff-scan-paired
    (count-exists (and readme-has-fact-directive readme-diff-scans-facts)
                  (and readme-has-axiom-directive readme-diff-scans-axioms)
                  (and readme-has-defterm-directive readme-diff-scans-terms)
                  (and readme-has-derive-directive readme-diff-scans-theorems)
                  (and readme-has-diff-directive readme-diff-scans-diffs)
                  (or (not readme-diff-not-scans-evidence) (not readme-evidence-not-direct-computation)))
    :using (count-exists counting.count-exists-base counting.count-exists-step
            readme-has-fact-directive readme-diff-scans-facts
            readme-has-axiom-directive readme-diff-scans-axioms
            readme-has-defterm-directive readme-diff-scans-terms
            readme-has-derive-directive readme-diff-scans-theorems
            readme-has-diff-directive readme-diff-scans-diffs
            readme-diff-not-scans-evidence readme-evidence-not-direct-computation))

(derive readme-diff-scan-type-count
    (count-exists readme-diff-scans-facts readme-diff-scans-terms
                  readme-diff-scans-axioms readme-diff-scans-theorems readme-diff-scans-diffs)
    :using (count-exists counting.count-exists-base counting.count-exists-step
            readme-diff-scans-facts readme-diff-scans-terms
            readme-diff-scans-axioms readme-diff-scans-theorems readme-diff-scans-diffs))

(diff readme-diff-scan-paired-vs-scan :replace readme-diff-scan-paired :with readme-diff-scan-type-count)
(diff readme-diff-scan-paired-vs-computable :replace readme-diff-scan-paired :with readme-computable-directive-count)

; Behavioral properties — README-internal count
(derive readme-diff-behavior-count
    (count-exists readme-diff-transitive readme-diff-follows-derivation-chains
                  readme-diff-excludes-self readme-diff-contaminates-diffs readme-diff-contaminates-theorems)
    :using (count-exists counting.count-exists-base counting.count-exists-step
            readme-diff-transitive readme-diff-follows-derivation-chains
            readme-diff-excludes-self readme-diff-contaminates-diffs readme-diff-contaminates-theorems))

; Exports for core.pltg
(derive export-diff-scan-paired (util.export readme-diff-scan-paired) :using (util.export readme-diff-scan-paired))
(derive export-diff-scan-type-count (util.export readme-diff-scan-type-count) :using (util.export readme-diff-scan-type-count))
(derive export-diff-behavior-count (util.export readme-diff-behavior-count) :using (util.export readme-diff-behavior-count))
(derive export-computable-directive-count (util.export readme-computable-directive-count) :using (util.export readme-computable-directive-count))
(derive export-diff-transitive (util.export readme-diff-transitive) :using (util.export readme-diff-transitive))
(derive export-diff-follows-derivation-chains (util.export readme-diff-follows-derivation-chains) :using (util.export readme-diff-follows-derivation-chains))
(derive export-diff-excludes-self (util.export readme-diff-excludes-self) :using (util.export readme-diff-excludes-self))
(derive export-diff-contaminates-diffs (util.export readme-diff-contaminates-diffs) :using (util.export readme-diff-contaminates-diffs))
(derive export-diff-contaminates-theorems (util.export readme-diff-contaminates-theorems) :using (util.export readme-diff-contaminates-theorems))

; =====================================================================
; Special Techniques — one per directive type section
; =====================================================================

; --- Symbolic: Rewrite Axioms as Reusable Functions ---

(fact readme-documents-rewrite-as-functions true
    :evidence (evidence "README"
        :quotes ("Rewrite axioms (`(= <pattern> <rhs>)`) fire automatically during evaluation — the engine pattern-matches the left side and replaces it with the right side, up to 100 rewrites deep. This means you can define mathematical operations once and reuse them across the entire system without re-citing evidence each time. The axiom is grounded once; every derive that triggers it inherits the grounding for free.")
        :explanation "README documents rewrite axioms as reusable functions with single-grounding benefit"))

(fact readme-documents-splat-variadic-reduce true
    :evidence (evidence "README"
        :quotes ("Combined with `?...`-prefixed **splat variables** (which collect trailing arguments), rewrite axioms can define variadic reduce functions — functions that accept any number of arguments and fold them down. This eliminates deeply nested binary expressions.")
        :explanation "README documents splat variables for variadic reduce eliminating nested binary ops"))

(fact readme-documents-counting-pltg-link true
    :evidence (evidence "README"
        :quotes ("The same pattern powers the validation system's `count-exists` (how many boolean items are truthy) and `sum-values` (numeric sum) — both defined in [`validation/counting.pltg`](validation/counting.pltg) and imported across all validation modules.")
        :explanation "README links to counting.pltg as source of count-exists and sum-values"))

(fact readme-documents-apples-splats-demo-link true
    :evidence (evidence "README"
        :quotes ("The `apples_splats_pltg` demo ([`demos/apples_splats_pltg/`](demos/apples_splats_pltg/)) builds full Peano arithmetic with variadic `sum-all`, `count-gt`, and `all-gt` using this technique.")
        :explanation "README links to apples_splats_pltg demo for rewrite+splat technique"))

; --- Computable: Effects in Computable Contexts ---

(fact readme-documents-effects-in-computable true
    :evidence (evidence "README"
        :quotes ("While effects typically fire as top-level directives, they can also appear inside computable contexts — `if` branches, `defterm` bodies, and `derive` WFFs — because the engine evaluates them like any other callable.")
        :explanation "README documents effects in computable contexts"))

(fact readme-documents-conditional-side-effects true
    :evidence (evidence "README"
        :quotes ("This enables conditional side effects driven by the formal system's own state:")
        :explanation "README documents conditional side effects driven by system state"))

(fact readme-documents-self-healing-demo-link true
    :evidence (evidence "README"
        :quotes ("The `self_healing` demo ([`demos/self_healing/`](demos/self_healing/)) builds a complete detect-patch-verify-rollback loop using this pattern: custom effects (`snapshot`, `patch-fact`, `rollback`, `check-diff`) are registered at construction, and the DSL script uses `if` to conditionally fire them based on consistency results.")
        :explanation "README links to self_healing demo for effects-in-computable technique"))

(fact readme-documents-extensibility-demo-link true
    :evidence (evidence "README"
        :quotes ("The `extensibility` demo ([`demos/extensibility/`](demos/extensibility/)) shows a simpler case — a `load-data` effect that loads documents from within the DSL itself, so the formal system controls its own data ingestion.")
        :explanation "README links to extensibility demo for effects technique"))

; --- Diffs: Items × Layers ---

(fact readme-documents-items-x-layers true
    :evidence (evidence "README"
        :quotes ("When a codebase has N items that each appear in multiple representations (documentation, configuration, implementation), the **Items × Layers** pattern catches discrepancies between layers. Create a fact per item per layer, derive per-layer aggregates with splat axioms (`count-exists`, `sum-values`, or custom reducers), then diff the aggregates against each other.")
        :explanation "README documents Items × Layers pattern"))

(fact readme-documents-items-x-layers-not-only-boolean true
    :evidence (evidence "README"
        :quotes ("Facts don't have to be boolean. Layers can carry numeric values, strings, or any other type — what matters is that each item has a fact in each layer, and the cross-layer diffs expose when layers disagree.")
        :explanation "README documents that layers can carry any type, not just booleans"))

(fact readme-documents-items-x-layers-matrix true
    :evidence (evidence "README"
        :quotes ("Any N×M grid of facts where rows are items and columns are representations becomes an Items × Layers validation.")
        :explanation "README documents N×M matrix interpretation of Items × Layers"))

(fact readme-documents-items-x-layers-paired true
    :evidence (evidence "README"
        :quotes ("Paired: each item must have ALL layers confirmed")
        :explanation "README documents paired boolean count within Items × Layers"))

(fact readme-documents-items-x-layers-qv-link true
    :evidence (evidence "README"
