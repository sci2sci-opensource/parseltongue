; readme.pltg — Claims extracted from core/README.md

(load-document "README" "../README.md")
(import (quote counting))
(defterm count-exists counting.count-exists :origin "import")

; =====================================================================
; Top-level claims
; =====================================================================

(fact readme-title "Parseltongue Core"
    :evidence (evidence "README"
        :quotes ("# Parseltongue Core")
        :explanation "Module title"))

(fact readme-tagline "The formal language engine. No LLM dependency"
    :evidence (evidence "README"
        :quotes ("The formal language engine. No LLM dependency")
        :explanation "Core tagline"))

; =====================================================================
; Directive types
; =====================================================================

(fact readme-directive-count 5
    :evidence (evidence "README"
        :quotes ("Five directive types, each optionally grounded in :evidence")
        :explanation "README claims 5 directives"))

(fact readme-has-fact-directive true
    :evidence (evidence "README"
        :quotes ("fact")
        :explanation "fact listed as directive"))

(fact readme-has-axiom-directive true
    :evidence (evidence "README"
        :quotes ("axiom")
        :explanation "axiom listed as directive"))

(fact readme-has-defterm-directive true
    :evidence (evidence "README"
        :quotes ("defterm")
        :explanation "defterm listed as directive"))

(fact readme-has-derive-directive true
    :evidence (evidence "README"
        :quotes ("derive")
        :explanation "derive listed as directive"))

(fact readme-has-diff-directive true
    :evidence (evidence "README"
        :quotes ("diff")
        :explanation "diff listed as directive"))

; =====================================================================
; Built-in operators section
; =====================================================================

(fact readme-special-forms-count 3
    :evidence (evidence "README"
        :quotes ("**Special forms**: if, let, quote")
        :explanation "README lists 3 special forms"))

(fact readme-arithmetic "5"
    :evidence (evidence "README"
        :quotes ("+, -, *, /, mod")
        :explanation "5 arithmetic operators"))

(fact readme-comparison "6"
    :evidence (evidence "README"
        :quotes (">, <, >=, <=, =, !=")
        :explanation "6 comparison operators"))

(fact readme-logic "4"
    :evidence (evidence "README"
        :quotes ("and, or, not, implies")
        :explanation "4 logic operators"))

; =====================================================================
; Quote verifier section
; =====================================================================

(fact readme-verifier-confidence-shape "dict"
    :evidence (evidence "README"
        :quotes ("confidence: {score: 0.95, level:")
        :explanation "README shows confidence as a dict"))

(fact readme-verifier-position-key "original_position"
    :evidence (evidence "README"
        :quotes ("original_position:")
        :explanation "README uses original_position key"))

(fact readme-normalization-steps 6
    :evidence (evidence "README"
        :quotes ("six-step normalization pipeline")
        :explanation "README says 6 normalization steps"))

(fact readme-extensibility-claim true
    :evidence (evidence "README"
        :quotes ("custom normalizers, fuzzy matchers, and custom tokenizers can be plugged in")
        :explanation "README claims extensibility for custom normalizers/matchers/tokenizers"))

(fact readme-binary-threshold true
    :evidence (evidence "README"
        :quotes ("a confidence score with a binary threshold for pass/fail")
        :explanation "README says binary threshold"))

