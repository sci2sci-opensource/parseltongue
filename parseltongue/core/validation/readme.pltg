; Packaging
; =====================================================================

(fact readme-documents-pltg-shipped true
    :evidence (evidence "README"
        :quotes ("ships .pltg module files")
        :explanation "README documents that .pltg files are shipped in the package"))

(fact readme-documents-txt-shipped true
    :evidence (evidence "README"
        :quotes (".txt resource documents alongside Python code")
        :explanation "README documents that .txt resources are shipped"))

(fact readme-documents-tests-configured true
    :evidence (evidence "README"
        :quotes ("parseltongue/core/tests directory is included in pytest testpaths")
        :explanation "README documents that core tests are in pytest testpaths"))

; =====================================================================
; Splat patterns — README coverage gap
; =====================================================================

(fact readme-documents-splat-patterns false
    :origin "README has no mention of ?... splat patterns")

; Cross-module diff (readme vs loader effect count) lives in core.pltg

; =====================================================================
; Code vs Docs — two-branch-then-diff
; =====================================================================

; --- 1. Top-level claims ---

(derive readme-identity-doc-count
    (count-exists readme-title readme-tagline)
    :using (count-exists counting.count-exists-base counting.count-exists-step
            readme-title readme-tagline))

(defterm readme-identity-impl-count 2
    :evidence (evidence "README"
        :quotes ("# Parseltongue Core" "The formal language engine. No LLM dependency")
        :explanation "2 top-level claims in README"))

(diff readme-identity-coverage
    :replace readme-identity-doc-count
    :with readme-identity-impl-count)

; --- 2. Directives ---

(derive readme-directives-doc-count
    (count-exists readme-directive-count readme-has-fact-directive readme-has-axiom-directive readme-has-defterm-directive readme-has-derive-directive readme-has-diff-directive)
    :using (count-exists counting.count-exists-base counting.count-exists-step
            readme-directive-count readme-has-fact-directive readme-has-axiom-directive readme-has-defterm-directive readme-has-derive-directive readme-has-diff-directive))

(defterm readme-directives-impl-count 6
    :evidence (evidence "README"
        :quotes ("Five directive types" "fact" "axiom" "defterm" "derive" "diff")
        :explanation "6 directive documentation features in README"))

(diff readme-directives-coverage
    :replace readme-directives-doc-count
    :with readme-directives-impl-count)

; --- 3. Built-in operators ---

(derive readme-operators-doc-count
    (count-exists readme-arithmetic readme-comparison readme-logic)
    :using (count-exists counting.count-exists-base counting.count-exists-step
            readme-arithmetic readme-comparison readme-logic))

(defterm readme-operators-impl-count 3
    :evidence (evidence "README"
        :quotes ("+, -, *, /, mod" ">, <, >=, <=, =, !=" "and, or, not, implies")
        :explanation "3 operator categories in README"))

(diff readme-operators-coverage
    :replace readme-operators-doc-count
    :with readme-operators-impl-count)

; --- 4. Evidence system ---

(derive readme-evidence-doc-count
    (count-exists readme-evidence-first-class readme-verify-manual-described readme-binary-threshold)
    :using (count-exists counting.count-exists-base counting.count-exists-step
            readme-evidence-first-class readme-verify-manual-described readme-binary-threshold))

(defterm readme-evidence-impl-count 3
    :evidence (evidence "README"
        :quotes ("Evidence is a first-class citizen" "system.verify_manual" "a confidence score with a binary threshold")
        :explanation "3 evidence system features in README"))

(diff readme-evidence-coverage
    :replace readme-evidence-doc-count
    :with readme-evidence-impl-count)

; --- 5. Issue types ---

(derive readme-issue-types-doc-count
    (count-exists readme-issue-type-1 readme-issue-type-2 readme-issue-type-3 readme-issue-type-4 readme-issue-type-5)
    :using (count-exists counting.count-exists-base counting.count-exists-step
            readme-issue-type-1 readme-issue-type-2 readme-issue-type-3 readme-issue-type-4 readme-issue-type-5))

(defterm readme-issue-types-impl-count 5
    :evidence (evidence "README"
        :quotes ("unverified_evidence" "no_evidence" "potential_fabrication" "diff_divergence" "diff_value_divergence")
        :explanation "5 issue types in README"))

(diff readme-issue-types-coverage
    :replace readme-issue-types-doc-count
    :with readme-issue-types-impl-count)

; --- 6. Custom environments ---

(derive readme-custom-env-doc-count
    (count-exists readme-docs-param-described readme-initial-env-described)
    :using (count-exists counting.count-exists-base counting.count-exists-step
            readme-docs-param-described readme-initial-env-described))

(defterm readme-custom-env-impl-count 2
    :evidence (evidence "README"
        :quotes ("The docs= parameter controls what system.doc() returns" "initial_env={}")
        :explanation "2 custom env features in README"))

(diff readme-custom-env-coverage
