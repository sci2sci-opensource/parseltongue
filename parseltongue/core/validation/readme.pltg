; =====================================================================
; Axiom bindings — prove README axioms against README code examples
; =====================================================================

; --- every-fact-cites-quote ---
(fact example-fact-has-evidence true
    :evidence (evidence "README"
        :quotes ("(fact revenue-q3 15.0\n  :evidence (evidence \"Q3 Report\"\n    :quotes (\"Q3 revenue was $15M\")\n    :explanation \"Dollar revenue figure from Q3 report\"))")
        :explanation "README code example shows a fact with :evidence and :quotes"))

(fact example-fact-quotes-verbatim true
    :evidence (evidence "README"
        :quotes ("Q3 revenue was $15M")
        :explanation "The example fact cites a verbatim quote from its source"))

(derive bound-every-fact-cites-quote every-fact-cites-quote
    :bind ((?is-fact example-fact-has-evidence) (?must-cite-quote example-fact-quotes-verbatim))
    :using (every-fact-cites-quote example-fact-has-evidence example-fact-quotes-verbatim))

; --- axioms-require-variables ---
(fact example-axiom-exists true
    :evidence (evidence "README"
        :quotes ("(axiom add-commutative (= (+ ?a ?b) (+ ?b ?a))\n  :origin \"Arithmetic axiom\")")
        :explanation "README code example shows an axiom"))

(fact example-axiom-has-question-vars true
    :evidence (evidence "README"
        :quotes ("?a" "?b")
        :explanation "The example axiom contains ?-variables"))

(derive bound-axioms-require-variables axioms-require-variables
    :bind ((?is-axiom example-axiom-exists) (?has-question-var example-axiom-has-question-vars))
    :using (axioms-require-variables example-axiom-exists example-axiom-has-question-vars))

; --- diffs-detect-contradictions ---
(fact example-diff-has-replace true
    :evidence (evidence "README"
        :quotes ("(diff growth-check\n  :replace revenue-q3-growth\n  :with revenue-q3-growth-computed)")
        :explanation "README code example shows a diff with :replace path"))

(fact example-diff-has-with true
    :evidence (evidence "README"
        :quotes (":with revenue-q3-growth-computed")
        :explanation "README diff example has a :with path"))

(fact example-diff-detects-divergence true
    :evidence (evidence "README"
        :quotes ("Where results diverge, something is wrong")
        :explanation "README states diffs detect divergence"))

(derive bound-diffs-detect-contradictions diffs-detect-contradictions
    :bind ((?path-a example-diff-has-replace) (?path-b example-diff-has-with) (?divergence-detectable example-diff-detects-divergence))
    :using (diffs-detect-contradictions example-diff-has-replace example-diff-has-with example-diff-detects-divergence))

; --- fabrication-propagates ---
(fact example-source-unverified true
    :evidence (evidence "README"
        :quotes ("if a fact's evidence is unverified")
        :explanation "README states the antecedent: source evidence is unverified"))

(fact example-derivation-tainted true
    :evidence (evidence "README"
        :quotes ("any theorem derived from it is automatically marked as a potential fabrication")
        :explanation "README states the consequent: derivation is tainted"))

(derive bound-fabrication-propagates fabrication-propagates
    :bind ((?source-unverified example-source-unverified) (?derivation-tainted example-derivation-tainted))
    :using (fabrication-propagates example-source-unverified example-derivation-tainted))

; --- Exports for core.pltg ---
(derive export-bound-fact-cites-quote
    (util.export bound-every-fact-cites-quote)
    :using (util.export bound-every-fact-cites-quote))

(derive export-bound-axioms-require-vars
    (util.export bound-axioms-require-variables)
    :using (util.export bound-axioms-require-variables))

(derive export-bound-diffs-detect
    (util.export bound-diffs-detect-contradictions)
    :using (util.export bound-diffs-detect-contradictions))

(derive export-bound-fabrication
    (util.export bound-fabrication-propagates)
    :using (util.export bound-fabrication-propagates))

; =====================================================================
; Dangling exports — internally verified listing counts for core.pltg
; to cross-check against implementation modules
; =====================================================================

(derive export-special-forms-count
    (util.export readme-special-forms-listing-count)
    :using (util.export readme-special-forms-listing-count))

(derive export-issue-types-count
    (util.export readme-issue-types-listing-count)
    :using (util.export readme-issue-types-listing-count))

(derive export-warning-types-count
    (util.export readme-warning-types-listing-count)
    :using (util.export readme-warning-types-listing-count))

(derive export-consistency-states-total
    (util.export readme-consistency-states-total)
    :using (util.export readme-consistency-states-total))

(derive export-lazy-phases-count
    (util.export readme-lazy-phases-listing-count)
    :using (util.export readme-lazy-phases-listing-count))

(derive export-ast-fields-count
    (util.export readme-ast-fields-listing-count)
    :using (util.export readme-ast-fields-listing-count))

