; =====================================================================
; Internal consistency — non-tautological diffs only
; =====================================================================
; README exports expectations for core.pltg to consume cross-module.
; Here we only prove internal consistency: stated counts vs listed items,
; and paired coverage (listing + description for same item).
; Most readme facts are correctly dangling — they're consumed externally.

; --- 1. Directive count vs listing ---
; README says "6 directive types" and lists them individually.

(derive readme-directive-listing-count
    (count-exists readme-has-fact-directive readme-has-axiom-directive
                  readme-has-defterm-directive readme-has-derive-directive readme-has-diff-directive
                  readme-has-evidence-directive)
    :using (count-exists readme-has-fact-directive readme-has-axiom-directive
                         readme-has-defterm-directive readme-has-derive-directive readme-has-diff-directive
                         readme-has-evidence-directive))

(diff readme-directive-listing-vs-stated :replace readme-directive-listing-count :with readme-directive-count)

; --- 2. Directive paired coverage ---
; Each directive has BOTH a listing fact AND a description fact.

(derive readme-directive-paired-count
    (count-exists (and readme-has-fact-directive readme-fact-description)
                  (and readme-has-axiom-directive readme-axiom-description)
                  (and readme-has-defterm-directive readme-defterm-forward-decl readme-defterm-computed)
                  (and readme-has-derive-directive readme-derive-restricted-eval)
                  (and readme-has-diff-directive readme-diff-lazy readme-documents-diffs-section)
                  (and readme-has-evidence-directive readme-has-evidence-directive))
    :using (count-exists
            readme-has-fact-directive readme-fact-description
            readme-has-axiom-directive readme-axiom-description
            readme-has-defterm-directive readme-defterm-forward-decl readme-defterm-computed
            readme-has-derive-directive readme-derive-restricted-eval
            readme-has-diff-directive readme-diff-lazy readme-documents-diffs-section
            readme-has-evidence-directive))

(diff readme-directive-paired-vs-listing :replace readme-directive-paired-count :with readme-directive-listing-count)

; --- 3. Demo count vs listing ---
; README says "11 demos" and lists them individually.

(derive readme-demo-listing-count
    (count-exists readme-demo-apples readme-demo-apples-pltg readme-demo-apples-splats-pltg
                  readme-demo-revenue readme-demo-biomarkers readme-demo-code-check
                  readme-demo-doc-validation readme-demo-spec-validation readme-demo-extensibility
                  readme-demo-self-healing readme-demo-deferred readme-demo-entry-mocks)
    :using (count-exists readme-demo-apples readme-demo-apples-pltg readme-demo-apples-splats-pltg
                         readme-demo-revenue readme-demo-biomarkers readme-demo-code-check
                         readme-demo-doc-validation readme-demo-spec-validation readme-demo-extensibility
                         readme-demo-self-healing readme-demo-deferred readme-demo-entry-mocks))

(diff readme-demo-listing-vs-count :replace readme-demo-listing-count :with readme-demo-count)

; --- 4. Loader effect count vs listing ---
