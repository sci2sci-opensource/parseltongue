; =====================================================================
; Special Techniques — one per directive type section
; =====================================================================

; --- Symbolic: Rewrite Axioms as Reusable Functions ---

(fact readme-documents-rewrite-as-functions true
    :evidence (evidence "README"
        :quotes ("Rewrite axioms (`(= <pattern> <rhs>)`) fire automatically during evaluation — the engine pattern-matches the left side and replaces it with the right side, up to 100 rewrites deep. This means you can define mathematical operations once and reuse them across the entire system without re-citing evidence each time. The axiom is grounded once; every derive that triggers it inherits the grounding for free.")
        :explanation "README documents rewrite axioms as reusable functions with single-grounding benefit"))

(fact readme-documents-splat-variadic-reduce true
    :evidence (evidence "README"
        :quotes ("Combined with `?...`-prefixed **splat variables** (which collect trailing arguments), rewrite axioms can define variadic reduce functions — functions that accept any number of arguments and fold them down. This eliminates deeply nested binary expressions.")
        :explanation "README documents splat variables for variadic reduce eliminating nested binary ops"))

(fact readme-documents-counting-pltg-link true
    :evidence (evidence "README"
        :quotes ("The same pattern powers the validation system's `count-exists` (how many boolean items are truthy) and `sum-values` (numeric sum) — both defined in [`validation/counting.pltg`](validation/counting.pltg) and imported across all validation modules.")
        :explanation "README links to counting.pltg as source of count-exists and sum-values"))

(fact readme-documents-apples-splats-demo-link true
    :evidence (evidence "README"
        :quotes ("The `apples_splats_pltg` demo ([`demos/apples_splats_pltg/`](demos/apples_splats_pltg/)) builds full Peano arithmetic with variadic `sum-all`, `count-gt`, and `all-gt` using this technique.")
        :explanation "README links to apples_splats_pltg demo for rewrite+splat technique"))

; --- Computable: Effects in Computable Contexts ---

(fact readme-documents-effects-in-computable true
    :evidence (evidence "README"
        :quotes ("While effects typically fire as top-level directives, they can also appear inside computable contexts — `if` branches, `defterm` bodies, and `derive` WFFs — because the engine evaluates them like any other callable.")
        :explanation "README documents effects in computable contexts"))

(fact readme-documents-conditional-side-effects true
    :evidence (evidence "README"
        :quotes ("This enables conditional side effects driven by the formal system's own state:")
        :explanation "README documents conditional side effects driven by system state"))

(fact readme-documents-self-healing-demo-link true
    :evidence (evidence "README"
        :quotes ("The `self_healing` demo ([`demos/self_healing/`](demos/self_healing/)) builds a complete detect-patch-verify-rollback loop using this pattern: custom effects (`snapshot`, `patch-fact`, `rollback`, `check-diff`) are registered at construction, and the DSL script uses `if` to conditionally fire them based on consistency results.")
        :explanation "README links to self_healing demo for effects-in-computable technique"))

(fact readme-documents-extensibility-demo-link true
    :evidence (evidence "README"
        :quotes ("The `extensibility` demo ([`demos/extensibility/`](demos/extensibility/)) shows a simpler case — a `load-data` effect that loads documents from within the DSL itself, so the formal system controls its own data ingestion.")
        :explanation "README links to extensibility demo for effects technique"))

; --- Diffs: Items × Layers ---

(fact readme-documents-items-x-layers true
    :evidence (evidence "README"
        :quotes ("When a codebase has N items that each appear in multiple representations (documentation, configuration, implementation), the **Items × Layers** pattern catches discrepancies between layers. Create a fact per item per layer, derive per-layer aggregates with splat axioms (`count-exists`, `sum-values`, or custom reducers), then diff the aggregates against each other.")
        :explanation "README documents Items × Layers pattern"))

(fact readme-documents-items-x-layers-not-only-boolean true
    :evidence (evidence "README"
        :quotes ("Facts don't have to be boolean. Layers can carry numeric values, strings, or any other type — what matters is that each item has a fact in each layer, and the cross-layer diffs expose when layers disagree.")
        :explanation "README documents that layers can carry any type, not just booleans"))

(fact readme-documents-items-x-layers-matrix true
    :evidence (evidence "README"
        :quotes ("Any N×M grid of facts where rows are items and columns are representations becomes an Items × Layers validation.")
        :explanation "README documents N×M matrix interpretation of Items × Layers"))

(fact readme-documents-items-x-layers-paired true
    :evidence (evidence "README"
        :quotes ("Paired: each item must have ALL layers confirmed")
        :explanation "README documents paired boolean count within Items × Layers"))

(fact readme-documents-items-x-layers-qv-link true
    :evidence (evidence "README"
        :quotes ("The `quote_verifier` validation module ([`validation/quote_verifier.pltg`](validation/quote_verifier.pltg)) uses this pattern extensively — 5 feature flags × 3 layers, 2 match strategies × 3 layers, 4 confidence levels × 3 layers, and 4 result dict keys × 3 layers.")
        :explanation "README links to quote_verifier as extensive Items × Layers example"))

; --- Evidence: Manual Verification Modules ---

(fact readme-documents-manual-verification-modules true
    :evidence (evidence "README"
        :quotes ("Some definitions have no document source — rewrite axioms with `:origin`, import aliases, and hypothetical values constructed for theorem proving. These are flagged by the consistency checker as `no_evidence`. A **manual verification module** aggregates all such definitions in one place and calls `(verify-manual ...)` for each, so an analyst can review them as a batch rather than hunting through individual modules.")
        :explanation "README documents manual verification modules concept"))

(fact readme-documents-manual-verification-3-categories 3
    :evidence (evidence "README"
        :quotes ("The system's own [`validation/verify_manual.pltg`](validation/verify_manual.pltg) demonstrates three categories of manually verified definitions:")
        :explanation "README says verify_manual.pltg demonstrates 3 categories"))

(fact readme-documents-manual-reusables true
    :evidence (evidence "README"
        :quotes ("**Internally constructed reusables** — axioms defined with `:origin` that serve as shared infrastructure. The `counting.pltg` splat axioms (`count-exists-base`, `count-exists-step`, `sum-values-base`, `sum-values-step`) have no document to quote because they *are* the counting mechanism.")
        :explanation "README documents internally constructed reusables category"))

(fact readme-documents-manual-reusables-avoid-defterms true
    :evidence (evidence "README"
        :quotes ("This allows derives to instantiate directly with reusable rewrite axioms instead of defining intermediate `defterm`s that would each require their own evidence — the rewrite fires automatically, so the derive needs only its `:using` symbols, and the consistency checker stays happy because the axioms are manually verified once at the source.")
        :explanation "README documents that reusables avoid intermediate defterms needing evidence"))

(fact readme-documents-manual-import-aliases true
    :evidence (evidence "README"
        :quotes ("**Import aliases** — `(defterm count-exists counting.count-exists :origin \"import\")` creates a local shorthand. Every module that imports `counting.pltg` produces one of these. They're mechanical and safe, but the checker flags them because `:origin` is not `:evidence`.")
        :explanation "README documents import aliases as manually verified category"))

(fact readme-documents-manual-hypotheticals true
    :evidence (evidence "README"
        :quotes ("**Hypotheticals for axiom instantiation** — some axioms require concrete values to prove via `:bind`, but those values don't exist in any document.")
        :explanation "README documents hypotheticals for axiom instantiation category"))

(fact readme-documents-manual-hypotheticals-qv-count 7
    :evidence (evidence "README"
        :quotes ("The `quote_verifier` validation module ([`validation/quote_verifier.pltg`](validation/quote_verifier.pltg)) uses this technique for 7 axioms — empty quotes, single-stopword quotes, normalized-to-empty quotes, score clamping, and config flag gating.")
        :explanation "README says quote_verifier uses hypotheticals for 7 axioms"))

