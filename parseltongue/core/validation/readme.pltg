    :origin "README does not yet document load_source() as the directive dispatcher (handles all 5 directives + fallback eval)")

(fact readme-documents-engine-defaults false
    :origin "README does not yet document engine defaults (strict_derive=True, overridable=False, Fact extends Axiom)")

; =====================================================================
; Lang module — README coverage stubs
; =====================================================================

(fact readme-documents-parse-evidence false
    :origin "README does not yet document parse_evidence() (parses evidence s-expression into Evidence object)")

(fact readme-documents-lang-docs false
    :origin "README does not yet document LANG_DOCS dictionary (operator/directive documentation data fed to LLM)")

(fact readme-foundational-take-evidence true
    :evidence (evidence "README"
        :quotes ("Facts, axioms, and terms can be grounded in :evidence with verbatim :quotes or a plain :origin string")
        :explanation "README states foundational directives take :evidence/:origin"))

(fact readme-derives-inherit-grounding true
    :evidence (evidence "README"
        :quotes ("Derives inherit grounding from their sources — a theorem is proven by its axioms, facts, and computable terms")
        :explanation "README states derives inherit grounding from sources"))

(fact readme-diffs-have-no-evidence true
    :evidence (evidence "README"
        :quotes ("Diffs require no evidence because inconsistency between their sides is itself a system-level issue")
        :explanation "README states diffs need no evidence — inconsistency is the signal"))

(defterm readme-evidence-grounding-scope
    (and readme-foundational-take-evidence readme-derives-inherit-grounding readme-diffs-have-no-evidence)
    :origin "All three evidence grounding scopes documented")

; =====================================================================
; Atoms module — README coverage stubs
; =====================================================================

(fact readme-documents-symbol-class false
    :origin "README does not yet document Symbol as a str subclass with immutability")

(fact readme-documents-frozen-dataclasses false
    :origin "README does not yet document that Evidence, Axiom, Theorem, Term are frozen dataclasses")

(fact readme-documents-tokenizer false
    :origin "README does not yet document tokenize() (splits source into tokens, ; comments)")

(fact readme-documents-reader false
    :origin "README does not yet document read_tokens() (recursive parse of token list into nested structures)")

(fact readme-documents-parse-api false
    :origin "README does not yet document parse() and parse_all() public s-expression parsing API")

(fact readme-documents-to-sexp false
    :origin "README does not yet document to_sexp() (pretty-print back to s-expression string, bool roundtrip)")

(fact readme-documents-match-substitute false
    :origin "README does not yet document match() and substitute() pattern matching with ?-variables and free_vars()")

(fact readme-documents-grounding-rule false
    :origin "README does not yet document evidence grounding rule (grounded = verified OR manually-verified)")

; =====================================================================
; Count mismatches — README stale values
; =====================================================================

(fact readme-demo-count-stale false
    :origin "README says 11 demos but actual count is 12 — missing 12th demo listing")

(fact readme-effect-count-stale false
    :origin "README says 7 built-in effects but actual count is 8 — missing dangerously-eval")

; =====================================================================
; Internal consistency — non-tautological diffs only
; =====================================================================
; README exports expectations for core.pltg to consume cross-module.
; Here we only prove internal consistency: stated counts vs listed items,
; and paired coverage (listing + description for same item).
; Most readme facts are correctly dangling — they're consumed externally.

; --- 1. Directive count vs listing ---
; README says "6 directive types" and lists them individually.

(derive readme-directive-listing-count
    (count-exists readme-has-fact-directive readme-has-axiom-directive
                  readme-has-defterm-directive readme-has-derive-directive readme-has-diff-directive
                  readme-has-evidence-directive)
    :using (count-exists readme-has-fact-directive readme-has-axiom-directive
                         readme-has-defterm-directive readme-has-derive-directive readme-has-diff-directive
                         readme-has-evidence-directive))

(diff readme-directive-listing-vs-stated :replace readme-directive-listing-count :with readme-directive-count)

; --- 2. Directive paired coverage ---
; Each directive has BOTH a listing fact AND a description fact.

(derive readme-directive-paired-count
    (count-exists (and readme-has-fact-directive readme-fact-description)
                  (and readme-has-axiom-directive readme-axiom-description)
                  (and readme-has-defterm-directive readme-defterm-forward-decl readme-defterm-computed)
                  (and readme-has-derive-directive readme-derive-restricted-eval)
                  (and readme-has-diff-directive readme-diff-lazy readme-documents-diffs-section))
    :using (count-exists
            readme-has-fact-directive readme-fact-description
            readme-has-axiom-directive readme-axiom-description
            readme-has-defterm-directive readme-defterm-forward-decl readme-defterm-computed
            readme-has-derive-directive readme-derive-restricted-eval
            readme-has-diff-directive readme-diff-lazy readme-documents-diffs-section))

(diff readme-directive-paired-vs-listing :replace readme-directive-paired-count :with readme-directive-listing-count)

; --- 3. Demo count vs listing ---
; README says "11 demos" and lists them individually.

(derive readme-demo-listing-count
    (count-exists readme-demo-apples readme-demo-apples-pltg readme-demo-revenue
                  readme-demo-biomarkers readme-demo-code-check readme-demo-doc-validation
                  readme-demo-spec-validation readme-demo-extensibility readme-demo-self-healing
                  readme-demo-deferred readme-demo-entry-mocks)
    :using (count-exists readme-demo-apples readme-demo-apples-pltg readme-demo-revenue
                         readme-demo-biomarkers readme-demo-code-check readme-demo-doc-validation
                         readme-demo-spec-validation readme-demo-extensibility readme-demo-self-healing
                         readme-demo-deferred readme-demo-entry-mocks))

(diff readme-demo-listing-vs-count :replace readme-demo-listing-count :with readme-demo-count)

; --- 4. Loader effect count vs listing ---
; README says "7 built-in effects" and lists them individually.

(derive readme-loader-effects-listing-count
    (count-exists readme-loader-import-effect readme-loader-run-on-entry-effect
                  readme-loader-load-document-effect readme-loader-context-effect
                  readme-loader-print-effect readme-loader-consistency-effect
                  readme-loader-verify-manual-effect)
    :using (count-exists readme-loader-import-effect readme-loader-run-on-entry-effect
                         readme-loader-load-document-effect readme-loader-context-effect
                         readme-loader-print-effect readme-loader-consistency-effect
                         readme-loader-verify-manual-effect))

(diff readme-loader-effects-vs-count :replace readme-loader-effects-listing-count :with readme-loader-effect-count)
