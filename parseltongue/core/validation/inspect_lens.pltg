; Lens navigation could be expressed as S-expressions:
; - (focus "engine.") (find "count") (view-node "name")
; - Compose lens operations: (pipe (focus "engine.") (filter kind "diff"))
; - Structural queries: (upstream "name" 3) (downstream "name")
; The Lens already has the data model — it needs a System wiring
; similar to how SearchSystem maps operators to posting-set functions.
(derive stub-todo-lens-language-system stub :using (stub))

