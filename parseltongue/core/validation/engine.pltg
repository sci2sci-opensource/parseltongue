; engine.pltg — Ground truth and internal validation for engine.py

(load-document "engine.py" "../engine.py")
(import (quote ..std.counting))
(import (quote ..std.epistemics))
(import (quote ..std.lists))
(import (quote lang))
(import (quote ..std.util))
(defterm count-exists counting.count-exists :origin "import")

; =====================================================================
; Module docstring vs class docstring
; =====================================================================

; Layer 1: DOC — module docstring documents 3 doc-mgmt features
(fact doc-claims-registration true
    :evidence (evidence "engine.py"
        :quotes ("direct registration")
        :explanation "Module docstring claims direct registration"))

(fact doc-claims-loading true
    :evidence (evidence "engine.py"
        :quotes ("loading from files")
        :explanation "Module docstring claims loading from files"))

(fact doc-claims-indexing true
    :evidence (evidence "engine.py"
        :quotes ("ground-truth indexing for evidence verification")
        :explanation "Module docstring claims ground-truth indexing"))

; Layer 2: IMPL — engine implements 3 doc-mgmt features
(fact engine-has-register-document true
    :evidence (evidence "engine.py"
        :quotes ("def register_document(self, name: str, text: str):")
        :explanation "Engine has register_document method"))

(fact engine-has-load-document true
    :evidence (evidence "engine.py"
        :quotes ("def load_document(self, name: str, path: str):")
        :explanation "Engine has load_document method"))

(fact engine-has-verifier-index true
    :evidence (evidence "engine.py"
        :quotes ("self._verifier.index.add(name, text)")
        :explanation "Documents are added to verifier index for evidence checking"))

; Per-layer counts
(derive doc-mgmt-doc-count
    (count-exists doc-claims-registration doc-claims-loading doc-claims-indexing)
    :using (count-exists doc-claims-registration doc-claims-loading doc-claims-indexing))

(derive doc-mgmt-impl-count
    (count-exists engine-has-register-document engine-has-load-document engine-has-verifier-index)
    :using (count-exists engine-has-register-document engine-has-load-document engine-has-verifier-index))

; Paired: each doc claim matched with its impl counterpart
(derive doc-mgmt-paired-count
    (count-exists (and doc-claims-registration engine-has-register-document)
                  (and doc-claims-loading engine-has-load-document)
                  (and doc-claims-indexing engine-has-verifier-index))
    :using (count-exists
            doc-claims-registration engine-has-register-document
            doc-claims-loading engine-has-load-document
            doc-claims-indexing engine-has-verifier-index))

; Cross-layer diffs — all 3 must agree
(diff doc-mgmt-paired-vs-doc :replace doc-mgmt-paired-count :with doc-mgmt-doc-count)
(diff doc-mgmt-paired-vs-impl :replace doc-mgmt-paired-count :with doc-mgmt-impl-count)

; =====================================================================
; Fact class
; =====================================================================

(fact fact-extends-axiom true
    :evidence (evidence "engine.py"
        :quotes ("class Fact(Axiom):")
        :explanation "Fact subclasses Axiom"))

(fact fact-docstring "A fact: non-parametric axiom"
    :evidence (evidence "engine.py"
        :quotes ("A fact: non-parametric axiom")
        :explanation "Fact docstring — it's a ground truth axiom"))

; =====================================================================
; Engine constructor defaults
; =====================================================================

(fact overridable-default false
    :evidence (evidence "engine.py"
        :quotes ("overridable: bool = False")
        :explanation "Overridable defaults to False"))

(fact strict-derive-default true
    :evidence (evidence "engine.py"
        :quotes ("strict_derive: bool = True")
        :explanation "Strict derive defaults to True"))

; =====================================================================
; Evaluation
; =====================================================================

(fact rewrite-depth-limit 100
    :evidence (evidence "engine.py"
        :quotes ("if depth > 100:")
        :explanation "Rewrite recursion limit is 100"))

(fact eval-doc "Evaluate an s-expression in the current system."
    :evidence (evidence "engine.py"
        :quotes ("Evaluate an s-expression in the current system.")
        :explanation "evaluate docstring"))

; Rewrite uses axioms as left-to-right rules
(fact rewrite-direction "left-to-right"
    :evidence (evidence "engine.py"
        :quotes ("Axioms of the form (= LHS RHS) are used left-to-right")
        :explanation "Rewrite direction documented"))

; EQ fallback: when structural comparison fails on formal expressions,
; engine tries rewriting both sides and comparing results
(fact eq-has-rewrite-fallback true
    :evidence (evidence "engine.py"
        :quotes ("if result is False and head == EQ and any(isinstance(a, list) for a in args):")
        :explanation "EQ comparison has a rewrite fallback path"))

; =====================================================================
; Derivation
; =====================================================================

(fact derive-doc "Derive a theorem from existing axioms/terms."
    :evidence (evidence "engine.py"
        :quotes ("Derive a theorem from existing axioms/terms.")
        :explanation "derive docstring"))

(fact derive-restricted-eval true
    :evidence (evidence "engine.py"
        :quotes ("Evaluation is restricted to facts/terms listed in :using.")
        :explanation "Derivation uses restricted environment"))

(fact derive-fabrication-propagation true
    :evidence (evidence "engine.py"
        :quotes ("If any source has unverified evidence, the theorem is")
        :explanation "Fabrication propagation documented"))

; Axiom introduction: requires free variables
(fact axiom-requires-free-vars true
    :evidence (evidence "engine.py"
        :quotes ("if not free_vars(wff):")
        :explanation "introduce_axiom rejects ground axioms"))

(fact axiom-rejection-message "Axiom"
    :evidence (evidence "engine.py"
        :quotes ("Axiom" "has no ?-variables")
        :explanation "Error message mentions missing ?-variables"))

; =====================================================================
; Consistency checking
; =====================================================================

(fact consistency-doc "Check full consistency state of the system."
    :evidence (evidence "engine.py"
        :quotes ("Check full consistency state of the system.")
        :explanation "consistency docstring"))

(fact consistency-layer-1 "Evidence grounding"
    :evidence (evidence "engine.py"
        :quotes ("1. Evidence grounding")
        :explanation "First consistency layer"))

(fact consistency-layer-2 "Fabrication propagation"
    :evidence (evidence "engine.py"
        :quotes ("2. Fabrication propagation")
        :explanation "Second consistency layer"))

(fact consistency-layer-3 "Diff agreement"
    :evidence (evidence "engine.py"
        :quotes ("3. Diff agreement")
        :explanation "Third consistency layer"))

(derive consistency-layer-count
    (count-exists consistency-layer-1 consistency-layer-2 consistency-layer-3)
    :using (count-exists counting.count-exists-base counting.count-exists-step
            consistency-layer-1 consistency-layer-2 consistency-layer-3))

; Issue type strings — exactly what the code creates
(fact issue-type-unverified "unverified_evidence"
    :evidence (evidence "engine.py"
        :quotes ("UNVERIFIED_EVIDENCE = \"unverified_evidence\"" "ConsistencyIssue(IssueType.UNVERIFIED_EVIDENCE")
        :explanation "Issue type for unverified evidence"))

(fact issue-type-no-evidence "no_evidence"
    :evidence (evidence "engine.py"
        :quotes ("NO_EVIDENCE = \"no_evidence\"" "ConsistencyIssue(IssueType.NO_EVIDENCE")
        :explanation "Issue type for missing evidence"))

(fact issue-type-fabrication "potential_fabrication"
    :evidence (evidence "engine.py"
        :quotes ("POTENTIAL_FABRICATION = \"potential_fabrication\"" "ConsistencyIssue(IssueType.POTENTIAL_FABRICATION")
        :explanation "Issue type for fabrication"))

(fact issue-type-diff-divergence "diff_divergence"
    :evidence (evidence "engine.py"
        :quotes ("DIFF_DIVERGENCE = \"diff_divergence\"" "ConsistencyIssue(IssueType.DIFF_DIVERGENCE")
        :explanation "Issue type for diff divergence"))

(fact issue-type-diff-value "diff_value_divergence"
    :evidence (evidence "engine.py"
        :quotes ("DIFF_VALUE_DIVERGENCE = \"diff_value_divergence\"" "ConsistencyIssue(IssueType.DIFF_VALUE_DIVERGENCE")
        :explanation "Issue type for diff value divergence"))

; =====================================================================
; Retract / rederive
; =====================================================================

(fact retract-doc "Remove a fact, axiom, term, theorem, or diff from the system."
    :evidence (evidence "engine.py"
        :quotes ("Remove a fact, axiom, term, theorem, or diff from the system.")
        :explanation "retract docstring"))

(fact retract-handles-theorems true
    :evidence (evidence "engine.py"
        :quotes ("if name in self.theorems:")
        :explanation "retract also handles theorems"))

(fact retract-doc-mentions-theorems true
    :evidence (evidence "engine.py"
        :quotes ("Remove a fact, axiom, term, theorem, or diff")
        :explanation "retract docstring includes theorem"))

; Verify docstring and implementation agree on theorem support
(diff retract-doc-vs-impl
    :replace retract-doc-mentions-theorems
    :with retract-handles-theorems)

(fact rederive-doc "Re-run a derivation to refresh its fabrication status."
    :evidence (evidence "engine.py"
        :quotes ("Re-run a derivation to refresh its fabrication status.")
        :explanation "rederive docstring"))

; =====================================================================
; Diff mechanism
; =====================================================================

(fact register-diff-doc "Register a diff — a lazy comparison between two symbols."
    :evidence (evidence "engine.py"
        :quotes ("Register a diff")
        :explanation "register_diff docstring"))

(fact diff-is-lazy true
    :evidence (evidence "engine.py"
        :quotes ("Stores only the parameters. The result is computed fresh on")
        :explanation "Diffs are lazy — computed on access"))

(fact eval-diff-doc "Evaluate a registered diff against current system state."
    :evidence (evidence "engine.py"
        :quotes ("Evaluate a registered diff against current system state.")
        :explanation "eval_diff docstring"))

; =====================================================================
; set_fact — overridable behavior
; =====================================================================

(fact set-fact-checks-overridable true
    :evidence (evidence "engine.py"
        :quotes ("if not self.overridable:")
        :explanation "set_fact checks overridable before allowing override"))

(fact set-fact-error-on-duplicate "Fact"
    :evidence (evidence "engine.py"
        :quotes ("Fact" "already exists. Use retract() first, or create System(overridable=True)")
        :explanation "Error message suggests retract or overridable"))

; Derive: set_fact both stores in facts dict AND puts value in env
(fact set-fact-updates-env true
    :evidence (evidence "engine.py"
        :quotes ("self.env[Symbol(name)] = value")
        :explanation "set_fact pushes value into evaluation env"))

; =====================================================================
; DSL loader
; =====================================================================

(fact load-source-handles-axiom true
    :evidence (evidence "engine.py"
        :quotes ("if head == AXIOM:")
        :explanation "Loader handles axiom directive"))

(fact load-source-handles-defterm true
    :evidence (evidence "engine.py"
        :quotes ("elif head == DEFTERM:")
        :explanation "Loader handles defterm directive"))

(fact load-source-handles-fact true
    :evidence (evidence "engine.py"
        :quotes ("elif head == FACT:")
        :explanation "Loader handles fact directive"))

(fact load-source-handles-derive true
    :evidence (evidence "engine.py"
        :quotes ("elif head == DERIVE:")
        :explanation "Loader handles derive directive"))

(fact load-source-handles-diff true
    :evidence (evidence "engine.py"
        :quotes ("elif head == DIFF:")
        :explanation "Loader handles diff directive"))

; Fallback: unknown directives are evaluated as expressions
(fact load-source-fallback-evaluates true
    :evidence (evidence "engine.py"
        :quotes ("engine.evaluate(expr)")
        :explanation "Unknown directives fall through to evaluate"))

; =====================================================================
; Code vs Docs — two-branch-then-diff
; =====================================================================

; --- 1. Consistency layers ---

(derive consistency-layers-doc-count
    (count-exists consistency-layer-1 consistency-layer-2 consistency-layer-3)
    :using (count-exists counting.count-exists-base counting.count-exists-step
            consistency-layer-1 consistency-layer-2 consistency-layer-3))

(diff consistency-layers-coverage
    :replace consistency-layers-doc-count
    :with consistency-layer-count)

; consistency-doc: docs say method exists, code confirms
(derive consistency-has-docstring
    (count-exists consistency-doc)
    :using (count-exists counting.count-exists-base
            consistency-doc))

(defterm consistency-has-impl 1
    :evidence (evidence "engine.py"
        :quotes ("def consistency(self, suppress_log: bool = True) -> ConsistencyReport:")
        :explanation "consistency method exists in source"))

(diff consistency-method-documented
    :replace consistency-has-docstring
    :with consistency-has-impl)

; --- 2. Issue types ---

(derive issue-types-doc-count
    (count-exists issue-type-unverified issue-type-no-evidence issue-type-fabrication issue-type-diff-divergence issue-type-diff-value)
    :using (count-exists counting.count-exists-base counting.count-exists-step
            issue-type-unverified issue-type-no-evidence issue-type-fabrication issue-type-diff-divergence issue-type-diff-value))

(defterm issue-types-impl-count 5
    :evidence (evidence "engine.py"
        :quotes ("UNVERIFIED_EVIDENCE = \"unverified_evidence\"" "NO_EVIDENCE = \"no_evidence\"" "POTENTIAL_FABRICATION = \"potential_fabrication\"" "DIFF_DIVERGENCE = \"diff_divergence\"" "DIFF_VALUE_DIVERGENCE = \"diff_value_divergence\"")
        :explanation "5 issue types in source"))

(diff issue-types-coverage
    :replace issue-types-doc-count
    :with issue-types-impl-count)

; --- 3. Directive loader ---

(derive directive-loader-doc-count
    (count-exists load-source-handles-axiom load-source-handles-defterm load-source-handles-fact load-source-handles-derive load-source-handles-diff load-source-fallback-evaluates)
    :using (count-exists counting.count-exists-base counting.count-exists-step
            load-source-handles-axiom load-source-handles-defterm load-source-handles-fact load-source-handles-derive load-source-handles-diff load-source-fallback-evaluates))

(defterm directive-loader-impl-count 6
    :evidence (evidence "engine.py"
        :quotes ("if head == AXIOM:" "elif head == DEFTERM:" "elif head == FACT:" "elif head == DERIVE:" "elif head == DIFF:" "engine.evaluate(expr)")
        :explanation "6 directive handler branches in source"))

(diff directive-loader-coverage
    :replace directive-loader-doc-count
    :with directive-loader-impl-count)

; --- 4. Evaluation mechanism ---

(derive eval-mechanism-doc-count
    (count-exists eval-doc rewrite-direction rewrite-depth-limit eq-has-rewrite-fallback)
    :using (count-exists counting.count-exists-base counting.count-exists-step
            eval-doc rewrite-direction rewrite-depth-limit eq-has-rewrite-fallback))

(defterm eval-mechanism-impl-count 4
    :evidence (evidence "engine.py"
        :quotes ("def evaluate(" "Axioms of the form (= LHS RHS) are used left-to-right" "if depth > 100:" "if result is False and head == EQ")
        :explanation "4 evaluation features in source"))

(diff eval-mechanism-coverage
    :replace eval-mechanism-doc-count
    :with eval-mechanism-impl-count)

; --- 5. Derivation mechanism ---

(derive derivation-doc-count
    (count-exists derive-doc derive-restricted-eval derive-fabrication-propagation axiom-requires-free-vars axiom-rejection-message)
    :using (count-exists counting.count-exists-base counting.count-exists-step
            derive-doc derive-restricted-eval derive-fabrication-propagation axiom-requires-free-vars axiom-rejection-message))

(defterm derivation-impl-count 5
    :evidence (evidence "engine.py"
        :quotes ("def derive(" "Evaluation is restricted to facts/terms listed in :using." "If any source has unverified evidence, the theorem is" "if not free_vars(wff):" "has no ?-variables")
        :explanation "5 derivation features in source"))

(diff derivation-mechanism-coverage
    :replace derivation-doc-count
    :with derivation-impl-count)

; --- 6. Diff mechanism ---

(derive diff-mechanism-doc-count
    (count-exists register-diff-doc eval-diff-doc diff-is-lazy)
    :using (count-exists counting.count-exists-base counting.count-exists-step
            register-diff-doc eval-diff-doc diff-is-lazy))

(defterm diff-mechanism-impl-count 3
    :evidence (evidence "engine.py"
        :quotes ("def register_diff(" "def eval_diff(" "Stores only the parameters. The result is computed fresh on")
        :explanation "3 diff features in source"))

(diff diff-mechanism-coverage
    :replace diff-mechanism-doc-count
    :with diff-mechanism-impl-count)

; --- 7. Fact/set_fact mechanism ---

(derive fact-mechanism-doc-count
    (count-exists fact-docstring fact-extends-axiom set-fact-checks-overridable set-fact-error-on-duplicate set-fact-updates-env)
    :using (count-exists counting.count-exists-base counting.count-exists-step
            fact-docstring fact-extends-axiom set-fact-checks-overridable set-fact-error-on-duplicate set-fact-updates-env))

(defterm fact-mechanism-impl-count 5
    :evidence (evidence "engine.py"
        :quotes ("class Fact(Axiom):" "A fact: non-parametric axiom" "if not self.overridable:" "already exists. Use retract() first" "self.env[Symbol(name)] = value")
        :explanation "5 fact mechanism features in source"))

(diff fact-mechanism-coverage
    :replace fact-mechanism-doc-count
    :with fact-mechanism-impl-count)

; --- 8. Retract/rederive lifecycle ---

(derive lifecycle-doc-count
    (count-exists retract-doc rederive-doc)
    :using (count-exists counting.count-exists-base counting.count-exists-step
            retract-doc rederive-doc))

(defterm lifecycle-impl-count 2
    :evidence (evidence "engine.py"
        :quotes ("def retract(" "def rederive(")
        :explanation "2 lifecycle methods in source"))

(diff lifecycle-coverage
    :replace lifecycle-doc-count
    :with lifecycle-impl-count)

; --- 9. Constructor defaults ---

(derive defaults-doc-count
    (count-exists (= overridable-default false) strict-derive-default)
    :using (count-exists counting.count-exists-base counting.count-exists-step
            overridable-default strict-derive-default))

(defterm defaults-impl-count 2
    :evidence (evidence "engine.py"
        :quotes ("overridable: bool = False" "strict_derive: bool = True")
        :explanation "2 constructor defaults in source"))

(diff defaults-coverage
    :replace defaults-doc-count
    :with defaults-impl-count)

; =====================================================================
; Cross-module proofs — lang axioms proved by engine code
; =====================================================================

; --- evidence-attachable: fact/axiom/defterm call _resolve_origin ---

(fact fact-calls-resolve-origin true
    :evidence (evidence "engine.py"
        :quotes ("engine.set_fact(str(expr[1]), expr[2], _resolve_origin(expr))")
        :explanation "fact directive calls _resolve_origin"))

(fact axiom-calls-resolve-origin true
    :evidence (evidence "engine.py"
        :quotes ("engine.introduce_axiom(name, wff, _resolve_origin(expr))")
        :explanation "axiom directive calls _resolve_origin"))

(fact defterm-calls-resolve-origin true
    :evidence (evidence "engine.py"
        :quotes ("engine.introduce_term(name, defn, _resolve_origin(expr))")
        :explanation "defterm directive calls _resolve_origin"))

; _resolve_origin checks :evidence keyword
(fact resolve-origin-checks-evidence true
    :evidence (evidence "engine.py"
        :quotes ("evidence_raw = get_keyword(expr, KW_EVIDENCE, None)\n    if evidence_raw is not None:\n        return parse_evidence(evidence_raw)")
        :explanation "_resolve_origin checks for :evidence keyword"))

; _resolve_origin checks :origin keyword
(fact resolve-origin-checks-origin true
    :evidence (evidence "engine.py"
        :quotes ("return get_keyword(expr, KW_ORIGIN, \"unknown\")")
        :explanation "_resolve_origin falls back to :origin keyword"))

; _resolve_origin handles both paths
(fact resolve-origin-checks-both true
    :evidence (evidence "engine.py"
        :quotes ("def _resolve_origin(expr) -> \"str | Evidence\":\n    evidence_raw = get_keyword(expr, KW_EVIDENCE, None)\n    if evidence_raw is not None:\n        return parse_evidence(evidence_raw)\n    return get_keyword(expr, KW_ORIGIN, \"unknown\")")
        :explanation "_resolve_origin tries :evidence first, falls back to :origin"))

(derive bound-evidence-attachable lang.evidence-attachable
    :bind ((?is-fact fact-calls-resolve-origin)
           (?is-axiom axiom-calls-resolve-origin)
           (?is-defterm defterm-calls-resolve-origin)
           (?has-origin-attached resolve-origin-checks-origin)
           (?has-evidence-attached resolve-origin-checks-evidence)
           (?has-origin-or-evidence resolve-origin-checks-both))
    :using (lang.evidence-attachable
            fact-calls-resolve-origin axiom-calls-resolve-origin defterm-calls-resolve-origin
            resolve-origin-checks-origin resolve-origin-checks-evidence resolve-origin-checks-both))

; --- derive-inherits-grounding: derive checks sources and propagates ---

(fact derive-checks-sources true
    :evidence (evidence "engine.py"
        :quotes ("ungrounded = self._check_sources_grounded(using)\n        issues = []\n        if does_not_hold:\n            issues.append(\"does not hold (evaluated to False)\")\n        if ungrounded:\n            issues.append(f\"derived from unverified: {', '.join(ungrounded)}\")")
        :explanation "derive method checks source grounding and propagates fabrication"))

(derive bound-derive-inherits lang.derive-inherits-grounding
    :bind ((?is-derive lang.doc-directive-derive)
           (?proven-by-sources derive-checks-sources))
    :using (lang.derive-inherits-grounding lang.doc-directive-derive derive-checks-sources))

; --- diff-no-evidence: diffs are structural, consistency evaluates them live ---

(fact diff-evaluated-structurally true
    :evidence (evidence "engine.py"
        :quotes ("all_diffs = sorted((self.eval_diff(n) for n in self.diffs), key=lambda d: d.name)" "downstream_divergent = [d for d in all_diffs if not d.empty and not d.diff_contamination_only]" "value_divergent = [d for d in all_diffs if d.values_diverge and d.empty]")
        :explanation "Consistency evaluates diffs structurally — divergence is a system issue"))

(defterm diff-calls-resolve-origin false
    :evidence (evidence "engine.py"
        :quotes ("engine.register_diff(str(expr[1]), str(get_keyword(expr, KW_REPLACE)), str(get_keyword(expr, KW_WITH)))")
        :explanation "diff handler calls register_diff directly — no _resolve_origin, no evidence attachment"))

(derive bound-diff-no-evidence lang.diff-no-evidence
    :bind ((?is-diff load-source-handles-diff)
           (?is-inconsistency-indicator diff-evaluated-structurally)
           (?needs-evidence diff-calls-resolve-origin))
    :using (lang.diff-no-evidence load-source-handles-diff diff-evaluated-structurally diff-calls-resolve-origin))

; =====================================================================
; _expr_references — static symbol search
; =====================================================================

(fact expr-references-is-static true
    :evidence (evidence "engine.py"
        :quotes ("@staticmethod\n    def _expr_references(expr, name: str) -> bool:\n        \"\"\"Check if an expression tree contains a Symbol matching name.\"\"\"")
        :explanation "_expr_references is a static method for recursive symbol search"))

(fact expr-references-checks-symbol true
    :evidence (evidence "engine.py"
        :quotes ("if isinstance(expr, Symbol):\n            return str(expr) == name")
        :explanation "_expr_references matches Symbol by string equality"))

(fact expr-references-recurses-lists true
    :evidence (evidence "engine.py"
        :quotes ("return any(Engine._expr_references(sub, name) for sub in expr)")
        :explanation "_expr_references recurses into list expressions via Engine static call"))

; =====================================================================
; _dependents — cross-type dependency tracking (Items × Layers)
; =====================================================================

; Layer 1: IMPL — what _dependents actually scans in _all_named_exprs
(fact dependents-scans-terms true
    :evidence (evidence "engine.py"
        :quotes ("for n, t in self.terms.items():\n                yield n, \"term\", t.definition")
        :explanation "_dependents scans term definitions"))

(fact dependents-scans-facts true
    :evidence (evidence "engine.py"
        :quotes ("for n, f in self.facts.items():\n                yield n, \"fact\", f.wff")
        :explanation "_dependents scans fact WFFs"))

(fact dependents-scans-axioms true
    :evidence (evidence "engine.py"
        :quotes ("for n, a in self.axioms.items():\n                yield n, \"axiom\", a.wff")
        :explanation "_dependents scans axiom WFFs"))

(fact dependents-scans-theorems true
    :evidence (evidence "engine.py"
        :quotes ("for n, th in self.theorems.items():\n                yield n, \"theorem\", th.wff")
        :explanation "_dependents scans theorem WFFs"))

(fact dependents-scans-diffs true
    :evidence (evidence "engine.py"
        :quotes ("for n, d in self.diffs.items():\n                if n != exclude_diff:\n                    yield n, \"diff\", [Symbol(d[\"replace\"]), Symbol(d[\"with\"])]")
        :explanation "_dependents scans diff replace/with references, excluding calling diff"))

; Layer 2: DOC — what the docstring claims _dependents covers
(fact dependents-doc-term true
    :evidence (evidence "engine.py"
        :quotes ("Returns a list of (name, kind) tuples where kind is one of\n        'term', 'fact', 'axiom', 'theorem', or 'diff'.")
        :explanation "Docstring lists term as a tracked kind"))

(fact dependents-doc-fact true
    :evidence (evidence "engine.py"
        :quotes ("Returns a list of (name, kind) tuples where kind is one of\n        'term', 'fact', 'axiom', 'theorem', or 'diff'.")
        :explanation "Docstring lists fact as a tracked kind"))

(fact dependents-doc-axiom true
    :evidence (evidence "engine.py"
        :quotes ("Returns a list of (name, kind) tuples where kind is one of\n        'term', 'fact', 'axiom', 'theorem', or 'diff'.")
        :explanation "Docstring lists axiom as a tracked kind"))

(fact dependents-doc-theorem true
    :evidence (evidence "engine.py"
        :quotes ("Returns a list of (name, kind) tuples where kind is one of\n        'term', 'fact', 'axiom', 'theorem', or 'diff'.")
        :explanation "Docstring lists theorem as a tracked kind"))

(fact dependents-doc-diff true
    :evidence (evidence "engine.py"
        :quotes ("Returns a list of (name, kind) tuples where kind is one of\n        'term', 'fact', 'axiom', 'theorem', or 'diff'.")
        :explanation "Docstring lists diff as a tracked kind"))

; Per-layer counts
(derive dependents-impl-count
    (count-exists dependents-scans-terms dependents-scans-facts dependents-scans-axioms dependents-scans-theorems dependents-scans-diffs)
    :using (count-exists counting.count-exists-base counting.count-exists-step
            dependents-scans-terms dependents-scans-facts dependents-scans-axioms dependents-scans-theorems dependents-scans-diffs))

(derive dependents-doc-count
    (count-exists dependents-doc-term dependents-doc-fact dependents-doc-axiom dependents-doc-theorem dependents-doc-diff)
    :using (count-exists counting.count-exists-base counting.count-exists-step
            dependents-doc-term dependents-doc-fact dependents-doc-axiom dependents-doc-theorem dependents-doc-diff))

; Paired: each doc claim matched with its impl
(derive dependents-paired-count
    (count-exists (and dependents-doc-term dependents-scans-terms)
                  (and dependents-doc-fact dependents-scans-facts)
                  (and dependents-doc-axiom dependents-scans-axioms)
                  (and dependents-doc-theorem dependents-scans-theorems)
                  (and dependents-doc-diff dependents-scans-diffs))
    :using (count-exists
            dependents-doc-term dependents-scans-terms
            dependents-doc-fact dependents-scans-facts
            dependents-doc-axiom dependents-scans-axioms
            dependents-doc-theorem dependents-scans-theorems
            dependents-doc-diff dependents-scans-diffs))

; Cross-layer diffs
(diff dependents-paired-vs-doc :replace dependents-paired-count :with dependents-doc-count)
(diff dependents-paired-vs-impl :replace dependents-paired-count :with dependents-impl-count)

; Behavioral properties
(fact dependents-checks-derivation-list true
    :evidence (evidence "engine.py"
        :quotes ("if kind == \"theorem\" and name_to_find in self.theorems[n].derivation:\n                return True")
        :explanation "_dependents also checks theorem .derivation lists for contamination"))

(fact dependents-is-transitive true
    :evidence (evidence "engine.py"
        :quotes ("while frontier:\n            result |= frontier\n            frontier_names = {n for n, _ in frontier}\n            next_frontier: set[tuple[str, str]] = set()")
        :explanation "_dependents expands transitively until no new dependents found"))

; =====================================================================
; eval_diff — contamination detection
; =====================================================================

(fact eval-diff-handles-theorem-contamination true
    :evidence (evidence "engine.py"
        :quotes ("if (\n                dep_kind == \"theorem\"\n                and not self._expr_references(defn, replace)\n                and replace in self.theorems[dep_name].derivation\n            ):\n                divergences[dep_name] = [defn, f\"<contaminated: uses {replace}>\"]")
        :explanation "eval_diff flags theorems whose WFF is a literal but whose derivation used the replaced symbol"))

(fact eval-diff-handles-diff-contamination true
    :evidence (evidence "engine.py"
        :quotes ("elif dep_kind == \"diff\":\n                # The dependent diff references the replaced symbol\n                # in its :replace or :with — flag as contaminated.\n                dep_params = self.diffs[dep_name]\n                divergences[dep_name] = [\n                    f\"diff({dep_params['replace']} vs {dep_params['with']})\",\n                    f\"<contaminated: references {replace}>\",\n                ]")
        :explanation "eval_diff flags dependent diffs that reference the replaced symbol"))

(fact eval-diff-excludes-self true
    :evidence (evidence "engine.py"
        :quotes ("affected = self._dependents(replace, exclude_diff=name)")
        :explanation "eval_diff excludes its own diff from the dependency scan"))

; Layer 1: DOC — eval_diff docstring documents contamination
(fact eval-diff-doc-transitive true
    :evidence (evidence "engine.py"
        :quotes ("Transitively scans dependencies via _dependents, following not\n        just direct references but also theorem derivation chains.")
        :explanation "eval_diff docstring documents transitive scanning"))

(fact eval-diff-doc-follows-derivation-chains true
    :evidence (evidence "engine.py"
        :quotes ("following not\n        just direct references but also theorem derivation chains.")
        :explanation "eval_diff docstring documents derivation chain following"))

(fact eval-diff-doc-theorem-contamination true
    :evidence (evidence "engine.py"
        :quotes ("Theorems whose derivation\n        chain used the replaced symbol — even when their WFF is a literal\n        — are flagged as contaminated.")
        :explanation "eval_diff docstring documents theorem contamination"))

(fact eval-diff-doc-diff-contamination true
    :evidence (evidence "engine.py"
        :quotes ("Dependent diffs that reference the replaced\n        symbol are flagged as contaminated.")
        :explanation "eval_diff docstring documents diff contamination"))

(fact eval-diff-doc-excludes-self true
    :evidence (evidence "engine.py"
        :quotes ("Excludes itself from its own dependency scan to avoid circular\n        self-contamination.")
        :explanation "eval_diff docstring documents self-exclusion"))

; Layer 2: IMPL — each behavior in source
(fact eval-diff-impl-transitive true
    :evidence (evidence "engine.py"
        :quotes ("affected = self._dependents(replace, exclude_diff=name)")
        :explanation "eval_diff delegates to _dependents which scans transitively"))

(fact eval-diff-impl-follows-derivation-chains true
    :evidence (evidence "engine.py"
        :quotes ("affected = self._dependents(replace, exclude_diff=name)")
        :explanation "eval_diff delegates to _dependents which checks theorem derivation lists"))

(fact eval-diff-impl-theorem-contamination true
    :evidence (evidence "engine.py"
        :quotes ("# For theorems found via .derivation whose WFF is already\n            # evaluated to a literal: substitution into the WFF won't\n            # change anything, but the derivation *used* the replaced\n            # symbol so the result is contaminated.  Flag as divergent\n            # since re-derivation with different input could change\n            # the outcome.\n            if (\n                dep_kind == \"theorem\"\n                and not self._expr_references(defn, replace)\n                and replace in self.theorems[dep_name].derivation\n            ):\n                divergences[dep_name] = [defn, f\"<contaminated: uses {replace}>\"]")
        :explanation "Theorem contamination detection block in eval_diff"))

(fact eval-diff-impl-diff-contamination true
    :evidence (evidence "engine.py"
        :quotes ("elif dep_kind == \"diff\":\n                # The dependent diff references the replaced symbol\n                # in its :replace or :with — flag as contaminated.\n                dep_params = self.diffs[dep_name]\n                divergences[dep_name] = [\n                    f\"diff({dep_params['replace']} vs {dep_params['with']})\",\n                    f\"<contaminated: references {replace}>\",\n                ]")
        :explanation "Diff contamination detection block in eval_diff"))

(fact eval-diff-impl-excludes-self true
    :evidence (evidence "engine.py"
        :quotes ("affected = self._dependents(replace, exclude_diff=name)")
        :explanation "eval_diff passes its own name as exclude_diff"))

; Per-layer counts
(derive eval-diff-contamination-doc-count
    (count-exists eval-diff-doc-transitive eval-diff-doc-follows-derivation-chains
                  eval-diff-doc-theorem-contamination eval-diff-doc-diff-contamination eval-diff-doc-excludes-self)
    :using (count-exists counting.count-exists-base counting.count-exists-step
            eval-diff-doc-transitive eval-diff-doc-follows-derivation-chains
            eval-diff-doc-theorem-contamination eval-diff-doc-diff-contamination eval-diff-doc-excludes-self))

(derive eval-diff-contamination-impl-count
    (count-exists eval-diff-impl-transitive eval-diff-impl-follows-derivation-chains
                  eval-diff-impl-theorem-contamination eval-diff-impl-diff-contamination eval-diff-impl-excludes-self)
    :using (count-exists counting.count-exists-base counting.count-exists-step
            eval-diff-impl-transitive eval-diff-impl-follows-derivation-chains
            eval-diff-impl-theorem-contamination eval-diff-impl-diff-contamination eval-diff-impl-excludes-self))

; Paired: doc × impl
(derive eval-diff-contamination-paired
    (count-exists (and eval-diff-doc-transitive eval-diff-impl-transitive)
                  (and eval-diff-doc-follows-derivation-chains eval-diff-impl-follows-derivation-chains)
                  (and eval-diff-doc-theorem-contamination eval-diff-impl-theorem-contamination)
                  (and eval-diff-doc-diff-contamination eval-diff-impl-diff-contamination)
                  (and eval-diff-doc-excludes-self eval-diff-impl-excludes-self))
    :using (count-exists
            eval-diff-doc-transitive eval-diff-impl-transitive
            eval-diff-doc-follows-derivation-chains eval-diff-impl-follows-derivation-chains
            eval-diff-doc-theorem-contamination eval-diff-impl-theorem-contamination
            eval-diff-doc-diff-contamination eval-diff-impl-diff-contamination
            eval-diff-doc-excludes-self eval-diff-impl-excludes-self))

; Cross-layer diffs
(diff eval-diff-contamination-paired-vs-doc :replace eval-diff-contamination-paired :with eval-diff-contamination-doc-count)
(diff eval-diff-contamination-paired-vs-impl :replace eval-diff-contamination-paired :with eval-diff-contamination-impl-count)

; =====================================================================
; Consistency classification — error vs warning
; =====================================================================

(defterm consistency-error
    :evidence (evidence "engine.py"
        :quotes ("report = ConsistencyReport(\n            consistent=len(issues) == 0,\n            issues=issues,\n            warnings=warnings,\n        )")
        :explanation "issues list drives consistent=False; anything appended to issues is an error"))

(defterm consistency-warning
    :evidence (evidence "engine.py"
        :quotes ("report = ConsistencyReport(\n            consistent=len(issues) == 0,\n            issues=issues,\n            warnings=warnings,\n        )")
        :explanation "warnings list is stored but consistent depends only on issues; warnings don't break consistency"))

; Evidence → epistemic status → consistency outcome
; Isomorphism: three independent counts align for errors and warnings.
;   errors:   collapsed-error-cross-check = issue-type-count = adjusted-issue-count  (all 5)
;   warnings: warning-cross-check = warning-type-count = unknown-count-from-witnesses (all 2)
; These are derived at the end of this section after all three layers are built.

; Evidence → epistemic status axioms
(load-document "epistemics.pltg" "../std/epistemics.pltg")

(axiom ungrounded-is-hallucinated
    (if (and (not ?grounded) (not ?manually-validated)) epistemics.hallucinated epistemics.unknown)
    :evidence (evidence "epistemics.pltg"
        :quotes ("hallucinated — the system has evidence that the claim is wrong.\n; Examples:\n;   - A quote was NOT found in the document (unverified evidence)")
        :explanation "ungrounded evidence without manual validation — matches epistemics definition of hallucinated"))

(fact unverified-is-grounded false
    :evidence (evidence "engine.py"
        :quotes ("elif not origin.is_grounded:\n                        unverified.append(name)")
        :explanation "unverified evidence: grounded = false"))

(fact unverified-is-manually-validated false
    :evidence (evidence "engine.py"
        :quotes ("if not origin.verified and origin.verify_manual:\n                        manually_verified.append(name)\n                    elif not origin.is_grounded:\n                        unverified.append(name)")
        :explanation "unverified path is elif after manual check — manually validated = false"))

(derive witness-evidence-hallucinated ungrounded-is-hallucinated
    :bind ((?grounded unverified-is-grounded) (?manually-validated unverified-is-manually-validated))
    :using (ungrounded-is-hallucinated unverified-is-grounded unverified-is-manually-validated))

(axiom manually-validated-is-unknown
    (if (and (not ?grounded) ?manually-validated) epistemics.unknown epistemics.exemplifiable)
    :evidence (evidence "epistemics.pltg"
        :quotes ("unknown — the system cannot make a determination.\n; Examples:\n;   - A human called verify_manual — the system trusts but can't check")
        :explanation "ungrounded but manually validated — matches epistemics definition of unknown"))

(fact manual-is-grounded false
    :evidence (evidence "engine.py"
        :quotes ("if not origin.verified and origin.verify_manual:\n                        manually_verified.append(name)")
        :explanation "manually validated evidence: grounded = false (not verified)"))

(fact manual-is-manually-validated true
    :evidence (evidence "engine.py"
        :quotes ("if not origin.verified and origin.verify_manual:\n                        manually_verified.append(name)")
        :explanation "manually validated evidence: manually validated = true"))

(derive witness-evidence-unknown manually-validated-is-unknown
    :bind ((?grounded manual-is-grounded) (?manually-validated manual-is-manually-validated))
    :using (manually-validated-is-unknown manual-is-grounded manual-is-manually-validated))

; --- NO_EVIDENCE → hallucinated ---
(axiom no-evidence-is-hallucinated
    (if (and (not ?has-evidence) (not ?manually-validated)) epistemics.hallucinated epistemics.unknown)
    :evidence (evidence "epistemics.pltg"
        :quotes ("- No evidence was provided at all (origin is a bare string)")
        :explanation "bare string origin, not manually validated — matches epistemics definition of hallucinated"))

(fact no-evidence-has-no-evidence false
    :evidence (evidence "engine.py"
        :quotes ("elif isinstance(origin, str):\n                    if (\n                        origin not in (\"unknown\", \"derived\")\n                        and not origin.startswith(\"diff \")\n                        and \"potential fabrication\" not in origin\n                    ):\n                        no_evidence.append((name, origin))")
        :explanation "string origin that isn't a known sentinel — no evidence attached"))

(fact no-evidence-not-manually-validated false
    :evidence (evidence "engine.py"
        :quotes ("new_origin = Evidence(\n                document=\"manual\",\n                quotes=[],\n                explanation=origin if isinstance(origin, str) else str(origin),\n                verify_manual=True,\n            )")
        :explanation "verify_manual converts string origins to Evidence — they leave the isinstance(origin, str) path"))

(derive witness-no-evidence-hallucinated no-evidence-is-hallucinated
    :bind ((?has-evidence no-evidence-has-no-evidence) (?manually-validated no-evidence-not-manually-validated))
    :using (no-evidence-is-hallucinated no-evidence-has-no-evidence no-evidence-not-manually-validated))

; --- POTENTIAL_FABRICATION → hallucinated (two branches) ---

; Branch 1: derive does not hold (WFF evaluated to False)
(axiom fabrication-does-not-hold
    (if (not ?holds) epistemics.hallucinated epistemics.exemplifiable)
    :evidence (evidence "epistemics.pltg"
        :quotes ("- A theorem was derived from an unverified source (fabrication)")
        :explanation "derivation evaluated to False — result is hallucinated"))

(fact derive-does-not-hold false
    :evidence (evidence "engine.py"
        :quotes ("if does_not_hold:\n            issues.append(\"does not hold (evaluated to False)\")")
        :explanation "derive checks if WFF holds — false means does not hold"))

(derive witness-fabrication-does-not-hold fabrication-does-not-hold
    :bind ((?holds derive-does-not-hold))
    :using (fabrication-does-not-hold derive-does-not-hold))

; Branch 2: derived from ungrounded sources
(axiom fabrication-ungrounded-source
    (if (and (= ?source-status epistemics.hallucinated) ?source-in-using) epistemics.hallucinated epistemics.unknown)
    :evidence (evidence "epistemics.pltg"
        :quotes ("- A theorem was derived from an unverified source (fabrication)")
        :explanation "hallucinated source in :using — derivation inherits hallucinated status"))

(defterm ungrounded-source-status epistemics.hallucinated
    :evidence (evidence "engine.py"
        :quotes ("if ungrounded:\n            issues.append(f\"derived from unverified: {', '.join(ungrounded)}\")")
        :explanation "ungrounded sources have hallucinated epistemic status"))

(fact ungrounded-source-in-using true
    :evidence (evidence "engine.py"
        :quotes ("ungrounded = self._check_sources_grounded(using)")
        :explanation "grounding check runs on :using sources"))

(derive witness-fabrication-ungrounded-source fabrication-ungrounded-source
    :bind ((?source-status ungrounded-source-status) (?source-in-using ungrounded-source-in-using))
    :using (fabrication-ungrounded-source ungrounded-source-status ungrounded-source-in-using))

; --- DIFF_DIVERGENCE → hallucinated ---
; Each side of a diff is in superposition until the diff observes it.
; Divergence means the diff found disagreement — observation is refuted.
; Both sides collapse to hallucinated, joint-status confirms hallucinated.

(fact diff-divergence-detected true
    :evidence (evidence "engine.py"
        :quotes ("downstream_divergent = [d for d in all_diffs if not d.empty and not d.diff_contamination_only]")
        :explanation "downstream divergent diffs detected"))

(defterm divergence-replace (epistemics.superpose epistemics.hallucinated epistemics.unknown epistemics.exemplifiable)
    :evidence (evidence "engine.py"
        :quotes ("original = self._resolve_value(replace)")
        :explanation "replace side — superposed until diff observes"))

(defterm divergence-with (epistemics.superpose epistemics.hallucinated epistemics.unknown epistemics.exemplifiable)
    :evidence (evidence "engine.py"
        :quotes ("substitute_val = self._resolve_value(with_)")
        :explanation "with side — superposed until diff observes"))

(defterm witness-diff-divergence-hallucinated
    (epistemics.joint-status
        (strict (epistemics.collapse (strict divergence-replace) epistemics.refuted))
        (strict (epistemics.collapse (strict divergence-with) epistemics.refuted)))
    :using (epistemics.collapse epistemics.joint-status epistemics.refuted
            divergence-replace divergence-with))

; --- DIFF_VALUE_DIVERGENCE → hallucinated ---
; Same pattern: value divergence is also a refuting observation.

(fact diff-value-divergence-detected true
    :evidence (evidence "engine.py"
        :quotes ("value_divergent = [d for d in all_diffs if d.values_diverge and d.empty]")
        :explanation "value-divergent diffs detected"))

(defterm value-divergence-replace (epistemics.superpose epistemics.hallucinated epistemics.unknown epistemics.exemplifiable)
    :evidence (evidence "engine.py"
        :quotes ("original = self._resolve_value(replace)")
        :explanation "replace side — superposed until diff observes"))

(defterm value-divergence-with (epistemics.superpose epistemics.hallucinated epistemics.unknown epistemics.exemplifiable)
    :evidence (evidence "engine.py"
        :quotes ("substitute_val = self._resolve_value(with_)")
        :explanation "with side — superposed until diff observes"))

(defterm witness-diff-value-hallucinated
    (epistemics.joint-status
        (strict (epistemics.collapse (strict value-divergence-replace) epistemics.refuted))
        (strict (epistemics.collapse (strict value-divergence-with) epistemics.refuted)))
    :using (epistemics.collapse epistemics.joint-status epistemics.refuted
            value-divergence-replace value-divergence-with))

; --- DIFF_CONTAMINATION → unknown ---
; Contamination means the system can't check — observation is hypothesised.
; Only one side (the contaminated diff itself), so no joint-status needed.

(fact diff-contamination-detected true
    :evidence (evidence "engine.py"
        :quotes ("diff_contamination = [d for d in all_diffs if d.diff_contamination_only]")
        :explanation "contamination-only diffs detected"))

(defterm contamination-status (epistemics.superpose epistemics.hallucinated epistemics.unknown epistemics.exemplifiable)
    :evidence (evidence "engine.py"
        :quotes ("diff_contamination = [d for d in all_diffs if d.diff_contamination_only]")
        :explanation "contaminated diff — superposed until observed"))

(defterm witness-diff-contamination-unknown
    (epistemics.collapse (strict contamination-status) epistemics.hypothesised)
    :using (epistemics.collapse epistemics.hypothesised contamination-status))

; --- Consistency outcome: condition → error or warning ---
; Each axiom models one if-branch in consistency(). Facts describe code behavior.

; UNVERIFIED_EVIDENCE → error
(axiom error-on-unverified
    (implies (and ?has-evidence ?is-unverified) consistency-error)
    :evidence (evidence "engine.py"
        :quotes ("if unverified:\n            issues.append(ConsistencyIssue(IssueType.UNVERIFIED_EVIDENCE, sorted(unverified)))")
        :explanation "evidence present but unverified → appended to issues"))

(fact unverified-has-evidence true
    :evidence (evidence "engine.py"
        :quotes ("if isinstance(origin, Evidence):")
        :explanation "unverified path requires origin to be Evidence"))

(fact unverified-is-unverified true
    :evidence (evidence "engine.py"
        :quotes ("elif not origin.is_grounded:\n                        unverified.append(name)")
        :explanation "evidence is not grounded → appended to unverified list"))

(derive unverified-causes-error error-on-unverified
    :bind ((?has-evidence unverified-has-evidence) (?is-unverified unverified-is-unverified))
    :using (error-on-unverified unverified-has-evidence unverified-is-unverified))

; NO_EVIDENCE → error
(axiom error-on-no-evidence
    (implies (and ?is-string-origin (not ?is-sentinel)) consistency-error)
    :evidence (evidence "engine.py"
        :quotes ("if no_evidence:\n            issues.append(ConsistencyIssue(IssueType.NO_EVIDENCE, sorted(no_evidence, key=lambda x: x[0])))")
        :explanation "string origin that isn't a sentinel → appended to issues"))

(fact no-evidence-is-string-origin true
    :evidence (evidence "engine.py"
        :quotes ("elif isinstance(origin, str):")
        :explanation "no-evidence path requires origin to be a string"))

(fact no-evidence-is-not-sentinel false
    :evidence (evidence "engine.py"
        :quotes ("origin not in (\"unknown\", \"derived\")\n                        and not origin.startswith(\"diff \")\n                        and \"potential fabrication\" not in origin")
        :explanation "filtered out known sentinels — remaining strings have no evidence"))

(derive no-evidence-causes-error error-on-no-evidence
    :bind ((?is-string-origin no-evidence-is-string-origin) (?is-sentinel no-evidence-is-not-sentinel))
    :using (error-on-no-evidence no-evidence-is-string-origin no-evidence-is-not-sentinel))

; POTENTIAL_FABRICATION → error (does not hold)
(axiom error-on-fabrication-does-not-hold
    (implies (not ?wff-holds) consistency-error)
    :evidence (evidence "engine.py"
        :quotes ("if does_not_hold:\n            issues.append(\"does not hold (evaluated to False)\")")
        :explanation "WFF evaluated to False → marked as potential fabrication"))

(fact fabrication-wff-does-not-hold false
    :evidence (evidence "engine.py"
        :quotes ("does_not_hold = result is False or result is None")
        :explanation "derive checks if WFF result is False or None"))

(derive fabrication-does-not-hold-causes-error error-on-fabrication-does-not-hold
    :bind ((?wff-holds fabrication-wff-does-not-hold))
    :using (error-on-fabrication-does-not-hold fabrication-wff-does-not-hold))

; POTENTIAL_FABRICATION → error (ungrounded source)
(axiom error-on-fabrication-ungrounded
    (implies (and ?has-ungrounded-source ?source-in-using) consistency-error)
    :evidence (evidence "engine.py"
        :quotes ("if ungrounded:\n            issues.append(f\"derived from unverified: {', '.join(ungrounded)}\")")
        :explanation "ungrounded source in :using → marked as potential fabrication"))

(fact fabrication-has-ungrounded-source true
    :evidence (evidence "engine.py"
        :quotes ("ungrounded = self._check_sources_grounded(using)")
        :explanation "derive checks grounding of all :using sources"))

(fact fabrication-source-in-using true
    :evidence (evidence "engine.py"
        :quotes ("origin = f\"potential fabrication — {'; '.join(issues)}\"")
        :explanation "issues non-empty → origin set to potential fabrication"))

(derive fabrication-ungrounded-causes-error error-on-fabrication-ungrounded
    :bind ((?has-ungrounded-source fabrication-has-ungrounded-source) (?source-in-using fabrication-source-in-using))
    :using (error-on-fabrication-ungrounded fabrication-has-ungrounded-source fabrication-source-in-using))

; DIFF_DIVERGENCE → error
(axiom error-on-diff-divergence
    (implies (and (!= ?result-a ?result-b) (not ?contamination-only)) consistency-error)
    :evidence (evidence "engine.py"
        :quotes ("if downstream_divergent:\n            issues.append(ConsistencyIssue(IssueType.DIFF_DIVERGENCE, downstream_divergent))")
        :explanation "original and substitute evaluate differently, not contamination-only → error"))

(fact divergence-evaluates-both true
    :evidence (evidence "engine.py"
        :quotes ("result_a = self.evaluate(defn)\n                result_b = self.evaluate(defn, {Symbol(replace): substitute_val})")
        :explanation "eval_diff evaluates definition with original and substitute values"))

(fact divergence-compares-results true
    :evidence (evidence "engine.py"
        :quotes ("if result_a != result_b:\n                divergences[dep_name] = [result_a, result_b]")
        :explanation "divergence detected when results differ"))

(fact divergence-filters-contamination true
    :evidence (evidence "engine.py"
        :quotes ("downstream_divergent = [d for d in all_diffs if not d.empty and not d.diff_contamination_only]")
        :explanation "downstream divergent excludes contamination-only diffs"))

(derive divergence-causes-error error-on-diff-divergence
    :bind ((?result-a divergence-evaluates-both) (?result-b divergence-compares-results) (?contamination-only divergence-filters-contamination))
    :using (error-on-diff-divergence divergence-evaluates-both divergence-compares-results divergence-filters-contamination))

; DIFF_VALUE_DIVERGENCE → error
(axiom error-on-value-divergence
    (implies (and (!= ?value-a ?value-b) ?no-downstream) consistency-error)
    :evidence (evidence "engine.py"
        :quotes ("if value_divergent:\n            issues.append(ConsistencyIssue(IssueType.DIFF_VALUE_DIVERGENCE, value_divergent))")
        :explanation "replace and with resolve to different values, no downstream divergences → error"))

(fact value-divergence-values-differ true
    :evidence (evidence "engine.py"
        :quotes ("def values_diverge(self) -> bool:\n        return self.value_a != self.value_b")
        :explanation "values_diverge checks if replace and with resolve differently"))

(fact value-divergence-no-downstream true
    :evidence (evidence "engine.py"
        :quotes ("value_divergent = [d for d in all_diffs if d.values_diverge and d.empty]")
        :explanation "value divergence requires d.empty — no downstream dependents affected"))

(derive value-divergence-causes-error error-on-value-divergence
    :bind ((?value-a value-divergence-values-differ) (?value-b value-divergence-no-downstream) (?no-downstream value-divergence-no-downstream))
    :using (error-on-value-divergence value-divergence-values-differ value-divergence-no-downstream))

; MANUALLY_VERIFIED → warning
(axiom warning-on-manual
    (implies (and ?has-evidence (not ?is-verified) ?is-verify-manual) consistency-warning)
    :evidence (evidence "engine.py"
        :quotes ("if manually_verified:\n            manual_details = {}")
        :explanation "evidence present, not verified, but verify_manual set → warning"))

(fact manual-has-evidence true
    :evidence (evidence "engine.py"
        :quotes ("if isinstance(origin, Evidence):")
        :explanation "manually verified path requires origin to be Evidence"))

(fact manual-is-verified false
    :evidence (evidence "engine.py"
        :quotes ("if not origin.verified and origin.verify_manual:")
        :explanation "evidence is not verified — verified = false"))

(fact manual-has-verify-manual-flag true
    :evidence (evidence "engine.py"
        :quotes ("if not origin.verified and origin.verify_manual:\n                        manually_verified.append(name)")
        :explanation "verify_manual flag is set — human marked it"))

(derive manual-causes-warning warning-on-manual
    :bind ((?has-evidence manual-has-evidence) (?is-verified manual-is-verified) (?is-verify-manual manual-has-verify-manual-flag))
    :using (warning-on-manual manual-has-evidence manual-is-verified manual-has-verify-manual-flag))

; DIFF_CONTAMINATION → warning
; Code: diff_contamination_only checks (1) not empty, (2) all divergences are diff() refs
; When both hold, it's a warning not an error — sibling diffs contaminate but don't break consistency
(axiom warning-on-contamination
    (implies (and (not ?is-empty) ?all-are-diff-refs) consistency-warning)
    :evidence (evidence "engine.py"
        :quotes ("warnings.append(\n                ConsistencyWarning(WarningType.DIFF_CONTAMINATION, [d.name for d in diff_contamination], contam_details)\n            )")
        :explanation "contaminated diffs (not empty + all divergences are diff refs) appended to warnings"))

(fact contamination-is-empty false
    :evidence (evidence "engine.py"
        :quotes ("if self.empty:\n            return False")
        :explanation "diff_contamination_only returns False if empty — contamination requires divergences"))

(fact contamination-all-are-diff-refs true
    :evidence (evidence "engine.py"
        :quotes ("return all(isinstance(v[0], str) and v[0].startswith(\"diff(\") for v in self.divergences.values())")
        :explanation "all divergence sources must be sibling-diff references (start with 'diff(')"))

(derive contamination-causes-warning warning-on-contamination
    :bind ((?is-empty contamination-is-empty) (?all-are-diff-refs contamination-all-are-diff-refs))
    :using (warning-on-contamination contamination-is-empty contamination-all-are-diff-refs))

; =====================================================================
; Classification enum — every IssueType and WarningType member as a fact
; =====================================================================

; IssueType members (errors — break consistent=True)
(fact issue-unverified-evidence true
    :evidence (evidence "engine.py"
        :quotes ("UNVERIFIED_EVIDENCE = \"unverified_evidence\"")
        :explanation "IssueType enum member"))

(fact issue-no-evidence true
    :evidence (evidence "engine.py"
        :quotes ("NO_EVIDENCE = \"no_evidence\"")
        :explanation "IssueType enum member"))

(fact issue-potential-fabrication true
    :evidence (evidence "engine.py"
        :quotes ("POTENTIAL_FABRICATION = \"potential_fabrication\"")
        :explanation "IssueType enum member"))

(fact issue-diff-divergence true
    :evidence (evidence "engine.py"
        :quotes ("DIFF_DIVERGENCE = \"diff_divergence\"")
        :explanation "IssueType enum member"))

(fact issue-diff-value-divergence true
    :evidence (evidence "engine.py"
        :quotes ("DIFF_VALUE_DIVERGENCE = \"diff_value_divergence\"")
        :explanation "IssueType enum member"))

; WarningType members (noted but don't break consistency)
(fact warning-manually-verified true
    :evidence (evidence "engine.py"
        :quotes ("MANUALLY_VERIFIED = \"manually_verified\"")
        :explanation "WarningType enum member"))

(fact warning-diff-contamination true
    :evidence (evidence "engine.py"
        :quotes ("DIFF_CONTAMINATION = \"diff_contamination\"")
        :explanation "WarningType enum member"))

; --- Items × Layers: epistemic status of all 8 witnesses ---
;
; Each witness evaluates to an epistemic status (hallucinated/unknown/exemplifiable).
; We count how many are hallucinated and how many are unknown, then cross-check
; against the classification enum counts (5 IssueTypes + 2 WarningTypes).
;
; Witnesses → status:
;   witness-evidence-hallucinated         → hallucinated  (UNVERIFIED_EVIDENCE)
;   witness-no-evidence-hallucinated      → hallucinated  (NO_EVIDENCE)
;   witness-fabrication-does-not-hold     → hallucinated  (POTENTIAL_FABRICATION branch 1)
;   witness-fabrication-ungrounded-source → hallucinated  (POTENTIAL_FABRICATION branch 2)
;   witness-diff-divergence-hallucinated  → hallucinated  (DIFF_DIVERGENCE)
;   witness-diff-value-hallucinated       → hallucinated  (DIFF_VALUE_DIVERGENCE)
;   witness-evidence-unknown              → unknown       (MANUALLY_VERIFIED)
;   witness-diff-contamination-unknown    → unknown       (DIFF_CONTAMINATION)
;
; Hallucinated count = 6 (not 5) because POTENTIAL_FABRICATION has 2 branches.
; Unknown count = 2, matching 2 WarningType members.

(derive hallucinated-count
    (epistemics.count-hallucinated
        (strict witness-evidence-hallucinated)
        (strict witness-no-evidence-hallucinated)
        (strict witness-fabrication-does-not-hold)
        (strict witness-fabrication-ungrounded-source)
        (strict witness-diff-divergence-hallucinated)
        (strict witness-diff-value-hallucinated)
        (strict witness-evidence-unknown)
        (strict witness-diff-contamination-unknown))
    :using (epistemics.count-hallucinated
            witness-evidence-hallucinated
            witness-no-evidence-hallucinated
            witness-fabrication-does-not-hold
            witness-fabrication-ungrounded-source
            witness-diff-divergence-hallucinated
            witness-diff-value-hallucinated
            witness-evidence-unknown
            witness-diff-contamination-unknown))

; Issue types that map to hallucinated witnesses (5 types, 6 witnesses)
(derive issue-type-count
    (count-exists issue-unverified-evidence
                  issue-no-evidence
                  issue-potential-fabrication
                  issue-diff-divergence
                  issue-diff-value-divergence)
    :using (count-exists
            issue-unverified-evidence
            issue-no-evidence
            issue-potential-fabrication
            issue-diff-divergence
            issue-diff-value-divergence))

; Cross-check: hallucinated-count (6) vs issue-type-count (5)
; They differ because POTENTIAL_FABRICATION covers 2 independent paths to hallucination
(defterm fabrication-branch-count 2
    :evidence (evidence "engine.py"
        :quotes ("if does_not_hold:" "if ungrounded:")
        :explanation "fabrication has 2 branches: does-not-hold and ungrounded-source"))

(derive adjusted-issue-count
    (+ issue-type-count (+ fabrication-branch-count (- 0 1)))
    :using (issue-type-count fabrication-branch-count))

(diff hallucinated-vs-issues
    :replace hallucinated-count
    :with adjusted-issue-count)

; Warning types that map to unknown witnesses (2 types, 2 witnesses)
(derive warning-type-count
    (count-exists warning-manually-verified
                  warning-diff-contamination)
    :using (count-exists
            warning-manually-verified
            warning-diff-contamination))

; Count unknowns from all 8 witnesses using joint-status trick:
; unknown if status = unknown, else not-unknown
; We use count-exists on (= witness unknown) checks
(derive unknown-count-from-witnesses
    (count-exists
        (= (strict witness-evidence-unknown) epistemics.unknown)
        (= (strict witness-diff-contamination-unknown) epistemics.unknown)
        (= (strict witness-evidence-hallucinated) epistemics.unknown)
        (= (strict witness-no-evidence-hallucinated) epistemics.unknown)
        (= (strict witness-fabrication-does-not-hold) epistemics.unknown)
        (= (strict witness-fabrication-ungrounded-source) epistemics.unknown)
        (= (strict witness-diff-divergence-hallucinated) epistemics.unknown)
        (= (strict witness-diff-value-hallucinated) epistemics.unknown))
    :using (count-exists
            witness-evidence-unknown
            witness-diff-contamination-unknown
            witness-evidence-hallucinated
            witness-no-evidence-hallucinated
            witness-fabrication-does-not-hold
            witness-fabrication-ungrounded-source
            witness-diff-divergence-hallucinated
            witness-diff-value-hallucinated))

; Cross-check: unknown-count (2) vs warning-type-count (2)
(diff unknown-vs-warnings
    :replace unknown-count-from-witnesses
    :with warning-type-count)

; --- Items × Layers: epistemic status × consequence × classification ---
;
; Three layers per witness, all must hold together:
;   1. Epistemic status: (= (strict witness) epistemics.hallucinated/unknown)
;   2. Consequence: the derive proving this causes error/warning
;   3. Classification: the enum entry exists as a fact
;
; All 8 witnesses appear in both cross-checks.
; Booleans do the filtering: hallucinated witnesses score true in error check,
; unknown witnesses score true in warning check.

; Error cross-check: hallucinated × causes-error × issue-type-exists
(derive error-cross-check
    (count-exists
        (and (= (strict witness-evidence-hallucinated) epistemics.hallucinated)
             unverified-causes-error issue-unverified-evidence)
        (and (= (strict witness-no-evidence-hallucinated) epistemics.hallucinated)
             no-evidence-causes-error issue-no-evidence)
        (and (= (strict witness-fabrication-does-not-hold) epistemics.hallucinated)
             fabrication-does-not-hold-causes-error issue-potential-fabrication)
        (and (= (strict witness-fabrication-ungrounded-source) epistemics.hallucinated)
             fabrication-ungrounded-causes-error issue-potential-fabrication)
        (and (= (strict witness-diff-divergence-hallucinated) epistemics.hallucinated)
             divergence-causes-error issue-diff-divergence)
        (and (= (strict witness-diff-value-hallucinated) epistemics.hallucinated)
             value-divergence-causes-error issue-diff-value-divergence)
        (and (= (strict witness-evidence-unknown) epistemics.hallucinated)
             manual-causes-warning warning-manually-verified)
        (and (= (strict witness-diff-contamination-unknown) epistemics.hallucinated)
             contamination-causes-warning warning-diff-contamination))
    :using (count-exists
            witness-evidence-hallucinated unverified-causes-error issue-unverified-evidence
            witness-no-evidence-hallucinated no-evidence-causes-error issue-no-evidence
            witness-fabrication-does-not-hold fabrication-does-not-hold-causes-error issue-potential-fabrication
            witness-fabrication-ungrounded-source fabrication-ungrounded-causes-error
            witness-diff-divergence-hallucinated divergence-causes-error issue-diff-divergence
            witness-diff-value-hallucinated value-divergence-causes-error issue-diff-value-divergence
            witness-evidence-unknown manual-causes-warning warning-manually-verified
            witness-diff-contamination-unknown contamination-causes-warning warning-diff-contamination))

; Warning cross-check: unknown × causes-warning × warning-type-exists
(derive warning-cross-check
    (count-exists
        (and (= (strict witness-evidence-hallucinated) epistemics.unknown)
             unverified-causes-error issue-unverified-evidence)
        (and (= (strict witness-no-evidence-hallucinated) epistemics.unknown)
             no-evidence-causes-error issue-no-evidence)
        (and (= (strict witness-fabrication-does-not-hold) epistemics.unknown)
             fabrication-does-not-hold-causes-error issue-potential-fabrication)
        (and (= (strict witness-fabrication-ungrounded-source) epistemics.unknown)
             fabrication-ungrounded-causes-error issue-potential-fabrication)
        (and (= (strict witness-diff-divergence-hallucinated) epistemics.unknown)
             divergence-causes-error issue-diff-divergence)
        (and (= (strict witness-diff-value-hallucinated) epistemics.unknown)
             value-divergence-causes-error issue-diff-value-divergence)
        (and (= (strict witness-evidence-unknown) epistemics.unknown)
             manual-causes-warning warning-manually-verified)
        (and (= (strict witness-diff-contamination-unknown) epistemics.unknown)
             contamination-causes-warning warning-diff-contamination))
    :using (count-exists
            witness-evidence-hallucinated unverified-causes-error issue-unverified-evidence
            witness-no-evidence-hallucinated no-evidence-causes-error issue-no-evidence
            witness-fabrication-does-not-hold fabrication-does-not-hold-causes-error issue-potential-fabrication
            witness-fabrication-ungrounded-source fabrication-ungrounded-causes-error
            witness-diff-divergence-hallucinated divergence-causes-error issue-diff-divergence
            witness-diff-value-hallucinated value-divergence-causes-error issue-diff-value-divergence
            witness-evidence-unknown manual-causes-warning warning-manually-verified
            witness-diff-contamination-unknown contamination-causes-warning warning-diff-contamination))

; Cross-check diffs
(diff error-layers-consistent
    :replace error-cross-check
    :with adjusted-issue-count)

(diff warning-layers-consistent
    :replace warning-cross-check
    :with warning-type-count)

; Collapsed error cross-check: fabrication's 2 branches collapse via joint-status.
; Both witness-fabrication-does-not-hold and witness-fabrication-ungrounded-source
; are hallucinated → joint-status(hallucinated, hallucinated) = hallucinated → 1 row.
; So 6 uncollapsed rows become 5 after joining the fabrication pair.
(derive collapsed-error-cross-check
    (count-exists
        (and (= (strict witness-evidence-hallucinated) epistemics.hallucinated)
             unverified-causes-error issue-unverified-evidence)
        (and (= (strict witness-no-evidence-hallucinated) epistemics.hallucinated)
             no-evidence-causes-error issue-no-evidence)
        (and (= (strict (epistemics.joint-status
                    (strict witness-fabrication-does-not-hold)
                    (strict witness-fabrication-ungrounded-source))) epistemics.hallucinated)
             fabrication-does-not-hold-causes-error fabrication-ungrounded-causes-error issue-potential-fabrication)
        (and (= (strict witness-diff-divergence-hallucinated) epistemics.hallucinated)
             divergence-causes-error issue-diff-divergence)
        (and (= (strict witness-diff-value-hallucinated) epistemics.hallucinated)
             value-divergence-causes-error issue-diff-value-divergence)
        (and (= (strict witness-evidence-unknown) epistemics.hallucinated)
             manual-causes-warning warning-manually-verified)
        (and (= (strict witness-diff-contamination-unknown) epistemics.hallucinated)
             contamination-causes-warning warning-diff-contamination))
    :using (count-exists epistemics.joint-status
            witness-evidence-hallucinated unverified-causes-error issue-unverified-evidence
            witness-no-evidence-hallucinated no-evidence-causes-error issue-no-evidence
            witness-fabrication-does-not-hold fabrication-does-not-hold-causes-error
            witness-fabrication-ungrounded-source fabrication-ungrounded-causes-error issue-potential-fabrication
            witness-diff-divergence-hallucinated divergence-causes-error issue-diff-divergence
            witness-diff-value-hallucinated value-divergence-causes-error issue-diff-value-divergence
            witness-evidence-unknown manual-causes-warning warning-manually-verified
            witness-diff-contamination-unknown contamination-causes-warning warning-diff-contamination))

; collapsed-error-cross-check (5) = issue-type-count (5) — fully connected
(diff error-layers-consistent
    :replace collapsed-error-cross-check
    :with issue-type-count)

; warning-cross-check (2) = warning-type-count (2) — fully connected
(diff warning-layers-consistent
    :replace warning-cross-check
    :with warning-type-count)

; --- Isomorphism: hallucinated ≅ errors, unknown ≅ warnings ---
; Four independent counts must all be 5:
;   1. collapsed-error-cross-check: mega (hallucinated × causes-error × enum)
;   2. issue-type-count: IssueType enum members
;   3. collapsed-hallucinated-count: count-hallucinated with fab pair joint-status'd
;   4. causes-error-count: count-exists of all causes-error derives (fab collapsed)

(derive collapsed-hallucinated-count
    (epistemics.count-hallucinated
        (strict witness-evidence-hallucinated)
        (strict witness-no-evidence-hallucinated)
        (strict (epistemics.joint-status
            (strict witness-fabrication-does-not-hold)
            (strict witness-fabrication-ungrounded-source)))
        (strict witness-diff-divergence-hallucinated)
        (strict witness-diff-value-hallucinated)
        (strict witness-evidence-unknown)
        (strict witness-diff-contamination-unknown))
    :using (epistemics.count-hallucinated epistemics.joint-status
            witness-evidence-hallucinated witness-no-evidence-hallucinated
            witness-fabrication-does-not-hold witness-fabrication-ungrounded-source
            witness-diff-divergence-hallucinated witness-diff-value-hallucinated
            witness-evidence-unknown witness-diff-contamination-unknown))

(derive causes-error-count
    (count-exists
        (and unverified-causes-error issue-unverified-evidence)
        (and no-evidence-causes-error issue-no-evidence)
        (and fabrication-does-not-hold-causes-error fabrication-ungrounded-causes-error issue-potential-fabrication)
        (and divergence-causes-error issue-diff-divergence)
        (and value-divergence-causes-error issue-diff-value-divergence))
    :using (count-exists
            unverified-causes-error issue-unverified-evidence
            no-evidence-causes-error issue-no-evidence
            fabrication-does-not-hold-causes-error fabrication-ungrounded-causes-error issue-potential-fabrication
            divergence-causes-error issue-diff-divergence
            value-divergence-causes-error issue-diff-value-divergence))

(derive hallucinated-is-error
    (= collapsed-error-cross-check issue-type-count collapsed-hallucinated-count causes-error-count)
    :using (collapsed-error-cross-check issue-type-count collapsed-hallucinated-count causes-error-count))

(derive causes-warning-count
    (count-exists
        (and manual-causes-warning warning-manually-verified)
        (and contamination-causes-warning warning-diff-contamination))
    :using (count-exists
            manual-causes-warning warning-manually-verified
            contamination-causes-warning warning-diff-contamination))

(derive unknown-is-warning
    (= warning-cross-check warning-type-count unknown-count-from-witnesses causes-warning-count)
    :using (warning-cross-check warning-type-count unknown-count-from-witnesses causes-warning-count))

(derive isomorphism-hallucinations-errors-unknowns-warnings
    (and hallucinated-is-error unknown-is-warning)
    :using (hallucinated-is-error unknown-is-warning))

; Total consistency states: fully-bound errors + warnings
(derive consistency-states-total
    (+ collapsed-error-cross-check warning-cross-check)
    :using (collapsed-error-cross-check warning-cross-check))

; Export cross-check counts for core.pltg
(derive export-error-cross-check
    (util.export collapsed-error-cross-check)
    :using (util.export collapsed-error-cross-check))

(derive export-warning-cross-check
    (util.export warning-cross-check)
    :using (util.export warning-cross-check))

(derive export-consistency-states-total
    (util.export consistency-states-total)
    :using (util.export consistency-states-total))

; =====================================================================
; Exports — for core.pltg cross-checks against README
; =====================================================================

(derive export-diffs-no-evidence
    (util.export bound-diff-no-evidence)
    :using (util.export bound-diff-no-evidence))

(derive export-rewrite-vs-bind
    (util.export derive-restricted-eval)
    :using (util.export derive-restricted-eval))

(derive export-computable-directives
    (util.export load-source-handles-derive)
    :using (util.export load-source-handles-derive))

(derive export-effects-in-computable
    (util.export load-source-fallback-evaluates)
    :using (util.export load-source-fallback-evaluates))

(derive export-rewrite-as-functions
    (util.export eq-has-rewrite-fallback)
    :using (util.export eq-has-rewrite-fallback))

(derive export-items-x-layers
    (util.export diff-is-lazy)
    :using (util.export diff-is-lazy))

(derive export-auto-grounding
    (util.export resolve-origin-checks-both)
    :using (util.export resolve-origin-checks-both))

(derive export-explanation-field
    (util.export resolve-origin-checks-evidence)
    :using (util.export resolve-origin-checks-evidence))

(derive export-origin-or-none
    (util.export resolve-origin-checks-origin)
    :using (util.export resolve-origin-checks-origin))

(derive export-document-index
    (util.export engine-has-verifier-index)
    :using (util.export engine-has-verifier-index))

(derive export-defaults
    (util.export fact-extends-axiom)
    :using (util.export fact-extends-axiom))

(derive export-diffs-cross-validation
    (util.export diff-evaluated-structurally)
    :using (util.export diff-evaluated-structurally))

(derive export-fabrication-propagation
    (util.export derive-fabrication-propagation)
    :using (util.export derive-fabrication-propagation))

(derive export-defaults-doc-count
    (util.export defaults-doc-count)
    :using (util.export defaults-doc-count))

(derive export-axiom-requires-free-vars
    (util.export axiom-requires-free-vars)
    :using (util.export axiom-requires-free-vars))

(derive rewrite-depth-confirmed
    (= rewrite-depth-limit 100)
    :using (rewrite-depth-limit))

(derive export-rewrite-depth
    (util.export rewrite-depth-confirmed)
    :using (util.export rewrite-depth-confirmed))

(derive rewrite-left-to-right-confirmed
    (= rewrite-direction "left-to-right")
    :using (rewrite-direction))

(derive export-left-to-right
    (util.export rewrite-left-to-right-confirmed)
    :using (util.export rewrite-left-to-right-confirmed))

(fact env-is-dict true
    :evidence (evidence "engine.py"
        :quotes ("self.env: dict = dict(env)")
        :explanation "Engine env is a dict"))

(derive export-env-dict
    (util.export env-is-dict)
    :using (util.export env-is-dict))

(fact consistency-checks-three-layers true
    :evidence (evidence "engine.py"
        :quotes ("# 1. Evidence grounding\n        unverified = []\n        manually_verified = []\n        no_evidence = []" "# 2. Fabrication propagation\n        fabrications = sorted(\n            name\n            for name, thm in self.theorems.items()\n            if isinstance(thm.origin, str) and \"potential fabrication\" in thm.origin\n        )" "# 3. Diff divergences — evaluated live\n        all_diffs = sorted((self.eval_diff(n) for n in self.diffs), key=lambda d: d.name)")
        :explanation "consistency() has 3 implementation sections"))

(derive export-three-layers
    (util.export consistency-checks-three-layers)
    :using (util.export consistency-checks-three-layers))

(fact env-includes-callable-operators true
    :evidence (evidence "engine.py"
        :quotes ("# Include callable operators (arithmetic, comparison, logic)\n        for sym, val in self.env.items():\n            if callable(val):\n                env[sym] = val")
        :explanation "Restricted env includes callable operators"))

(derive export-operators-plain-callables
    (util.export env-includes-callable-operators)
    :using (util.export env-includes-callable-operators))

(derive export-fallback-evaluates
    (util.export load-source-fallback-evaluates)
    :using (util.export load-source-fallback-evaluates))

(derive retract-exists (= retract-doc "Remove a fact, axiom, term, theorem, or diff from the system.") :using (retract-doc))
(derive export-retract
    (util.export retract-exists)
    :using (util.export retract-exists))

(derive rederive-exists (= rederive-doc "Re-run a derivation to refresh its fabrication status.") :using (rederive-doc))
(derive export-rederive
    (util.export rederive-exists)
    :using (util.export rederive-exists))

; --- _dependents cross-type coverage ---
(derive export-dependents-types
    (util.export dependents-paired-count)
    :using (util.export dependents-paired-count))

(derive export-dependents-transitivity
    (util.export dependents-is-transitive)
    :using (util.export dependents-is-transitive))

(derive export-dependents-derivation-check
    (util.export dependents-checks-derivation-list)
    :using (util.export dependents-checks-derivation-list))

