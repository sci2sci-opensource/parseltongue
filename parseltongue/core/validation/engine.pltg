(defterm stub-suppress-log :origin "TODO: consistency() gained suppress_log: bool = True param — silences log.warning output by default")

; --- Scope special forms in _eval ---
(defterm stub-scope-handler :origin "TODO: SCOPE handler — dispatches to callable or self, resolves project/delegate in args via _rp")
(defterm stub-self-handler :origin "TODO: SELF handler — evaluates all args in current engine (identity scope)")
