(print "--- README axiom bindings cross-checked against engine impl ---")
(diff thm-axiom-var :replace axiom-var-requirement-consistent :with readme.export-bound-axioms-require-vars)
(diff thm-fabrication :replace fabrication-propagation-consistent :with readme.export-bound-fabrication)
(diff thm-fact-cites-quote :replace readme.export-bound-fact-cites-quote :with engine.export-auto-grounding)
(diff thm-diffs-detect :replace readme.export-bound-diffs-detect :with engine.export-diffs-cross-validation)

(print "")
(print "--- core internal theorem cross-checks ---")
(diff thm-retract :replace engine-retract-doc-incomplete :with readme.readme-documents-retract)
(diff thm-extensibility :replace readme-extensibility-ungrounded :with demos.export-extensibility-topic)
(diff thm-loader-consistent :replace readme-loader-consistent :with loader.export-load-pltg)
(diff thm-omits-loader :replace readme-omits-loader :with loader.export-import-checks-circular)
(diff thm-serialization :replace system-provides-serialization-engine-lacks :with readme.readme-documents-serialization)

; --- README internal counts cross-checked against impl ---
; 3 manual verification categories proven by existence
(derive manual-category-reusables-confirmed
    (= counting.export-counting-module-exists true)
    :using (counting.export-counting-module-exists))

(derive manual-category-aliases-confirmed
    (= count-exists counting.count-exists)
    :using (count-exists counting.count-exists))

(derive manual-category-hypotheticals-confirmed
    (= readme.readme-documents-manual-hypotheticals-qv-count quote_verifier.export-hypothetical-axiom-count)
    :using (readme.readme-documents-manual-hypotheticals-qv-count quote_verifier.export-hypothetical-axiom-count))

(derive manual-categories-count
    (count-exists manual-category-reusables-confirmed
                  manual-category-aliases-confirmed
                  manual-category-hypotheticals-confirmed)
    :using (count-exists manual-category-reusables-confirmed
                         manual-category-aliases-confirmed
                         manual-category-hypotheticals-confirmed))

(print "")
(print "--- README count cross-refs ---")
(diff thm-readme-ast-fields :replace readme.export-ast-fields-count :with ast_verifier.node-field-count)
(diff thm-readme-demo-paired :replace readme.export-demo-paired-count :with demos.demo-total-count)
(diff thm-readme-lazy-phases :replace readme.export-lazy-phases-count :with lazy_loader.phase-count)
(diff thm-readme-special-forms :replace readme.export-special-forms-count :with lang.special-forms-tuple-size)
(diff thm-readme-ast-api :replace readme.readme-ast-api-listing-count :with ast_verifier.public-api-count)
(diff thm-readme-consistency-layers :replace readme.readme-consistency-layers-listing-count :with engine.consistency-layers-doc-count)
(diff thm-readme-engine-flags :replace readme.readme-engine-flags-listing-count :with engine.export-defaults-doc-count)
(diff thm-readme-operator-categories :replace readme.readme-operator-category-count :with default_system_settings.export-operator-category-count)
(diff thm-readme-parser-stages :replace readme.readme-parser-stages-listing-count :with atoms.export-parser-stages-count)
(diff thm-readme-issue-types :replace readme.export-issue-types-count :with engine.issue-types-impl-count)
(diff thm-readme-manual-categories :replace readme.export-manual-categories-count :with manual-categories-count)

(print "")
(print "========================================")

