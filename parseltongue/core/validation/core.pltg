    :using (engine.export-operators-plain-callables system.export-conditional-side-effects))

; --- Derived from axioms ---
(derive human-in-loop-confirmed util.manual-control-implies-human
    :bind ((?manual-available loader.export-manual-verification) (?human-in-loop readme.readme-documents-engine-human-in-loop))
    :using (util.manual-control-implies-human loader.export-manual-verification readme.readme-documents-engine-human-in-loop))

(derive intersection-lookup-confirmed util.set-implies-fast
    :bind ((?set-indexed engine.export-document-index) (?fast-lookup readme.readme-documents-engine-intersection-lookup))
    :using (util.set-implies-fast engine.export-document-index readme.readme-documents-engine-intersection-lookup))

(derive large-collections-confirmed util.set-implies-fast
    :bind ((?set-indexed engine.export-document-index) (?fast-lookup readme.readme-documents-engine-large-collections))
    :using (util.set-implies-fast engine.export-document-index readme.readme-documents-engine-large-collections))

