(import (quote verify_manual))
; (import (quote self_test))
(import (quote ..std.util))
(import (quote ..std.counting))

(defterm count-exists counting.count-exists :origin "import")
; verify in-place — core loads after verify_manual, so circular dep if done there
(verify-manual (quote count-exists))

(defterm stub util.stub :origin "import")

(print "")
(print "========================================")
(print "  Parseltongue Core — Self-Validation")
(print "========================================")

