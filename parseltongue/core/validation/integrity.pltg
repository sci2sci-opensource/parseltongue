(derive stub-committed-env-merkle-root stub :using (stub))
(derive stub-signed-env-commitment stub :using (stub))
(derive stub-prover-scope-isolation stub :using (stub))
(derive stub-delegate-project-through-prover stub :using (stub))
(derive stub-boolean-only-crosses-scope stub :using (stub))
(derive stub-attack-fake-fact-rejected stub :using (stub))
(derive stub-attack-recommit-detected stub :using (stub))
(derive stub-attack-phantom-fact-rejected stub :using (stub))
(derive stub-attack-underage-returns-false stub :using (stub))
(derive stub-attack-false-result-rejected stub :using (stub))
