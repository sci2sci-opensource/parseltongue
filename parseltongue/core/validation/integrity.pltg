(derive stub-signer-accessible-only-via-delegate stub :using (stub))
(derive stub-conditional-delegate-routes-to-block stub :using (stub))
(derive stub-merkle-over-signed-leaves stub :using (stub))
(derive stub-tamper-detection-via-hash stub :using (stub))
(derive stub-isolated-merkle-cannot-sign stub :using (stub))

; --- PKI via delegation (TestDelegatedPKI) ---
(derive stub-keystore-public-directory stub :using (stub))
(derive stub-ed25519-signing-via-scope stub :using (stub))
(derive stub-x25519-ecdh-key-exchange stub :using (stub))
(derive stub-aes-gcm-encryption stub :using (stub))
(derive stub-delegation-routes-by-role stub :using (stub))
(derive stub-verifier-scope-isolated stub :using (stub))
(derive stub-cross-signing-handshake stub :using (stub))

