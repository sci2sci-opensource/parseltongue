; verify_manual.pltg — Manually verify computed defterms that have no document source.
;
; Computed defterms use :origin (a string) instead of :evidence.
; The consistency checker flags these as "no_evidence".
; verify-manual marks them as manually verified so they pass.

; --- atoms.pltg ---
(verify-manual (quote atoms.reader-doc-count))
(verify-manual (quote atoms.atom-conv-doc-count))
(verify-manual (quote atoms.core-types-doc-count))

; --- engine.pltg ---
(verify-manual (quote engine.consistency-layers-doc-count))
(verify-manual (quote engine.consistency-has-docstring))
