; verify_manual.pltg — Manually verify computed defterms that have no document source.
;
; Computed defterms use :origin (a string) instead of :evidence.
; The consistency checker flags these as "no_evidence".
; verify-manual marks them as manually verified so they pass.
;
; All *-doc-count entries are now self-verifying derives via count-exists.

; --- counting.pltg (axioms have :origin) ---
(verify-manual (quote counting.count-exists))
(verify-manual (quote counting.count-exists-base))
(verify-manual (quote counting.count-exists-step))
(verify-manual (quote counting.sum-values))
(verify-manual (quote counting.sum-values-base))
(verify-manual (quote counting.sum-values-step))

; --- count-exists aliases (defterm :origin "import") ---
(verify-manual (quote atoms.count-exists))
(verify-manual (quote engine.count-exists))
(verify-manual (quote lang.count-exists))
(verify-manual (quote system.count-exists))
(verify-manual (quote quote_verifier.count-exists))
(verify-manual (quote quote_verifier.sum-values))
(verify-manual (quote loader.count-exists))
(verify-manual (quote default_system_settings.count-exists))
(verify-manual (quote demos.count-exists))
(verify-manual (quote readme.count-exists))
(verify-manual (quote pyproject.count-exists))
(verify-manual (quote ast_verifier.count-exists))
(verify-manual (quote lazy_loader.count-exists))

; --- (deleted: readme.readme-documents-splat-patterns — now has :evidence) ---

; --- quote_verifier hypothetical bind scenarios ---
; Calculation artifacts: concrete values to instantiate axiom ?-vars.
; axiom 5 (regular-stopwords-diluted): hypothetical single-stopword-in-5-word-quote scenario
(verify-manual (quote quote_verifier.regular-is-not-dangerous))
(verify-manual (quote quote_verifier.regular-single-count))
(verify-manual (quote quote_verifier.regular-word-count))

; axiom 6 (empty-quote-rejected): hypothetical empty-quote input/return
(verify-manual (quote quote_verifier.empty-has-no-content))
(verify-manual (quote quote_verifier.empty-verified-result))

; axiom 10 (single-stopword-rejected): hypothetical single-stopword-quote input/return
(verify-manual (quote quote_verifier.single-word-is-single))
(verify-manual (quote quote_verifier.single-word-is-stopword))
(verify-manual (quote quote_verifier.remove-stopwords-enabled))
(verify-manual (quote quote_verifier.single-stopword-verified))

; axiom 11 (normalized-to-empty-rejected): hypothetical normalizes-to-empty input/return
(verify-manual (quote quote_verifier.quote-has-content))
(verify-manual (quote quote_verifier.normalized-has-content))
(verify-manual (quote quote_verifier.normalized-empty-verified))

; axiom 13 (score-clamped): hypothetical score after dangerous stopword penalty
(verify-manual (quote quote_verifier.score-after-single-dangerous))

; axiom 14 (config-flag-gates-step): hypothetical disabled-step return
(verify-manual (quote quote_verifier.no-transformations))
