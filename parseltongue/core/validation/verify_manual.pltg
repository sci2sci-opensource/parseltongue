(verify-manual (quote engine.directive-loader-doc-count))
(verify-manual (quote engine.eval-mechanism-doc-count))
(verify-manual (quote engine.derivation-doc-count))
(verify-manual (quote engine.diff-mechanism-doc-count))
(verify-manual (quote engine.fact-mechanism-doc-count))
(verify-manual (quote engine.lifecycle-doc-count))
(verify-manual (quote engine.defaults-doc-count))
(verify-manual (quote engine.consistency-layer-count))

