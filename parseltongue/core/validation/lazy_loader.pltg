; lazy_loader.pltg — Ground truth from lazy_loader.py
;
; LazyLoader extends Loader with fault-tolerant, dependency-aware
; loading. It parses all directives into an AST, builds a dependency
; graph, and executes in topological order. Errors are isolated to
; their dependent subtrees.

(load-document "lazy_loader.py" "../loader/lazy_loader.py")
(import (quote counting))
(defterm count-exists counting.count-exists :origin "import")

; =====================================================================
; LazyLoadResult — 3 tracking fields + 4 methods
; =====================================================================

(fact result-has-errors true
    :evidence (evidence "lazy_loader.py"
        :quotes ("errors: dict[DirectiveNode, Exception] = field(default_factory=dict)")
        :explanation "LazyLoadResult tracks failed nodes with their exceptions"))

(fact result-has-skipped true
    :evidence (evidence "lazy_loader.py"
        :quotes ("skipped: dict[DirectiveNode, DirectiveNode] = field(default_factory=dict)")
        :explanation "Skipped maps each node to the failed dep that caused the skip"))

(fact result-has-loaded true
    :evidence (evidence "lazy_loader.py"
        :quotes ("loaded: set[DirectiveNode] = field(default_factory=set)")
        :explanation "LazyLoadResult tracks successfully loaded nodes"))

(fact result-has-ok true
    :evidence (evidence "lazy_loader.py"
        :quotes ("@property\n    def ok(self) -> bool:\n        return not self.errors")
        :explanation "ok is True when there are no errors"))

(fact result-has-partial true
    :evidence (evidence "lazy_loader.py"
        :quotes ("@property\n    def partial(self) -> bool:\n        return bool(self.errors) and bool(self.loaded)")
        :explanation "partial is True when there are both errors and loaded nodes"))

(fact result-has-root-cause true
    :evidence (evidence "lazy_loader.py"
        :quotes ("def root_cause(self, node: DirectiveNode) -> DirectiveNode | None:\n        \"\"\"Trace a skipped node back to the root error node.\"\"\"")
        :explanation "root_cause traces skip chains to the root error"))

(fact result-has-error-trees true
    :evidence (evidence "lazy_loader.py"
        :quotes ("def error_trees(self) -> dict[DirectiveNode, list[DirectiveNode]]:\n        \"\"\"Map each root error node to the list of nodes it caused to skip.\"\"\"")
        :explanation "error_trees groups cascade by root error"))

(fact result-has-summary true
    :evidence (evidence "lazy_loader.py"
        :quotes ("def summary(self) -> str:")
        :explanation "summary renders a human-readable error report"))

(derive result-field-count
    (count-exists result-has-errors result-has-skipped result-has-loaded)
    :using (count-exists result-has-errors result-has-skipped result-has-loaded))

(derive result-method-count
    (count-exists result-has-ok result-has-partial result-has-root-cause result-has-error-trees result-has-summary)
    :using (count-exists result-has-ok result-has-partial result-has-root-cause result-has-error-trees result-has-summary))

; =====================================================================
; LazyLoader — 4 phases of _load_source
; =====================================================================

(fact phase-1a-parses-all true
    :evidence (evidence "lazy_loader.py"
        :quotes ("# Phase 1a: Parse all expressions, namespace definition names,\n        # but DON'T patch body symbols yet (engine is empty).")
        :explanation "Phase 1a tokenizes and parses all expressions, collects definition names"))

(fact phase-1a-collects-names true
    :evidence (evidence "lazy_loader.py"
        :quotes ("defined_names: set[str] = set()")
        :explanation "Phase 1a builds a set of all definition names for later patching"))

(fact phase-1b-patches-from-names true
    :evidence (evidence "lazy_loader.py"
        :quotes ("# Phase 1b: Now patch body symbols using collected names,\n        # then build DirectiveNodes.")
        :explanation "Phase 1b patches symbols using collected names, not engine state"))

(fact phase-2-resolves-graph true
    :evidence (evidence "lazy_loader.py"
        :quotes ("# Phase 2: Resolve the dependency graph\n        resolve_graph(nodes)")
        :explanation "Phase 2 links nodes into a DAG via resolve_graph"))

(fact phase-3-executes-effects true
    :evidence (evidence "lazy_loader.py"
        :quotes ("# Phase 3: Separate effects from named directives")
        :explanation "Phase 3 executes effects (import, print, etc.) in order"))

(fact phase-4-topological-exec true
    :evidence (evidence "lazy_loader.py"
        :quotes ("# Phase 4: Topological execution of named directives")
        :explanation "Phase 4 executes named directives respecting dependencies"))

(derive phase-count
    (count-exists phase-1a-parses-all phase-1b-patches-from-names phase-2-resolves-graph phase-3-executes-effects phase-4-topological-exec)
    :using (count-exists phase-1a-parses-all phase-1b-patches-from-names phase-2-resolves-graph phase-3-executes-effects phase-4-topological-exec))

; =====================================================================
; Fault tolerance mechanisms
; =====================================================================

(fact catches-parse-errors true
    :evidence (evidence "lazy_loader.py"
        :quotes ("try:\n                expr = read_tokens(tokens)\n            except SyntaxError as e:\n                err_node = DirectiveNode(\n                    name=None, expr=[], dep_names=set(),\n                    kind=\"error\", source_file=self._current.current_file,\n                    source_order=order,\n                )")
        :explanation "Parse errors create error nodes instead of crashing"))

(fact catches-effect-errors true
    :evidence (evidence "lazy_loader.py"
        :quotes ("for node in effect_nodes:\n            try:\n                _execute_directive(system.engine, node.expr)\n            except Exception as e:")
        :explanation "Effect execution errors are caught and recorded"))

(fact catches-directive-errors true
    :evidence (evidence "lazy_loader.py"
        :quotes ("try:\n                _execute_directive(system.engine, node.expr)\n                executed.add(node.name)\n                if self._result:\n                    self._result.loaded.add(node)\n                return True\n            except Exception as e:\n                self._failed_names[node.name] = node")
        :explanation "Directive execution errors are caught and recorded"))

(fact checks-intra-module-deps true
    :evidence (evidence "lazy_loader.py"
        :quotes ("# Check intra-module children (graph-linked dependencies)\n            for child in node.children:\n                if not _execute_node(child):")
        :explanation "Phase 4 checks graph-linked children before executing"))

(fact checks-cross-module-deps true
    :evidence (evidence "lazy_loader.py"
        :quotes ("# Check cross-module dependencies (not graph-linked)\n            for dep_name in node.dep_names:\n                if dep_name in self._failed_names:")
        :explanation "Phase 4 checks global failed names for cross-module deps"))

(fact tracks-failed-globally true
    :evidence (evidence "lazy_loader.py"
        :quotes ("self._failed_names: dict[str, DirectiveNode] = {}  # global across modules")
        :explanation "Failed names are tracked globally across all modules"))

(derive fault-tolerance-count
    (count-exists catches-parse-errors catches-effect-errors catches-directive-errors
                  checks-intra-module-deps checks-cross-module-deps tracks-failed-globally)
    :using (count-exists catches-parse-errors catches-effect-errors catches-directive-errors
                         checks-intra-module-deps checks-cross-module-deps tracks-failed-globally))

; =====================================================================
; _patch_symbols_from_names — key difference from standard loader
; =====================================================================

(fact patch-from-names-exists true
    :evidence (evidence "lazy_loader.py"
        :quotes ("def _patch_symbols_from_names(self, expr, known_names, skip_index=None):")
        :explanation "LazyLoader has its own patching that uses collected names"))

(fact patch-from-names-checks-set true
    :evidence (evidence "lazy_loader.py"
        :quotes ("candidate = f\"{self._current.module_name}.{item}\"\n                if candidate in known_names:")
        :explanation "Patches against pre-collected name set, not engine state"))

; =====================================================================
; Axioms: behavioral invariants
; =====================================================================

(axiom failed-deps-cascade
    (implies ?dep-failed ?dependent-skipped)
    :evidence (evidence "lazy_loader.py"
        :quotes ("for child in node.children:\n                if not _execute_node(child):\n                    self._failed_names[node.name] = node\n                    if self._result:\n                        self._result.skipped[node] = child")
        :explanation "If a dependency fails, all its dependents are skipped"))

(axiom cross-module-failures-propagate
    (implies ?cross-dep-failed ?cross-dependent-skipped)
    :evidence (evidence "lazy_loader.py"
        :quotes ("for dep_name in node.dep_names:\n                if dep_name in self._failed_names:\n                    failed_dep = self._failed_names[dep_name]\n                    self._failed_names[node.name] = node")
        :explanation "Cross-module failures propagate via global failed_names"))

(axiom parse-errors-dont-crash
    (implies ?syntax-error ?error-recorded)
    :evidence (evidence "lazy_loader.py"
        :quotes ("except SyntaxError as e:\n                err_node = DirectiveNode(\n                    name=None, expr=[], dep_names=set(),\n                    kind=\"error\"")
        :explanation "Syntax errors produce error nodes, don't crash the loader"))

(axiom root-cause-traces-to-error
    (implies ?node-skipped ?root-in-errors)
    :evidence (evidence "lazy_loader.py"
        :quotes ("while current in self.skipped and id(current) not in seen:\n            seen.add(id(current))\n            current = self.skipped[current]\n        return current if current in self.errors else None")
        :explanation "root_cause follows skip chain until it reaches an error node"))

; =====================================================================
; Entry points: lazy_load_pltg and LazyLoader.load_main
; =====================================================================

(fact has-lazy-load-pltg true
    :evidence (evidence "lazy_loader.py"
        :quotes ("def lazy_load_pltg(path: str, effects: dict[str, Any] | None = None, **system_kwargs) -> LazyLoadResult:")
        :explanation "Module exports lazy_load_pltg convenience function"))

(fact has-load-main true
    :evidence (evidence "lazy_loader.py"
        :quotes ("def load_main(self, path: str, effects: dict[str, Any] | None = None, **system_kwargs) -> System:")
        :explanation "LazyLoader overrides load_main"))

(fact has-ast-property true
    :evidence (evidence "lazy_loader.py"
        :quotes ("@property\n    def ast(self) -> list[DirectiveNode]:\n        \"\"\"All parsed DirectiveNodes from the most recent load.\"\"\"\n        return self._all_nodes")
        :explanation "LazyLoader exposes the full AST via .ast property"))

(derive entry-point-count
    (count-exists has-lazy-load-pltg has-load-main has-ast-property)
    :using (count-exists has-lazy-load-pltg has-load-main has-ast-property))

; =====================================================================
; Docstring layer — LazyLoadResult names its fields
; =====================================================================

(fact doc-result-errors true
    :evidence (evidence "lazy_loader.py"
        :quotes ("``errors``  maps failed DirectiveNode -> Exception (root causes).")
        :explanation "Result docstring documents errors field"))

(fact doc-result-skipped true
    :evidence (evidence "lazy_loader.py"
        :quotes ("``skipped`` maps skipped DirectiveNode -> the DirectiveNode whose\n                failure caused the skip (walk .children to trace).")
        :explanation "Result docstring documents skipped field"))

(fact doc-result-loaded true
    :evidence (evidence "lazy_loader.py"
        :quotes ("``loaded``  is the set of DirectiveNodes that executed successfully.")
        :explanation "Result docstring documents loaded field"))

(derive doc-result-field-count
    (count-exists doc-result-errors doc-result-skipped doc-result-loaded)
    :using (count-exists doc-result-errors doc-result-skipped doc-result-loaded))

; =====================================================================
; Docstring layer — LazyLoader phase list
; =====================================================================

(fact doc-phase-parse true
    :evidence (evidence "lazy_loader.py"
        :quotes ("1. Parse all directives into DirectiveNodes")
        :explanation "Docstring lists phase 1: parse"))

(fact doc-phase-resolve true
    :evidence (evidence "lazy_loader.py"
        :quotes ("2. Resolve the dependency graph (children/dependents)")
        :explanation "Docstring lists phase 2: resolve"))

(fact doc-phase-execute true
    :evidence (evidence "lazy_loader.py"
        :quotes ("3. Execute effects immediately, named directives topologically")
        :explanation "Docstring lists phase 3: execute"))

(fact doc-phase-error true
    :evidence (evidence "lazy_loader.py"
        :quotes ("4. On error, record the node and skip its dependent subtree")
        :explanation "Docstring lists phase 4: error handling"))

(derive doc-phase-count
    (count-exists doc-phase-parse doc-phase-resolve doc-phase-execute doc-phase-error)
    :using (count-exists doc-phase-parse doc-phase-resolve doc-phase-execute doc-phase-error))

; =====================================================================
; Docstring layer — method docstrings
; =====================================================================

(fact doc-root-cause true
    :evidence (evidence "lazy_loader.py"
        :quotes ("Trace a skipped node back to the root error node.")
        :explanation "root_cause docstring"))

(fact doc-error-trees true
    :evidence (evidence "lazy_loader.py"
        :quotes ("Map each root error node to the list of nodes it caused to skip.")
        :explanation "error_trees docstring"))

; =====================================================================
; Items × Layers diffs — docstring vs implementation
; =====================================================================

; Result docstring names 3 fields, impl has 3 fields
(diff result-doc-vs-impl :replace doc-result-field-count :with result-field-count)

; Docstring lists 4 phases, impl has 5 (1a+1b split)
(diff doc-phase-vs-impl :replace doc-phase-count :with phase-count)

; Result field paired: docstring + impl for each field
(derive result-field-paired
    (count-exists (and doc-result-errors result-has-errors)
                  (and doc-result-skipped result-has-skipped)
                  (and doc-result-loaded result-has-loaded))
    :using (count-exists
            doc-result-errors result-has-errors
            doc-result-skipped result-has-skipped
            doc-result-loaded result-has-loaded))

(diff result-field-paired-vs-doc :replace result-field-paired :with doc-result-field-count)

; Method paired: docstring + impl for root_cause and error_trees
(derive method-doc-paired
    (count-exists (and doc-root-cause result-has-root-cause)
                  (and doc-error-trees result-has-error-trees))
    :using (count-exists
            doc-root-cause result-has-root-cause
            doc-error-trees result-has-error-trees))

; ok, partial, summary have no separate docstring facts — count the ones that do
(derive method-with-doc-count
    (count-exists result-has-root-cause result-has-error-trees)
    :using (count-exists result-has-root-cause result-has-error-trees))

(diff method-doc-vs-impl :replace method-doc-paired :with method-with-doc-count)

; =====================================================================
; Axiom instantiations — binding ?-vars to concrete facts
; =====================================================================

; failed-deps-cascade: ?dep-failed → ?dependent-skipped
; Bind: directive error catching → skipped dict population
(derive cascade-produces-skipped failed-deps-cascade
    :bind ((?dep-failed catches-directive-errors) (?dependent-skipped result-has-skipped))
    :using (failed-deps-cascade catches-directive-errors result-has-skipped))

; cross-module-failures-propagate: ?cross-dep-failed → ?cross-dependent-skipped
; Bind: cross-module dep checking → global tracking
(derive cross-module-produces-tracking cross-module-failures-propagate
    :bind ((?cross-dep-failed checks-cross-module-deps) (?cross-dependent-skipped tracks-failed-globally))
    :using (cross-module-failures-propagate checks-cross-module-deps tracks-failed-globally))

; parse-errors-dont-crash: ?syntax-error → ?error-recorded
; Bind: parse error catching → errors dict population
(derive parse-errors-produce-result parse-errors-dont-crash
    :bind ((?syntax-error catches-parse-errors) (?error-recorded result-has-errors))
    :using (parse-errors-dont-crash catches-parse-errors result-has-errors))

; root-cause-traces-to-error: ?node-skipped → ?root-in-errors
; Bind: root_cause method → error_trees grouping
(derive root-cause-enables-trees root-cause-traces-to-error
    :bind ((?node-skipped result-has-root-cause) (?root-in-errors result-has-error-trees))
    :using (root-cause-traces-to-error result-has-root-cause result-has-error-trees))

; Diff the instantiation results against the facts they bind to
(diff cascade-vs-skipped :replace cascade-produces-skipped :with result-has-skipped)
(diff cross-module-vs-tracking :replace cross-module-produces-tracking :with tracks-failed-globally)
(diff parse-error-vs-result :replace parse-errors-produce-result :with result-has-errors)
(diff root-cause-vs-trees :replace root-cause-enables-trees :with result-has-error-trees)

; =====================================================================
; Patching: docstring + impl paired
; =====================================================================

(fact doc-patch-resolves-names true
    :evidence (evidence "lazy_loader.py"
        :quotes ("Like _patch_symbols but resolves against a set of known names\n        instead of checking the engine.")
        :explanation "Docstring says patches against name set, not engine"))

; Phase 1a collects names, phase 1b uses them for patching
(derive name-collection-enables-patching
    (and phase-1a-collects-names patch-from-names-checks-set)
    :using (phase-1a-collects-names phase-1b-patches-from-names patch-from-names-checks-set))

; Patching: docstring claim + method exists + checks set — all paired
(derive patch-paired
    (count-exists (and doc-patch-resolves-names patch-from-names-exists)
                  (and doc-patch-resolves-names patch-from-names-checks-set))
    :using (count-exists doc-patch-resolves-names patch-from-names-exists patch-from-names-checks-set))

(diff patch-paired-vs-name-collection :replace patch-paired :with name-collection-enables-patching)
