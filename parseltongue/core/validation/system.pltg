; system.pltg — Ground truth and internal validation for system.py

(load-document "system.py" "../system.py")
(import (quote counting))
(defterm count-exists counting.count-exists :origin "import")

; =====================================================================
; System class — documented contract
; =====================================================================

(fact system-docstring "Composes Engine with default operators, serialization, and introspection."
    :evidence (evidence "system.py"
        :quotes ("Composes Engine with default operators, serialization, and introspection.")
        :explanation "System's self-description"))

; =====================================================================
; Constructor parameters
; =====================================================================

(fact system-overridable-default false
    :evidence (evidence "system.py"
        :quotes ("overridable: bool = False")
        :explanation "Defaults to non-overridable"))

(fact system-initial-env-default "None"
    :evidence (evidence "system.py"
        :quotes ("initial_env: dict | None = None")
        :explanation "initial_env defaults to None (uses DEFAULT_OPERATORS)"))

(fact system-docs-default "None"
    :evidence (evidence "system.py"
        :quotes ("docs: dict | None = None")
        :explanation "docs defaults to None (uses ENGINE_DOCS)"))

(fact system-strict-derive-default true
    :evidence (evidence "system.py"
        :quotes ("strict_derive: bool = True")
        :explanation "strict_derive defaults True"))

(fact system-effects-param true
    :evidence (evidence "system.py"
        :quotes ("effects: dict[str, Callable] | None = None")
        :explanation "System accepts effects"))

; =====================================================================
; Delegation to Engine
; =====================================================================

; System delegates everything to engine — it's a facade
(fact system-delegates-evaluate true
    :evidence (evidence "system.py"
        :quotes ("return self.engine.evaluate(expr, local_env)")
        :explanation "evaluate delegates to engine"))

(fact system-delegates-consistency true
    :evidence (evidence "system.py"
        :quotes ("return self.engine.consistency()")
        :explanation "consistency delegates to engine"))

(fact system-delegates-derive true
    :evidence (evidence "system.py"
        :quotes ("return self.engine.derive(name, wff, using)")
        :explanation "derive delegates to engine"))

; =====================================================================
; Properties — what System exposes
; =====================================================================

(fact system-exposes-facts true
    :evidence (evidence "system.py"
        :quotes ("return self.engine.facts")
        :explanation "facts property"))

(fact system-exposes-axioms true
    :evidence (evidence "system.py"
        :quotes ("return self.engine.axioms")
        :explanation "axioms property"))

(fact system-exposes-theorems true
    :evidence (evidence "system.py"
        :quotes ("return self.engine.theorems")
        :explanation "theorems property"))

(fact system-exposes-terms true
    :evidence (evidence "system.py"
        :quotes ("return self.engine.terms")
        :explanation "terms property"))

(fact system-exposes-diffs true
    :evidence (evidence "system.py"
        :quotes ("return self.engine.diffs")
        :explanation "diffs property"))

(fact system-exposes-documents true
    :evidence (evidence "system.py"
        :quotes ("return self.engine.documents")
        :explanation "documents property"))

; =====================================================================
; Provenance — traversal logic
; =====================================================================

(fact provenance-returns-dict true
    :evidence (evidence "system.py"
        :quotes ("def provenance(self, name: str) -> dict:")
        :explanation "provenance returns a dict"))

(fact provenance-checks-facts true
    :evidence (evidence "system.py"
        :quotes ("if name in self.engine.facts:")
        :explanation "provenance checks facts"))

(fact provenance-checks-axioms true
    :evidence (evidence "system.py"
        :quotes ("if name in self.engine.axioms:")
        :explanation "provenance checks axioms"))

(fact provenance-checks-terms true
    :evidence (evidence "system.py"
        :quotes ("if name in self.engine.terms:")
        :explanation "provenance checks terms"))

(fact provenance-checks-theorems true
    :evidence (evidence "system.py"
        :quotes ("if name in self.engine.theorems:")
        :explanation "provenance checks theorems"))

(fact provenance-checks-diffs true
    :evidence (evidence "system.py"
        :quotes ("if name in self.engine.diffs:")
        :explanation "provenance checks diffs"))

; provenance recurses for theorems — follows derivation chain
(fact provenance-recurses-for-theorems true
    :evidence (evidence "system.py"
        :quotes ("\"derivation_chain\": [self.provenance(dep) for dep in thm.derivation]")
        :explanation "Theorem provenance recursively expands derivation"))

; =====================================================================
; Serialization — to_dict / from_dict
; =====================================================================

(fact system-serializes-terms true
    :evidence (evidence "system.py"
        :quotes ("\"terms\": {n: serialize_term(t) for n, t in self.engine.terms.items()}")
        :explanation "to_dict serializes terms"))

(fact system-serializes-facts true
    :evidence (evidence "system.py"
        :quotes ("\"facts\": {n: serialize_fact(f) for n, f in self.engine.facts.items()}")
        :explanation "to_dict serializes facts"))

(fact system-serializes-axioms true
    :evidence (evidence "system.py"
        :quotes ("\"axioms\": {n: serialize_axiom(a) for n, a in self.engine.axioms.items()}")
        :explanation "to_dict serializes axioms"))

(fact system-serializes-theorems true
    :evidence (evidence "system.py"
        :quotes ("\"theorems\": {n: serialize_theorem(t) for n, t in self.engine.theorems.items()}")
        :explanation "to_dict serializes theorems"))

; =====================================================================
; Internal consistency
; =====================================================================

; System docstring says "serialization" — Engine docstring says "No serialization"
; System wraps Engine and ADDS serialization — this is intentional and consistent
(derive system-adds-what-engine-lacks
    (and system-serializes-terms system-serializes-facts system-serializes-axioms system-serializes-theorems)
    :using (system-serializes-terms system-serializes-facts system-serializes-axioms system-serializes-theorems))

; Effects are injected into engine.env with system auto-injected as first arg
(fact effects-auto-inject-system true
    :evidence (evidence "system.py"
        :quotes ("self.engine.env[Symbol(name)] = lambda *args, _fn=fn: _fn(self, *args)")
        :explanation "Effects receive system as first arg automatically"))

; load_source is a module-level function, not a method
(fact load-source-is-module-fn true
    :evidence (evidence "system.py"
        :quotes ("def load_source(system: System, source: str):")
        :explanation "load_source is a standalone function"))

; =====================================================================
; Code vs Docs — two-branch-then-diff
; =====================================================================

; --- 1. Constructor parameters ---

(derive constructor-params-doc-count
    (count-exists system-docstring (= system-overridable-default false) system-strict-derive-default system-effects-param system-initial-env-default system-docs-default)
    :using (count-exists counting.count-exists-base counting.count-exists-step
            system-docstring system-overridable-default system-strict-derive-default system-effects-param system-initial-env-default system-docs-default))

(defterm constructor-params-impl-count 6
    :evidence (evidence "system.py"
        :quotes ("Composes Engine with default operators" "overridable: bool = False" "strict_derive: bool = True" "effects: dict[str, Callable] | None = None" "initial_env: dict | None = None" "docs: dict | None = None")
        :explanation "6 constructor features in source"))

(diff constructor-params-coverage
    :replace constructor-params-doc-count
    :with constructor-params-impl-count)

; --- 2. Delegation ---

(derive delegation-doc-count
    (count-exists system-delegates-evaluate system-delegates-consistency system-delegates-derive)
    :using (count-exists counting.count-exists-base counting.count-exists-step
            system-delegates-evaluate system-delegates-consistency system-delegates-derive))

(defterm delegation-impl-count 3
    :evidence (evidence "system.py"
        :quotes ("return self.engine.evaluate(expr, local_env)" "return self.engine.consistency()" "return self.engine.derive(name, wff, using)")
        :explanation "3 delegation methods in source"))

(diff delegation-coverage
    :replace delegation-doc-count
    :with delegation-impl-count)

; --- 3. Exposed properties ---

(derive properties-doc-count
    (count-exists system-exposes-facts system-exposes-axioms system-exposes-theorems system-exposes-terms system-exposes-diffs system-exposes-documents)
    :using (count-exists counting.count-exists-base counting.count-exists-step
            system-exposes-facts system-exposes-axioms system-exposes-theorems system-exposes-terms system-exposes-diffs system-exposes-documents))

(defterm properties-impl-count 6
    :evidence (evidence "system.py"
        :quotes ("return self.engine.facts" "return self.engine.axioms" "return self.engine.theorems" "return self.engine.terms" "return self.engine.diffs" "return self.engine.documents")
        :explanation "6 property accessors in source"))

(diff properties-coverage
    :replace properties-doc-count
    :with properties-impl-count)

; --- 4. Provenance ---

(derive provenance-doc-count
    (count-exists provenance-returns-dict provenance-checks-facts provenance-checks-axioms provenance-checks-terms provenance-checks-theorems provenance-checks-diffs provenance-recurses-for-theorems)
    :using (count-exists counting.count-exists-base counting.count-exists-step
            provenance-returns-dict provenance-checks-facts provenance-checks-axioms provenance-checks-terms provenance-checks-theorems provenance-checks-diffs provenance-recurses-for-theorems))

(defterm provenance-impl-count 7
    :evidence (evidence "system.py"
        :quotes ("def provenance(self, name: str) -> dict:" "if name in self.engine.facts:" "if name in self.engine.axioms:" "if name in self.engine.terms:" "if name in self.engine.theorems:" "if name in self.engine.diffs:" "\"derivation_chain\": [self.provenance(dep) for dep in thm.derivation]")
        :explanation "7 provenance features in source"))

(diff provenance-coverage
    :replace provenance-doc-count
    :with provenance-impl-count)

; --- 5. Effects + load_source ---

(derive effects-doc-count
    (count-exists effects-auto-inject-system load-source-is-module-fn)
    :using (count-exists counting.count-exists-base counting.count-exists-step
            effects-auto-inject-system load-source-is-module-fn))

(defterm effects-impl-count 2
    :evidence (evidence "system.py"
        :quotes ("self.engine.env[Symbol(name)] = lambda *args, _fn=fn: _fn(self, *args)" "def load_source(system: System, source: str):")
        :explanation "2 effects features in source"))

(diff effects-coverage
    :replace effects-doc-count
    :with effects-impl-count)
