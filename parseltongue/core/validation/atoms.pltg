; atoms.pltg — Ground truth and internal validation for atoms.py

(load-document "atoms.py" "../atoms.py")
(import (quote counting))
(defterm count-exists counting.count-exists :origin "import")

; =====================================================================
; Module contract — what the docstring promises
; =====================================================================

(fact module-claims-pure-types true
    :evidence (evidence "atoms.py"
        :quotes ("Pure types, s-expression reader/printer.")
        :explanation "Module docstring claims pure types"))

(fact module-claims-no-domain true
    :evidence (evidence "atoms.py"
        :quotes ("No domain knowledge, no state.")
        :explanation "Module docstring claims no domain knowledge"))

; Axiom: purity implies immutability — pure types should be frozen
(axiom purity-implies-immutable
    (implies ?pure (not ?mutable))
    :evidence (evidence "atoms.py"
        :quotes ("Pure types, s-expression reader/printer.
No domain knowledge, no state.")
        :explanation "Module docstring claims both purity and statelessness — pure types with no state should be immutable"))

; Code facts: frozen/immutable status of each atom type
(fact symbol-is-immutable true
    :evidence (evidence "atoms.py"
        :quotes ("class Symbol(str):")
        :explanation "Symbol inherits from str — immutable by construction"))

(fact evidence-is-frozen false
    :evidence (evidence "atoms.py"
        :quotes ("verified: bool = False")
        :explanation "Evidence has mutable field 'verified' — not a frozen dataclass"))

(fact axiom-class-is-frozen false
    :evidence (evidence "atoms.py"
        :quotes ("@dataclass
class Axiom:")
        :explanation "Axiom uses @dataclass without frozen=True"))

(fact theorem-class-is-frozen false
    :evidence (evidence "atoms.py"
        :quotes ("@dataclass
class Theorem:")
        :explanation "Theorem uses @dataclass without frozen=True"))

(fact term-class-is-frozen false
    :evidence (evidence "atoms.py"
        :quotes ("@dataclass
class Term:")
        :explanation "Term uses @dataclass without frozen=True"))

; =====================================================================
; Symbol
; =====================================================================

(fact symbol-base-class "str"
    :evidence (evidence "atoms.py"
        :quotes ("class Symbol(str):")
        :explanation "Symbol subclasses str"))

(fact symbol-docstring "A symbol in Parseltongue. Just a string with a distinct type."
    :evidence (evidence "atoms.py"
        :quotes ("A symbol in Parseltongue. Just a string with a distinct type.")
        :explanation "Symbol's documented purpose"))

; =====================================================================
; Evidence — the grounding mechanism
; =====================================================================

(fact evidence-docstring "Structured evidence with verifiable quotes from a source document."
    :evidence (evidence "atoms.py"
        :quotes ("Structured evidence with verifiable quotes from a source document.")
        :explanation "Evidence's documented purpose"))

(fact evidence-verified-default false
    :evidence (evidence "atoms.py"
        :quotes ("verified: bool = False")
        :explanation "Not verified until proven"))

(fact evidence-verify-manual-default false
    :evidence (evidence "atoms.py"
        :quotes ("verify_manual: bool = False")
        :explanation "Not manually verified by default"))

(fact evidence-grounded-doc "Evidence is grounded if verified or manually verified."
    :evidence (evidence "atoms.py"
        :quotes ("Evidence is grounded if verified or manually verified.")
        :explanation "is_grounded docstring"))

(fact evidence-grounded-impl "verified-or-manual"
    :evidence (evidence "atoms.py"
        :quotes ("return self.verified or self.verify_manual")
        :explanation "is_grounded implementation"))

; Axiom: grounding requires either verification or manual override
(axiom grounding-rule (= (or ?verified ?manual) ?grounded)
    :evidence (evidence "atoms.py"
        :quotes ("return self.verified or self.verify_manual")
        :explanation "Grounding is disjunction of verified and verify_manual"))

; Derive: default evidence is ungrounded (both defaults are false)
(derive default-evidence-ungrounded
    (= (or evidence-verified-default evidence-verify-manual-default) false)
    :using (evidence-verified-default evidence-verify-manual-default))

; Grounding conditions from docstring — what must be true for grounding
(fact grounding-path-verified true
    :evidence (evidence "atoms.py"
        :quotes ("Evidence is grounded if verified or manually verified.")
        :explanation "Docstring names 'verified' as first grounding path"))

(fact grounding-path-verify-manual true
    :evidence (evidence "atoms.py"
        :quotes ("return self.verified or self.verify_manual")
        :explanation "Implementation confirms verify_manual as second grounding path"))

; =====================================================================
; Axiom class — what it documents about itself
; =====================================================================

(fact axiom-docstring "An axiom: a foundational WFF assumed true, with evidence."
    :evidence (evidence "atoms.py"
        :quotes ("An axiom: a foundational WFF assumed true, with evidence.")
        :explanation "Axiom's self-description"))

(fact axiom-has-origin true
    :evidence (evidence "atoms.py"
        :quotes ("origin: \"str | Evidence\"")
        :explanation "Axiom tracks its origin"))

; Axiom: every axiom carries origin (str or Evidence)
(axiom origin-is-provenance (= ?origin ?provenance)
    :evidence (evidence "atoms.py"
        :quotes ("origin: \"str | Evidence\"")
        :explanation "Origin is the provenance mechanism"))

; =====================================================================
; Theorem class
; =====================================================================

(fact theorem-docstring "A theorem: a WFF derived from facts, axioms, terms, or other theorems."
    :evidence (evidence "atoms.py"
        :quotes ("A theorem: a WFF derived from facts, axioms, terms, or other theorems.")
        :explanation "Theorem's self-description"))

(fact theorem-default-origin "derived"
    :evidence (evidence "atoms.py"
        :quotes ("origin: \"str | Evidence\" = \"derived\"")
        :explanation "Theorem origin defaults to derived"))

(fact theorem-has-derivation true
    :evidence (evidence "atoms.py"
        :quotes ("derivation: list")
        :explanation "Theorem records what it was derived from"))

; Theorem docstring says "derived from axioms/terms via substitution"
; but derivation list can also include facts and other theorems
; Both facts answer: "does the docstring document all derivation sources?"
(fact theorem-doc-covers-all-sources true
    :evidence (evidence "atoms.py"
        :quotes ("A theorem: a WFF derived from facts, axioms, terms, or other theorems.")
        :explanation "Docstring lists all derivation source types"))

(fact theorem-impl-accepts-all-sources true
    :evidence (evidence "atoms.py"
        :quotes ("derivation: list")
        :explanation "Derivation list accepts any source type"))

(diff theorem-derivation-sources
    :replace theorem-doc-covers-all-sources
    :with theorem-impl-accepts-all-sources)

; =====================================================================
; Term class
; =====================================================================

(fact term-docstring "A term/concept/primitive introduced into the system."
    :evidence (evidence "atoms.py"
        :quotes ("A term/concept/primitive introduced into the system.")
        :explanation "Term's self-description"))

(fact term-forward-decl-display "(primitive)"
    :evidence (evidence "atoms.py"
        :quotes ("if self.definition is not None else \"(primitive)\"")
        :explanation "Forward-declared terms display as (primitive)"))

; =====================================================================
; Reader pipeline: tokenize -> read_tokens -> atom
; =====================================================================

(fact tokenize-doc "Tokenize s-expression source into atoms and parens."
    :evidence (evidence "atoms.py"
        :quotes ("Tokenize s-expression source into atoms and parens.")
        :explanation "tokenize docstring"))

(fact comment-char ";"
    :evidence (evidence "atoms.py"
        :quotes ("if char == \";\":")
        :explanation "Semicolon starts comments"))

(fact read-tokens-doc "Recursively parse token list into nested Python structures."
    :evidence (evidence "atoms.py"
        :quotes ("Recursively parse token list into nested Python structures.")
        :explanation "read_tokens docstring"))

(fact atom-doc "Convert a token string to a typed value."
    :evidence (evidence "atoms.py"
        :quotes ("Convert a token string to a typed value.")
        :explanation "atom docstring"))

; atom() conversion chain: int -> float -> bool -> string -> keyword -> Symbol
(fact atom-tries-int-first true
    :evidence (evidence "atoms.py"
        :quotes ("return int(token)")
        :explanation "First tries int conversion"))

(fact atom-tries-float-second true
    :evidence (evidence "atoms.py"
        :quotes ("return float(token)")
        :explanation "Then tries float"))

(fact atom-keyword-prefix ":"
    :evidence (evidence "atoms.py"
        :quotes ("if token.startswith(\":\"):")
        :explanation "Colon-prefixed tokens stay as strings"))

(fact atom-fallback-is-symbol true
    :evidence (evidence "atoms.py"
        :quotes ("return Symbol(token)")
        :explanation "Everything else becomes a Symbol"))

; =====================================================================
; parse / parse_all contract
; =====================================================================

(fact parse-doc "Parse a source string into an s-expression."
    :evidence (evidence "atoms.py"
        :quotes ("Parse a source string into an s-expression.")
        :explanation "parse docstring"))

(fact parse-all-doc "Parse all top-level s-expressions from source."
    :evidence (evidence "atoms.py"
        :quotes ("Parse all top-level s-expressions from source.")
        :explanation "parse_all docstring"))

; parse is tokenize + single read_tokens
; parse_all is tokenize + loop of read_tokens
; Theorem: parse_all on single-expression input returns [parse(input)]

; =====================================================================
; to_sexp — roundtrip printer
; =====================================================================

(fact to-sexp-doc "Pretty-print a Python object back to s-expression string."
    :evidence (evidence "atoms.py"
        :quotes ("Pretty-print a Python object back to s-expression string.")
        :explanation "to_sexp docstring"))

(fact to-sexp-bool-true "true"
    :evidence (evidence "atoms.py"
        :quotes ("return \"true\" if obj else \"false\"")
        :explanation "Booleans print as true/false"))

(fact to-sexp-bool-false "false"
    :evidence (evidence "atoms.py"
        :quotes ("return \"true\" if obj else \"false\"")
        :explanation "to_sexp prints False as 'false'"))

; =====================================================================
; DSL helpers — match, free_vars, substitute
; =====================================================================

(fact match-doc "Match pattern against expr. ?-prefixed symbols are pattern variables."
    :evidence (evidence "atoms.py"
        :quotes ("Match pattern against expr. ?-prefixed symbols are pattern variables.")
        :explanation "match docstring"))

(fact free-vars-doc "Extract all ?-prefixed symbols from an expression."
    :evidence (evidence "atoms.py"
        :quotes ("Extract all ?-prefixed symbols from an expression.")
        :explanation "free_vars docstring"))

(fact substitute-doc "Replace symbols with their bound values in an expression tree."
    :evidence (evidence "atoms.py"
        :quotes ("Replace symbols with their bound values in an expression tree.")
        :explanation "substitute docstring"))

; Splat pattern support — docstring ground truth
(fact match-splat-doc true
    :evidence (evidence "atoms.py"
        :quotes ("A ``?...name`` symbol as the last element of a list pattern matches
    zero or more remaining elements, bound as a list.")
        :explanation "match docstring documents ?... splat pattern support"))

(fact substitute-splat-doc true
    :evidence (evidence "atoms.py"
        :quotes ("``?...name`` bindings are spliced into the parent list rather than
    inserted as a nested list.")
        :explanation "substitute docstring documents ?... splicing behavior"))

; Axiom: match produces bindings that substitute can consume
(axiom match-substitute-roundtrip
    (= (implies (?bindings ?pattern ?expr) (= ?expr (?substitute ?pattern ?bindings))) true)
    :evidence (evidence "atoms.py"
        :quotes ("Match pattern against expr. ?-prefixed symbols are pattern variables."
                 "Replace symbols with their bound values in an expression tree.")
        :explanation "match and substitute are inverses — match extracts bindings, substitute applies them"))

; =====================================================================
; Internal consistency: module contract vs content
; =====================================================================

; Module says "No state" — verify no mutable module-level state
; atoms.py has no module-level mutable state — only classes and functions. Consistent.

(derive module-is-stateless
    (and module-claims-pure-types module-claims-no-domain)
    :using (module-claims-pure-types module-claims-no-domain))

; atom() true/false token values
(fact atom-true-token "true"
    :evidence (evidence "atoms.py"
        :quotes ("if token == \"true\":")
        :explanation "true token"))

(fact atom-false-token "false"
    :evidence (evidence "atoms.py"
        :quotes ("if token == \"false\":")
        :explanation "false token"))

; Derive: atom() and to_sexp are roundtrip-compatible for booleans
; atom("true") -> True, to_sexp(True) -> "true"
(derive bool-roundtrip-consistent
    (= atom-true-token to-sexp-bool-true)
    :using (atom-true-token to-sexp-bool-true))

; Evidence str format uses is_grounded to decide status label
(defterm evidence-unverified-status "UNVERIFIED"
    :evidence (evidence "atoms.py"
        :quotes ("status = \"grounded\" if self.is_grounded else \"UNVERIFIED\"")
        :explanation "Unverified evidence displays UNVERIFIED"))

(defterm evidence-grounded-status "grounded"
    :evidence (evidence "atoms.py"
        :quotes ("status = \"grounded\" if self.is_grounded else \"UNVERIFIED\"")
        :explanation "Grounded evidence displays grounded"))

; Term display logic: primitive vs computed
(fact term-has-body-display "to_sexp"
    :evidence (evidence "atoms.py"
        :quotes ("to_sexp(self.definition)")
        :explanation "Terms with a body display via to_sexp"))

(fact term-definition-check "self.definition is not None"
    :evidence (evidence "atoms.py"
        :quotes ("if self.definition is not None")
        :explanation "Display branches on whether definition exists"))

(axiom term-display-rule
    (if ?has-definition ?to-sexp ?primitive)
    :evidence (evidence "atoms.py"
        :quotes ("to_sexp(self.definition) if self.definition is not None else \"(primitive)\"")
        :explanation "If has definition show sexp, else show (primitive)"))

; Display says "primitive" — does the docstring agree?
(fact term-display-says-primitive true
    :evidence (evidence "atoms.py"
        :quotes ("(primitive)")
        :explanation "Forward-declared terms display as primitive"))

(fact term-docstring-says-primitive true
    :evidence (evidence "atoms.py"
        :quotes ("A term/concept/primitive introduced into the system.")
        :explanation "Docstring includes primitive"))

(diff term-label-consistency
    :replace term-display-says-primitive
    :with term-docstring-says-primitive)

(derive term-display-documented
    (and term-definition-check term-docstring-says-primitive)
    :using (term-definition-check term-docstring-says-primitive))

; =====================================================================
; Code vs Docs — two-branch-then-diff
; =====================================================================

; --- 1. Reader pipeline function count ---

(derive reader-doc-count
    (count-exists tokenize-doc read-tokens-doc atom-doc parse-doc parse-all-doc comment-char)
    :using (count-exists counting.count-exists-base counting.count-exists-step
            tokenize-doc read-tokens-doc atom-doc parse-doc parse-all-doc comment-char))

(defterm reader-impl-count 6
    :evidence (evidence "atoms.py"
        :quotes ("def tokenize(" "def read_tokens(" "def atom(" "def parse(" "def parse_all(" "if char == \";\":")
        :explanation "6 reader pipeline features in source"))

(diff reader-pipeline-coverage
    :replace reader-doc-count
    :with reader-impl-count)

; --- 2. Atom conversion chain ---

(derive atom-conv-doc-count
    (count-exists atom-tries-int-first atom-tries-float-second atom-keyword-prefix atom-false-token atom-fallback-is-symbol)
    :using (count-exists counting.count-exists-base counting.count-exists-step
            atom-tries-int-first atom-tries-float-second atom-keyword-prefix atom-false-token atom-fallback-is-symbol))

(defterm atom-conv-impl-count 5
    :evidence (evidence "atoms.py"
        :quotes ("return int(token)" "return float(token)" "if token.startswith(\":\"):" "if token == \"false\":" "return Symbol(token)")
        :explanation "5 conversion branches in atom()"))

(diff atom-conversion-coverage
    :replace atom-conv-doc-count
    :with atom-conv-impl-count)

; --- 3. Core type documentation ---

(derive core-types-doc-count
    (count-exists symbol-docstring symbol-base-class evidence-docstring axiom-docstring theorem-docstring term-docstring)
    :using (count-exists counting.count-exists-base counting.count-exists-step
            symbol-docstring symbol-base-class evidence-docstring axiom-docstring theorem-docstring term-docstring))

(defterm core-types-impl-count 6
    :evidence (evidence "atoms.py"
        :quotes ("class Symbol(str):" "Just a string with a distinct type" "Structured evidence with verifiable quotes" "An axiom: a foundational WFF" "A theorem: a WFF derived from" "A term/concept/primitive")
        :explanation "6 core type properties in source"))

(diff core-types-coverage
    :replace core-types-doc-count
    :with core-types-impl-count)

; --- 4. Evidence/provenance mechanism ---

(derive evidence-mechanism-doc-count
    (count-exists evidence-grounded-doc evidence-grounded-impl axiom-has-origin theorem-has-derivation theorem-default-origin)
    :using (count-exists counting.count-exists-base counting.count-exists-step
            evidence-grounded-doc evidence-grounded-impl axiom-has-origin theorem-has-derivation theorem-default-origin grounding-rule origin-is-provenance))

(defterm evidence-mechanism-impl-count 5
    :evidence (evidence "atoms.py"
        :quotes ("def is_grounded" "return self.verified or self.verify_manual" "origin: \"str | Evidence\"" "derivation: list" "origin: \"str | Evidence\" = \"derived\"")
        :explanation "5 evidence/provenance features in source"))

(diff evidence-mechanism-coverage
    :replace evidence-mechanism-doc-count
    :with evidence-mechanism-impl-count)

; --- 5. Evidence status labels ---
; String-valued defterms — diff each against its code-branch counterpart

(defterm evidence-unverified-code "UNVERIFIED"
    :evidence (evidence "atoms.py"
        :quotes ("status = \"grounded\" if self.is_grounded else \"UNVERIFIED\"")
        :explanation "Unverified status label in Evidence.__str__"))

(diff evidence-unverified-label
    :replace evidence-unverified-status
    :with evidence-unverified-code)

(defterm evidence-grounded-code "grounded"
    :evidence (evidence "atoms.py"
        :quotes ("status = \"grounded\" if self.is_grounded else \"UNVERIFIED\"")
        :explanation "Grounded status label in Evidence.__str__"))

(diff evidence-grounded-label
    :replace evidence-grounded-status
    :with evidence-grounded-code)

; --- 6. DSL helpers ---

(derive dsl-helpers-doc-count
    (count-exists match-doc free-vars-doc substitute-doc to-sexp-doc)
    :using (count-exists counting.count-exists-base counting.count-exists-step
            match-doc free-vars-doc substitute-doc to-sexp-doc match-substitute-roundtrip))

(defterm dsl-helpers-impl-count 4
    :evidence (evidence "atoms.py"
        :quotes ("def match(" "def free_vars(" "def substitute(" "def to_sexp(")
        :explanation "4 DSL helper functions in source"))

(diff dsl-helpers-coverage
    :replace dsl-helpers-doc-count
    :with dsl-helpers-impl-count)

; --- 7. Term display paths ---

(derive term-display-doc-count
    (count-exists term-forward-decl-display term-has-body-display)
    :using (count-exists counting.count-exists-base counting.count-exists-step
            term-forward-decl-display term-has-body-display term-display-rule))

(defterm term-display-impl-count 2
    :evidence (evidence "atoms.py"
        :quotes ("(primitive)" "to_sexp(self.definition)")
        :explanation "2 display paths in Term.__str__"))

(diff term-display-coverage
    :replace term-display-doc-count
    :with term-display-impl-count)

; --- 8. Splat pattern support ---

(fact match-splat-impl true
    :evidence (evidence "atoms.py"
        :quotes ("# Splat: ?...name as last element matches remaining items
        if (pattern and isinstance(pattern[-1], Symbol)
                and str(pattern[-1]).startswith(\"?...\")):")
        :explanation "match() implements ?... splat matching"))

(fact substitute-splat-impl true
    :evidence (evidence "atoms.py"
        :quotes ("if (isinstance(sub, Symbol) and str(sub).startswith(\"?...\")
                    and sub in bindings):
                val = bindings[sub]
                if isinstance(val, list):
                    result.extend(val)")
        :explanation "substitute() implements ?... splicing"))

(derive splat-doc-count
    (count-exists match-splat-doc substitute-splat-doc)
    :using (count-exists match-splat-doc substitute-splat-doc))

(derive splat-impl-count
    (count-exists match-splat-impl substitute-splat-impl)
    :using (count-exists match-splat-impl substitute-splat-impl))

(derive splat-paired-count
    (count-exists (and match-splat-doc match-splat-impl)
                  (and substitute-splat-doc substitute-splat-impl))
    :using (count-exists match-splat-doc match-splat-impl substitute-splat-doc substitute-splat-impl))

(diff splat-paired-vs-doc
    :replace splat-doc-count
    :with splat-paired-count)

(diff splat-paired-vs-impl
    :replace splat-impl-count
    :with splat-paired-count)

(diff match-splat-pair
    :replace match-splat-doc
    :with match-splat-impl)

(diff substitute-splat-pair
    :replace substitute-splat-doc
    :with substitute-splat-impl)

; --- 9. Module contract (purity vs mutability) ---
; Docstring claims purity. Axiom: purity implies immutability.
; Code: are all types actually frozen? No — diff surfaces the inconsistency.

(derive module-purity-contract
    (and module-claims-pure-types module-claims-no-domain)
    :using (module-claims-pure-types module-claims-no-domain
            module-is-stateless purity-implies-immutable))

(defterm all-types-immutable
    (and symbol-is-immutable evidence-is-frozen axiom-class-is-frozen
         theorem-class-is-frozen term-class-is-frozen)
    :evidence (evidence "atoms.py"
        :quotes ("class Symbol(str):
    \"\"\"A symbol in Parseltongue. Just a string with a distinct type.\"\"\""
                 "return Symbol(token)"
                 "@dataclass
class Evidence:
    \"\"\"Structured evidence with verifiable quotes from a source document.\"\"\"

    document: str  # registered document name
    quotes: list[str]  # exact quotes from the document
    explanation: str = \"\"  # why these quotes support the claim
    verification: list = field(default_factory=list)  # filled by verifier
    verified: bool = False  # all quotes verified?
    verify_manual: bool = False  # manually verified by user?"
                 "@dataclass
class Axiom:
    \"\"\"An axiom: a foundational WFF assumed true, with evidence.\"\"\"

    name: str
    wff: Any
    origin: \"str | Evidence\""
                 "@dataclass
class Theorem:
    \"\"\"A theorem: a WFF derived from facts, axioms, terms, or other theorems.\"\"\"

    name: str
    wff: Any
    derivation: list = field(default_factory=list)
    origin: \"str | Evidence\" = \"derived\""
                 "@dataclass
class Term:
    \"\"\"A term/concept/primitive introduced into the system.\"\"\"

    name: str
    definition: Any
    origin: \"str | Evidence\""
                 "to_sexp(self.definition) if self.definition is not None"
                 "isinstance(obj, Symbol)")
        :explanation "All five types are interconnected: atom() produces Symbols, Evidence grounds claims via origin in Axiom/Theorem/Term, Theorem tracks derivation chains, Term stores definitions — they form the complete atom type system"))

(diff module-purity-vs-immutability
    :replace module-purity-contract
    :with all-types-immutable)

; --- 9. Evidence default grounding ---
; Docstring defines two grounding paths (verified, manual).
; Code defaults both to False — defaults don't satisfy grounding.

(derive grounding-has-two-paths
    (and grounding-path-verified grounding-path-verify-manual)
    :using (grounding-path-verified grounding-path-verify-manual default-evidence-ungrounded))

(defterm defaults-satisfy-grounding
    (or evidence-verified-default evidence-verify-manual-default)
    :evidence (evidence "atoms.py"
        :quotes ("verified: bool = False"
                 "verify_manual: bool = False"
                 "return self.verified or self.verify_manual")
        :explanation "Both grounding fields default to False and are combined via OR in is_grounded — defaults don't satisfy grounding"))

(diff evidence-defaults-grounding
    :replace grounding-has-two-paths
    :with defaults-satisfy-grounding)

; --- 10. Bool roundtrip consistency ---
; Parser: atom("true")→True, atom("false")→False
; Printer: to_sexp(True)→"true", to_sexp(False)→"false"
; Diff confirms roundtrip works for both values.

(derive bool-true-roundtrip
    (= atom-true-token to-sexp-bool-true)
    :using (atom-true-token to-sexp-bool-true bool-roundtrip-consistent))

(derive bool-false-roundtrip
    (= atom-false-token to-sexp-bool-false)
    :using (atom-false-token to-sexp-bool-false))

(diff bool-roundtrip-coverage
    :replace bool-true-roundtrip
    :with bool-false-roundtrip)

; --- 11. Term display documentation ---
; Docstring documents "primitive" concept, code implements the check.

(derive term-primitive-doc-view
    term-docstring-says-primitive
    :using (term-docstring-says-primitive term-display-documented))

(diff term-display-documented-check
    :replace term-primitive-doc-view
    :with term-definition-check)

